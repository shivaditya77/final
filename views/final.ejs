<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="final">
    <link rel="stylesheet" href="/css/Final.css">
    <div class="final-body">
        <div class="final-vignette"></div>
        <div class="final-grain"></div>
        <div class="bg-parallax"></div>
        
        <%- include('partials/navbar') %>

        <div class="final-container">
            <div id="normal-state">
                <div class="overlay-card">
                    <div class="intro-badge">
                        <span class="badge-text">T H E · F I N A L · C H A P T E R</span>
                        <span class="badge-heart">💕</span>
                    </div>
                    
                    <div class="candle-container">
                        <div class="candle-icon">🕯️</div>
                    </div>

                    <div class="message-container">
                        <h1 class="romantic-message" id="display-text"></h1>
                        <div class="cursor-blink" id="cursor-blink" style="display:none">|</div>
                    </div>

                    <div class="button-container" id="open-heart-btn-container">
                        <button id="open-heart-btn" class="romantic-final-btn">
                            <span class="btn-content">
                                <span class="btn-icon">💌</span>
                                <span class="btn-text">Open My Heart</span>
                                <span class="btn-sparkle">✨</span>
                            </span>
                        </button>
                    </div>

                    <div class="proposal-section" id="proposal-section" style="display:none">
                        <div class="proposal-content">
                            <div class="ring-icon">💍</div>
                            <h2 class="proposal-question">Will You Be My Forever?</h2>
                            <div class="proposal-buttons">
                                <button class="yes-btn" id="yes-btn">💖 Yes, Forever 💖</button>
                                <button class="no-btn" id="no-btn">No 😢</button>
                            </div>
                            <p class="proposal-hint" id="proposal-hint">(There's only one right answer 😏)</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="celebration-section" id="celebration-state" style="display:none">
                <canvas id="fireworks-canvas" class="fireworks-canvas"></canvas>
                <div class="celebration-content">
                    <div class="firework">🎆✨🎇</div>
                    <h2 class="celebration-title">I Love You! 💖</h2>
                    <p class="celebration-text">You've made me the happiest person alive!<br />Today, tomorrow, forever... ❤️</p>
                    <button class="share-btn" onclick="alert('❤️ SHE SAID YES! Screenshot this beautiful moment! ❤️')">
                        📱 Share This Moment 📱
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const messageText = `Happy Birthday, my love Bhondu… ❤️✨

Sometimes I sit and think… what did I do to deserve you?
Because the way you came into my life and changed everything… it feels nothing less than a miracle. 🥺

You didn’t just become a part of my life…
you became my peace in chaos, my comfort in silence, my strength when I feel weak. 💖

There are days when I don’t say it enough…
but the truth is, you are the most beautiful thing that has ever happened to me. ✨

If life ever gives me a chance to choose again,
in every lifetime, in every version of me…
I will find you, and I will choose you—again and again. 💫

And even if one day everything fades away,
my love for you never will… it will stay, quietly, deeply, forever. ❤️

On your birthday, I don’t just wish you happiness…
I wish you a life full of love, dreams, and everything your heart deserves. 🥺💖

And selfishly… I wish to be a part of all your tomorrows. ✨

I love you… more than words, more than time, more than I can ever explain. ❤️💫💕`;

            const displayText = document.getElementById('display-text');
            const cursor = document.getElementById('cursor-blink');
            const openHeartBtn = document.getElementById('open-heart-btn');
            const proposalSection = document.getElementById('proposal-section');
            const noBtn = document.getElementById('no-btn');
            const yesBtn = document.getElementById('yes-btn');
            const proposalHint = document.getElementById('proposal-hint');

            let noClickCount = 0;
            let typeTimeout = null;
            let fireworksId = null;

            let finalAudio = null;

            if (openHeartBtn) {
                openHeartBtn.addEventListener('click', () => {
                    // Stop background music if playing
                    if (window.pauseMusic) window.pauseMusic();
                    
                    finalAudio = new Audio('/assets/final.mp3');
                    finalAudio.play().catch(() => {});

                    const btnContainer = document.getElementById('open-heart-btn-container');
                    if (btnContainer) btnContainer.style.display = 'none';
                    if (cursor) cursor.style.display = 'inline-block';
                    let i = 0;
                    const type = () => {
                        if (!document.getElementById('display-text')) return;
                        if (i < messageText.length) {
                            const char = messageText.charAt(i);
                            if (displayText) displayText.innerText = messageText.substring(0, i + 1);
                            i++;
                            let delay = 40;
                            if (char === '.' || char === '!' || char === '?') delay = 300;
                            else if (char === ',' || char === ';') delay = 150;
                            typeTimeout = setTimeout(type, delay);
                        } else {
                            if (cursor) cursor.style.display = 'none';
                            setTimeout(() => {
                                if (proposalSection) {
                                    proposalSection.style.display = 'block';
                                    proposalSection.style.animation = 'fadeInUp 1s ease forwards';
                                }
                            }, 1500);
                        }
                    };
                    type();
                });
            }

            // Cleanup music when leaving this page via Barba
            barba.hooks.before(() => {
                if (finalAudio) {
                    finalAudio.pause();
                    finalAudio.src = "";
                    finalAudio = null;
                }
            });

            if (noBtn) {
                const moveButton = () => {
                    const x = Math.random() * (window.innerWidth - noBtn.offsetWidth - 100);
                    const y = Math.random() * (window.innerHeight - noBtn.offsetHeight - 100);
                    noBtn.style.position = 'fixed';
                    noBtn.style.left = `${x}px`;
                    noBtn.style.top = `${y}px`;
                    noBtn.style.zIndex = '9999';
                };

                noBtn.addEventListener('mouseover', moveButton);
                noBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    moveButton();
                    const noMessages = [
                        "Are you sure? 😢 Think of our journey...",
                        "Really? After everything we've shared? 💭",
                        "I'll ask again... with more love! ❤️",
                        "That's not an option for us! 😏",
                        "Last chance to make me the happiest! 💕",
                        "Okay now you're just teasing me! 😂 SAY YES!"
                    ];
                    if (noClickCount < noMessages.length - 1) {
                        if (proposalHint) proposalHint.innerText = noMessages[noClickCount];
                        noClickCount++;
                        if (yesBtn) yesBtn.style.transform = `scale(${1 + noClickCount * 0.2})`;
                        if (yesBtn) yesBtn.style.boxShadow = `0 0 ${20 + noClickCount * 10}px #ff4d6d`;
                    } else {
                        celebrate();
                    }
                });
            }

            if (yesBtn) {
                yesBtn.addEventListener('click', celebrate);
            }

            function celebrate() {
                const norm = document.getElementById('normal-state');
                const celeb = document.getElementById('celebration-state');
                if (norm) norm.style.display = 'none';
                if (celeb) celeb.style.display = 'block';
                
                if (finalAudio) finalAudio.pause(); // Reset if already playing
                finalAudio = new Audio('/assets/final.mp3');
                finalAudio.play().catch(() => {});
                startFireworks();
            }

            function startFireworks() {
                const canvas = document.getElementById('fireworks-canvas');
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;

                let fireworks = [];

                class Firework {
                    constructor(x, y) {
                        this.x = x; this.y = y;
                        this.particles = [];
                        this.color = `hsl(${Math.random() * 360}, 100%, 65%)`;
                        for (let i = 0; i < 60; i++) {
                            const angle = (Math.PI * 2 * i) / 60;
                            const velocity = Math.random() * 6 + 2;
                            this.particles.push({ x: this.x, y: this.y, vx: Math.cos(angle)*velocity, vy: Math.sin(angle)*velocity, life: 1 });
                        }
                    }
                    update() {
                        this.particles.forEach(p => { p.x += p.vx; p.y += p.vy; p.vy += 0.1; p.life -= 0.02; });
                        this.particles = this.particles.filter(p => p.life > 0);
                        return this.particles.length > 0;
                    }
                    draw() {
                        this.particles.forEach(p => { ctx.globalAlpha = p.life; ctx.fillStyle = this.color; ctx.fillRect(p.x, p.y, 3, 3); });
                    }
                }

                function animate() {
                    if (!document.getElementById('fireworks-canvas')) return;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    if (Math.random() < 0.05) fireworks.push(new Firework(Math.random()*canvas.width, Math.random()*canvas.height*0.5));
                    fireworks = fireworks.filter(f => {
                        const alive = f.update();
                        if (alive) f.draw();
                        return alive;
                    });
                    fireworksId = requestAnimationFrame(animate);
                }
                animate();
            }

            // Barba cleanup
            barba.hooks.before(() => {
                if (typeTimeout) clearTimeout(typeTimeout);
                if (fireworksId) cancelAnimationFrame(fireworksId);
            });
        })();
    </script>
</div>
<%- include('partials/footer') %>
