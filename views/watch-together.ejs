<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="watch-together">
    <link rel="stylesheet" href="/css/Home.css">
    <script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>

    <div class="home-body cinema-mode">
        <div class="animated-bg"></div>
        <div class="vignette"></div>

        <%- include('partials/navbar') %>

        <div class="cinema-app-wrapper">
            <main class="cinema-main-content">
                <div class="cinema-top-nav">
                    <div class="brand-logo" style="font-family: 'Poppins', sans-serif; font-size: 1.5rem; font-weight: 900; color: #ff4d6d; margin-right: 20px; letter-spacing: -1px;">Bhondu<span style="color: #fff; background: #ff4d6d; padding: 2px 8px; border-radius: 8px; margin-left: 2px;">Tube</span></div>
                    <div class="search-bar-wrapper">
                        <input type="text" id="video-input" placeholder="Search BhonduTube..." class="cinema-input" autocomplete="off">
                        <button id="load-video-btn" class="cinema-search-btn">🔍</button>
                    </div>
                    <div id="search-results" class="search-results-dropdown"></div>
                    
                    <div class="nav-actions-right">
                        <a href="/" class="nav-icon-link" title="Home">🏠</a>
                        <button class="nav-icon-link" title="Notifications">🔔</button>
                        <button class="nav-icon-link profile-mini" title="Soulmate">💋</button>
                    </div>
                </div>

                <div class="cinema-grid-layout">
                    <div class="video-section">
                        <div class="player-wrapper">
                            <div id="player"></div>
                            <div class="sync-status" id="sync-status">
                                <span class="status-dot"></span>
                                <span id="status-text">Waiting...</span>
                            </div>
                        </div>

                        <div class="video-info-glass glass-card">
                            <h1 id="video-title" class="v-title">Select a video to begin...</h1>
                        </div>

                        <div class="reaction-strip-wrapper">
                            <div class="reaction-strip genz-style">
                                <button class="reaction-btn genz-btn" data-emoji="❤️">❤️</button>
                                <button class="reaction-btn genz-btn" data-emoji="😂">😂</button>
                                <button class="reaction-btn genz-btn" data-emoji="😍">😍</button>
                                <button class="reaction-btn genz-btn" data-emoji="🔥">🔥</button>
                                <button class="reaction-btn genz-btn" data-emoji="🍿">🍿</button>
                            </div>
                        </div>
                    </div>

                    <div class="chat-section glass-card">
                        <div class="chat-header">
                            <h3>Live Popcorn Chat</h3>
                        </div>
                        <div id="cinema-chat-messages" class="chat-messages classy-scroll">
                            <div class="chat-system-msg">Messages clear on reload. ❤️</div>
                        </div>
                        <div class="chat-input-area">
                            <div class="glass-input-wrapper">
                                <input type="text" id="chat-input" placeholder="Type a message..." autocomplete="off">
                                <button id="send-chat-btn">➔</button>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <style>
        .cinema-app-wrapper { display: flex; height: 100vh; background: #050505; color: #fff; overflow: hidden; position: relative; }
        .cinema-main-content { flex: 1; display: flex; flex-direction: column; background: radial-gradient(circle at top right, #1a0a0a 0%, #050505 100%); height: 100%; overflow: hidden; }
        .cinema-top-nav { padding: 15px 40px; display: flex; justify-content: space-between; align-items: center; background: rgba(5,5,5,0.9); backdrop-filter: blur(15px); z-index: 1100; border-bottom: 1px solid rgba(255,255,255,0.05); flex-shrink: 0; }
        .status-container, .user-status-dot, .nav-status-signal { display: none !important; }
        .search-bar-wrapper { display: flex; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 50px; width: 100%; max-width: 500px; padding: 5px; transition: 0.3s; align-items: center; }
        .search-bar-wrapper:focus-within { border-color: #ff4d6d; box-shadow: 0 0 15px rgba(255,77,109,0.3); }
        .cinema-input { flex: 1; background: transparent; border: none; padding: 10px 20px; color: #fff; outline: none; }
        .cinema-search-btn { background: #ff4d6d; border: none; color: white; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; margin-left: 10px; }
        .nav-actions-right { display: flex; gap: 15px; align-items: center; }
        .nav-icon-link { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 10px; border-radius: 12px; cursor: pointer; transition: 0.3s; text-decoration: none; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; width: 45px; height: 45px; }
        .nav-icon-link:hover { background: rgba(255,77,109,0.15); border-color: #ff4d6d; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(255,77,109,0.3); }
        .profile-mini { border-radius: 50%; background: linear-gradient(135deg, rgba(255,77,109,0.2), rgba(255,30,77,0.2)); }
        .cinema-grid-layout { display: grid; grid-template-columns: 1fr 400px; flex: 1; overflow: hidden; margin-top: 10px; }
        .video-section { padding: 30px; overflow-y: auto; display: flex; flex-direction: column; }
        .player-wrapper { position: relative; background: #000; border-radius: 24px; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.8); border: 1px solid rgba(255,255,255,0.05); width: 100%; aspect-ratio: 16/9; flex-shrink: 0; }
        #player { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
        .sync-status { position: absolute; top: 20px; right: 20px; background: rgba(10, 25, 41, 0.8); padding: 8px 18px; border-radius: 50px; font-size: 0.85rem; display: flex; align-items: center; gap: 10px; z-index: 50; backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); }
        .status-dot { width: 8px; height: 8px; background: #ff4d6d; border-radius: 50%; animation: pulse 1.5s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }
        
        /* Gen Z Reaction Styling */
        .reaction-strip-wrapper { margin-top: 20px; display: flex; justify-content: center; flex-shrink: 0; }
        .genz-style { display: flex; gap: 15px; padding: 10px 25px; background: rgba(255,255,255,0.03); border-radius: 60px; border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(15px); box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
        .genz-btn { width: 55px; height: 55px; font-size: 1.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; overflow: hidden; }
        .genz-btn:hover { transform: scale(1.3) translateY(-8px); background: rgba(255,77,109,0.15); border-color: #ff4d6d; box-shadow: 0 10px 25px rgba(255,77,109,0.4); }

        /* Classy Chat */
        .chat-section { display: flex; flex-direction: column; background: rgba(10,10,10,0.5); border-left: 1px solid rgba(255,255,255,0.05); overflow: hidden; height: 100%; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; min-height: 0; }
        .msg-bubble { padding: 12px 18px; border-radius: 20px; max-width: 80%; font-size: 0.95rem; position: relative; animation: fadeIn 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.2); backdrop-filter: blur(5px); }
        .msg-other { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.05); align-self: flex-start; border-bottom-left-radius: 4px; }
        .msg-me { background: linear-gradient(135deg, #ff4d6d 0%, #ff1e4d 100%); align-self: flex-end; border-bottom-right-radius: 4px; color: #fff; box-shadow: 0 5px 20px rgba(255, 77, 109, 0.3); }
        .msg-user { font-size: 0.75rem; font-weight: 800; margin-bottom: 4px; display: block; color: #ff4d6d; }
        .msg-me .msg-user { color: rgba(255, 255, 255, 0.8); }
        .chat-input-area { padding: 15px; background: rgba(5,5,5,0.8); border-top: 1px solid rgba(255,255,255,0.05); flex-shrink: 0; }
        .glass-input-wrapper { display: flex; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 50px; padding: 5px 5px 5px 20px; align-items: center; transition: 0.3s; backdrop-filter: blur(10px); }
        .glass-input-wrapper:focus-within { border-color: #ff4d6d; background: rgba(255,255,255,0.06); box-shadow: 0 0 20px rgba(255,77,109,0.2); }
        .glass-input-wrapper input { flex: 1; background: transparent; border: none; color: #fff; outline: none; font-size: 0.95rem; }
        #send-chat-btn { background: #ff4d6d; border: none; width: 40px; height: 40px; border-radius: 50%; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.3s; }
        #send-chat-btn:hover { transform: scale(1.1) rotate(-15deg); }

        /* Search Results */
        .search-results-dropdown { position: absolute; top: calc(100% + 10px); left: 50%; transform: translateX(-50%); width: 95%; max-width: 500px; background: rgba(15, 15, 15, 0.98); border: 1px solid rgba(255, 77, 109, 0.4); border-radius: 20px; max-height: 400px; overflow-y: auto; z-index: 2000; display: none; box-shadow: 0 20px 60px rgba(0,0,0,0.8); backdrop-filter: blur(25px); }
        .search-item { display: flex; align-items: center; gap: 15px; padding: 12px 20px; cursor: pointer; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .search-item img { width: 80px; aspect-ratio: 16/9; object-fit: cover; border-radius: 8px; }
        .search-item b { font-size: 0.85rem; color: #fff; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Smooth Title */
        .v-title { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 0; line-height: 1.2; flex-shrink: 0; }
        .video-info-glass { padding: 25px; margin-top: 20px; border-radius: 20px; flex-shrink: 0; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes floatUp { 0% { transform: translateY(0) scale(1); opacity: 1; } 100% { transform: translateY(-200px) scale(1.5); opacity: 0; } }
        .classy-scroll::-webkit-scrollbar { width: 4px; }
        .classy-scroll::-webkit-scrollbar-thumb { background: rgba(255, 77, 109, 0.3); border-radius: 10px; }

        /* MOBILE RESPONSIVE QUERIES - PRO GRADE */
        @media (max-width: 850px) {
            .cinema-top-nav { padding: 10px 15px; flex-direction: column; gap: 10px; height: auto; }
            .search-bar-wrapper { max-width: 100%; order: 1; }
            .nav-actions-right { order: 2; width: 100%; justify-content: center; margin-top: 5px; }
            .cinema-grid-layout { display: flex; flex-direction: column; height: auto; overflow-y: auto; }
            .video-section { flex-shrink: 0; padding: 15px; overflow: visible; }
            .chat-section { flex: 1; height: auto; border-left: none; border-top: 1px solid rgba(255, 255, 255, 0.05); min-height: 500px; margin: 0; background: rgba(5,5,5,0.8); border-radius: 0; }
            .chat-messages { max-height: 400px; }
            .chat-input-area { position: sticky; bottom: 0; background: #050505; z-index: 100; padding: 15px; }
            .v-title { font-size: 1.4rem; padding: 0 10px; }
            .genz-style { gap: 10px; padding: 8px 15px; }
            .genz-btn { width: 48px; height: 48px; font-size: 1.5rem; }
            .reaction-strip-wrapper { margin-top: 20px; }
            .search-results-dropdown { width: 95%; }
        }

        @media (max-width: 480px) {
            .v-title { font-size: 1.1rem; }
            .genz-btn { width: 42px; height: 42px; font-size: 1.3rem; }
            .genz-style { gap: 5px; padding: 5px 10px; }
            .nav-icon-link { width: 38px; height: 38px; font-size: 1rem; }
        }
    </style>

    <script>
        let player, pusher, channel, isSyncing = false, lastAction = "";
        const username = "<%= username %>";

        function initSync() {
            pusher = new Pusher("<%= pusherKey %>", { cluster: "<%= pusherCluster %>", authEndpoint: "/pusher/auth" });
            channel = pusher.subscribe("presence-soul-connect");
            channel.bind("pusher:subscription_succeeded", (m) => { if (m.count > 1) updateStatus(true); });
            channel.bind("pusher:member_added", () => updateStatus(true));
            channel.bind("pusher:member_removed", () => updateStatus(false));
            channel.bind("youtube-sync", (data) => {
                if (data.username === username) return;
                isSyncing = true;
                handleRemoteAction(data);
                if (data.action === 'load') fetchVideoDetails(data.videoId);
                setTimeout(() => isSyncing = false, 1000);
            });
            channel.bind("youtube-chat", (data) => {
                if (data.username === username) return;
                showFloatingEmoji(data.text);
            });
            channel.bind("youtube-chat-message", (data) => {
                if (data.username === username) return;
                appendChatMessage(data.username, data.text, false);
            });
        }

        function syncAction(action, currentTime, videoId = null) {
            fetch("/api/youtube/sync", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ action, currentTime, videoId })
            });
        }

        function handleRemoteAction(data) {
            if (data.action === 'play') { player.seekTo(data.currentTime, true); player.playVideo(); }
            else if (data.action === 'pause') player.pauseVideo();
            else if (data.action === 'seek') player.seekTo(data.currentTime, true);
            else if (data.action === 'load') player.loadVideoById(data.videoId);
        }

        const chatInput = document.getElementById("chat-input");
        const sendBtn = document.getElementById("send-chat-btn");
        const chatMessages = document.getElementById("cinema-chat-messages");

        function sendChatMessage() {
            const text = chatInput.value.trim();
            if (!text) return;
            fetch("/api/youtube/chat-message", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ text }) });
            appendChatMessage(username, text, true);
            chatInput.value = "";
        }

        function appendChatMessage(user, text, isMe) {
            const div = document.createElement("div");
            div.className = `msg-bubble ${isMe ? 'msg-me' : 'msg-other'}`;
            div.innerHTML = `<span class="msg-user">${user}</span><span class="msg-text">${text}</span>`;
            chatMessages.appendChild(div);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        sendBtn.onclick = sendChatMessage;
        chatInput.onkeypress = (e) => { if (e.key === "Enter") sendChatMessage(); };

        function updateStatus(online) {
            const t = document.getElementById("status-text"), d = document.querySelector(".status-dot");
            t.innerText = online ? "Soulmate is here! ❤️" : "Waiting for Soulmate...";
            d.style.background = online ? "#00ff88" : "#ff4d6d";
        }

        function onYouTubeIframeAPIReady() {
            player = new YT.Player('player', { height: '100%', width: '100%', videoId: 'dQw4w9WgXcQ', playerVars: { 'autoplay': 0, 'controls': 1 }, events: { 'onStateChange': onPlayerStateChange } });
            initSync();
        }

        function onPlayerStateChange(e) {
            if (isSyncing) return;
            const time = player.getCurrentTime();
            let action = "";
            if (e.data === YT.PlayerState.PLAYING) action = "play";
            else if (e.data === YT.PlayerState.PAUSED) action = "pause";
            else if (e.data === YT.PlayerState.BUFFERING) action = "seek";
            if (action && action !== lastAction) { lastAction = action; syncAction(action, time); }
        }

        const videoInput = document.getElementById("video-input"), resultsDropdown = document.getElementById("search-results"), apiKey = "<%= youtubeApiKey %>";
        videoInput.oninput = () => {
            const q = videoInput.value.trim();
            if (q.length < 3) { resultsDropdown.style.display = "none"; return; }
            clearTimeout(window.sT);
            window.sT = setTimeout(async () => {
                try {
                    const r = await fetch(`https://www.googleapis.com/youtube/v3/search?part=snippet&maxResults=8&q=${encodeURIComponent(q)}&type=video&key=${apiKey}`);
                    const d = await r.json();
                    if (d.items) displayResults(d.items);
                } catch (e) {}
            }, 500);
        };

        function displayResults(items) {
            resultsDropdown.innerHTML = "";
            items.forEach(item => {
                const div = document.createElement("div");
                div.className = "search-item";
                div.innerHTML = `<img src="${item.snippet.thumbnails.default.url}"><div><b>${item.snippet.title}</b><br><small>${item.snippet.channelTitle}</small></div>`;
                div.onclick = () => {
                    const id = item.id.videoId;
                    player.loadVideoById(id);
                    syncAction("load", 0, id);
                    fetchVideoDetails(id);
                    resultsDropdown.style.display = "none";
                    videoInput.value = "";
                };
                resultsDropdown.appendChild(div);
            });
            resultsDropdown.style.display = "block";
        }

        async function fetchVideoDetails(id) {
            try {
                const r = await fetch(`https://www.googleapis.com/youtube/v3/videos?part=snippet&id=${id}&key=${apiKey}`);
                const d = await r.json();
                if (d.items[0]) {
                    const v = d.items[0].snippet;
                    document.getElementById("video-title").innerText = v.title;
                }
            } catch (e) {}
        }

        document.querySelectorAll(".reaction-btn").forEach(btn => {
            btn.onclick = () => {
                const e = btn.getAttribute("data-emoji");
                showFloatingEmoji(e);
                fetch("/api/youtube/chat", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ text: e }) });
            };
        });

        function showFloatingEmoji(e) {
            const div = document.createElement("div");
            div.innerText = e;
            div.style.cssText = `position:fixed; left:${Math.random()*80+10}%; bottom:20%; font-size:2rem; z-index:2000; animation:floatUp 2s forwards; pointer-events:none;`;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 2000);
        }
    </script>
</div>
<%- include('partials/footer') %>
