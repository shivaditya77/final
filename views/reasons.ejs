    <script>
        (function() {
            // ========== INTRO ==========
            const intro = document.getElementById('reasons-intro');
            if (intro) {
                setTimeout(() => {
                    intro.classList.add('fade-out');
                    setTimeout(() => intro.remove(), 800);
                }, 1200); // Faster intro (1.2s instead of 3s)
            }

            // ========== SEARCH & SHUFFLE ==========
            const searchInput = document.getElementById('reasons-search');
            const shuffleBtn = document.getElementById('shuffle-btn');
            const cards = document.querySelectorAll('.reason-card');

            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase();
                    cards.forEach(card => {
                        const text = card.querySelector('.reason-text').innerText.toLowerCase();
                        if (text.includes(term)) {
                            card.style.display = 'flex';
                        } else {
                            card.style.display = 'none';
                        }
                    });
                });
            }

            if (shuffleBtn) {
                shuffleBtn.addEventListener('click', () => {
                    const randomIndex = Math.floor(Math.random() * cards.length);
                    const target = document.getElementById('reason-' + randomIndex);
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        target.classList.add('highlight-glow');
                        setTimeout(() => target.classList.remove('highlight-glow'), 2000);
                    }
                });
            }

            // ========== INTERSECTION OBSERVER (FADE IN) ==========
            const cardObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('in-view');
                    }
                });
            }, { 
                threshold: 0.01, // Very sensitive
                rootMargin: '0px 0px 200px 0px' // Proactive: Trigger 200px BEFORE it enters
            });

            cards.forEach(card => cardObserver.observe(card));

            // Force reveal first 4 cards immediately as a safety measure
            for(let i=0; i<4; i++) {
                if(cards[i]) cards[i].classList.add('in-view');
            }

            // ========== SCROLL LOGIC ==========
            const actualReasons = cards.length;
            let unlockedUpTo = 0;
            const progressFill = document.getElementById('reasons-progress');
            const scrollPctText = document.getElementById('scroll-pct');
            const unlockCountText = document.getElementById('unlock-count');
            const nextBtn = document.getElementById('next-btn');
            const popupOverlay = document.getElementById('popup-overlay');

            function handleScroll() {
                if (!progressFill) return;
                
                const winHeight = window.innerHeight;
                const docHeight = document.documentElement.scrollHeight;
                const scrollTop = window.scrollY || document.documentElement.scrollTop;
                const scrolled = (scrollTop / (docHeight - winHeight)) * 100;
                const pct = Math.min(100, Math.round(scrolled));

                progressFill.style.width = pct + '%';
                if (scrollPctText) scrollPctText.innerText = pct + '%';

                // Unlock based on scroll position - ensure we reach the end
                const targetUnlocked = Math.ceil((scrolled / 100) * actualReasons);
                
                if (targetUnlocked > unlockedUpTo) {
                    for (let i = 0; i < targetUnlocked; i++) {
                        const card = document.getElementById('reason-' + i);
                        if (card && card.classList.contains('locked')) {
                            unlockCard(card);
                        }
                    }
                    unlockedUpTo = Math.max(unlockedUpTo, targetUnlocked);
                    if (unlockCountText) unlockCountText.innerText = Math.min(actualReasons, unlockedUpTo);
                }

                if (pct > 90 && nextBtn) {
                    nextBtn.classList.add('show');
                }

                // Final check when at bottom
                if (pct >= 99) {
                    if (unlockedUpTo < actualReasons) {
                        cards.forEach(c => unlockCard(c));
                        unlockedUpTo = actualReasons;
                        if (unlockCountText) unlockCountText.innerText = actualReasons;
                    }
                    if (nextBtn) nextBtn.classList.add('show');
                }

                if (unlockedUpTo >= actualReasons && popupOverlay && !popupOverlay.classList.contains('show')) {
                    setTimeout(() => {
                        if (popupOverlay) {
                            popupOverlay.classList.add('show');
                            createHeartExplosion();
                        }
                    }, 800);
                }
            }

            function unlockCard(card) {
                card.classList.remove('locked');
                card.classList.add('unlocked');
                card.classList.add('in-view'); // Backup to ensure it's never black
                const lock = card.querySelector('.lock-icon');
                if (lock) lock.remove();
                const txt = card.querySelector('.reason-text');
                if (txt) txt.style.filter = 'none';
                
                const badge = document.createElement('div');
                badge.className = 'new-badge';
                badge.innerText = 'UNLOCKED';
                card.appendChild(badge);
                setTimeout(() => badge.remove(), 4000);
            }

            window.heartReason = (index) => {
                const card = document.getElementById('reason-' + index);
                if (card.classList.contains('locked')) return;
                
                const heart = document.getElementById('heart-pop-' + index);
                if (heart) {
                    heart.classList.remove('pop');
                    void heart.offsetWidth;
                    heart.classList.add('pop');
                    card.classList.add('hearted');
                }
            };

            window.addEventListener('scroll', handleScroll);
            handleScroll();

            const popupClose = document.getElementById('popup-close');
            if (popupClose) {
                popupClose.addEventListener('click', () => {
                    if (popupOverlay) popupOverlay.classList.remove('show');
                });
            }

            function createHeartExplosion() {
                const emojis = ['❤️', '💖', '💕', '💗', '💓'];
                for (let i = 0; i < 50; i++) {
                    setTimeout(() => {
                        const h = document.createElement('div');
                        h.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
                        h.style.cssText = `position:fixed;left:${Math.random()*100}%;top:${Math.random()*100}%;font-size:${Math.random()*25+15}px;pointer-events:none;z-index:3000;animation:floatHeartEffect 1.5s ease-out forwards;`;
                        document.body.appendChild(h);
                        setTimeout(() => h.remove(), 1500);
                    }, i * 30);
                }
            }

            // ========== MUSIC TOGGLE ==========
            const rMusicIcon = document.getElementById('reasons-music-icon');
            const musicBtn = document.getElementById('music-toggle-btn');
            if (musicBtn) {
                musicBtn.addEventListener('click', () => {
                    const isPlaying = window.toggleMusic();
                    if (rMusicIcon) rMusicIcon.innerText = isPlaying ? '🎶' : '🎵';
                });
            }

            // Barba cleanup
            barba.hooks.before(() => {
                window.removeEventListener('scroll', handleScroll);
            });
        })();
    </script>

    <style>
    @keyframes floatHeartEffect {
        0% { transform: translateY(0); opacity: 1; }
        100% { transform: translateY(-50px); opacity: 0; }
    }
    </style>
</div>
