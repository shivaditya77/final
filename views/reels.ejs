<%- include('partials/header') %>
    <div data-barba="container" data-barba-namespace="reels">
        <link rel="stylesheet" href="/css/Reels.css">
        <%- include('partials/navbar') %>
            <main class="reels-page">

                <!-- Soul Sync Toggle -->
                <div class="soul-sync-header">
                    <div id="sync-status" class="sync-status">
                        <span id="sync-text">Soul Sync Off</span>
                    </div>
                    <button id="master-sync-btn" class="soul-sync-toggle" onclick="toggleSoulSync()">
                        <div class="toggle-track">
                            <div class="toggle-thumb">♾️</div>
                        </div>
                    </button>
                </div>

                <!-- Sync Glow Border -->
                <div id="sync-glow" class="sync-glow-overlay"></div>

                <div class="reels-container" id="reels-container">
                    <% const totalReels=reels.length; const displayReels=[reels[totalReels-1], ...reels, reels[0]]; %>
                        <% displayReels.forEach((reel, index)=> { %>
                            <div class="reel-slide" id="reel-<%= index %>" data-video-url="<%= reel.url %>"
                                data-real-index="<%= index-1 %>">
                                <!-- Progress Bar -->
                                <div class="reel-progress-container">
                                    <div class="reel-progress-bar" id="progress-<%= index %>"></div>
                                </div>

                                <div class="reel-content" id="content-<%= index %>"
                                    onclick="handleInteraction(event, '<%= index %>')">
                                    <div class="reel-video-wrapper" id="video-wrapper-<%= index %>">
                                        <!-- Native Video will be injected here for performance -->
                                    </div>

                                    <div class="reel-loader">❤️</div>

                                    <!-- Tap to Unmute Indicator -->
                                    <div class="tap-unmute-indicator" id="mute-indicator-<%= index %>">🔊</div>

                                    <!-- Big Heart Overlay -->
                                    <div class="big-heart-overlay" id="big-heart-<%= index %>">❤️</div>

                                    <!-- Comment Bubbles Container -->
                                    <div id="comments-<%= index %>" class="reel-comments-container"></div>
                                </div>

                                <!-- Sidebar Actions -->
                                <div class="reel-sidebar">
                                    <div class="sidebar-item">
                                        <button class="sidebar-btn heart-btn" id="heart-btn-<%= index %>"
                                            onclick="triggerLove(this, event, '<%= index %>')">🤍</button>
                                        <span class="sidebar-label">Love</span>
                                    </div>
                                </div>

                                <!-- Info Section -->
                                <div class="reel-info-section">
                                    <div class="profile-line">
                                        <div class="profile-avatar">❤️</div>
                                        <span class="profile-name">
                                            <%= username==='Bhondu' ? 'Vishu' : 'Bhondu' %>
                                        </span>
                                        <span class="follow-btn">Following</span>
                                    </div>
                                    <h2 class="reel-description">
                                        <%= reel.title %>
                                    </h2>
                                </div>
                            </div>
                            <% }) %>
                </div>
            </main>

            <script>
                (function () {
                    const videoElements = {};
                    let currentActive = -1;
                    let isGlobalMuted = true;
                    let lastTapTime = 0;
                    let isSyncEnabled = false;
                    let syncLeader = null;
                    let isProcessingRemoteScroll = false;
                    let isProcessingRemotePlayback = false;
                    let isTeleporting = false;

                    const container = document.getElementById('reels-container');
                    const myUsername = "<%= username %>";
                    const otherUser = myUsername === 'Bhondu' ? 'Vishu' : 'Bhondu';
                    const totalItems = <%= totalReels %>;
                    
                    function setupSync() {
                        const pusher = window.globalPusher || (typeof initGlobalPusher === 'function' ? initGlobalPusher() : null);
                        const channel = window.globalChannel;

                        if (!channel) {
                            console.warn("⚠️ Sync deferred: Pusher channel not ready. Retrying...");
                            setTimeout(setupSync, 500);
                            return;
                        }

                        console.log("✅ Reels Sync Initialized on channel:", channel.name);

                        // Clear existing bindings to prevent duplicates
                        channel.unbind('force-sync');
                        channel.unbind('user-scrolled-reel');
                        channel.unbind('user-played-reel');
                        channel.unbind('user-paused-reel');
                        channel.unbind('user-hearted-reel');

                        channel.bind('force-sync', (data) => {
                            if (data.leader !== myUsername) {
                                isSyncEnabled = data.leader !== null;
                                syncLeader = data.leader;
                                updateSyncUI(isSyncEnabled);
                                
                                if (isSyncEnabled) {
                                    isProcessingRemoteScroll = true;
                                    isProcessingRemotePlayback = true;
                                    scrollToIndex(data.reelIndex + 1);
                                    setTimeout(() => {
                                        const v = videoElements[data.reelIndex + 1];
                                        if (v) {
                                            v.currentTime = data.currentTime;
                                            if (data.isPaused) v.pause(); else v.play();
                                        }
                                        isProcessingRemoteScroll = false;
                                        isProcessingRemotePlayback = false;
                                    }, 800);
                                }
                            }
                        });

                        channel.bind('user-scrolled-reel', (data) => {
                            if (isSyncEnabled && data.username !== myUsername) {
                                isProcessingRemoteScroll = true;
                                scrollToIndex(data.reelIndex + 1);
                                setTimeout(() => { isProcessingRemoteScroll = false; }, 1000);
                            }
                        });

                        channel.bind('user-played-reel', (data) => {
                            if (isSyncEnabled && data.username !== myUsername && videoElements[data.reelIndex + 1]) {
                                isProcessingRemotePlayback = true;
                                const v = videoElements[data.reelIndex + 1];
                                v.currentTime = data.currentTime;
                                v.play().finally(() => { isProcessingRemotePlayback = false; });
                            }
                        });

                        channel.bind('user-paused-reel', (data) => {
                            if (isSyncEnabled && data.username !== myUsername && videoElements[data.reelIndex + 1]) {
                                isProcessingRemotePlayback = true;
                                videoElements[data.reelIndex + 1].pause();
                                setTimeout(() => { isProcessingRemotePlayback = false; }, 100);
                            }
                        });
                        
                        channel.bind('user-hearted-reel', (data) => {
                            if (data.username !== myUsername && data.reelIndex == currentActive - 1) {
                                spawnHeart(window.innerWidth / 2, window.innerHeight / 2, true);
                            }
                        });
                    }

                    setupSync();

                    // ========== SYNC CONTROLS ==========
                    window.toggleSoulSync = () => {
                        isSyncEnabled = !isSyncEnabled;
                        if (isSyncEnabled) {
                            syncLeader = myUsername;
                            updateSyncUI(true);
                            const v = videoElements[currentActive];
                            fetch('/api/reels/force-sync', {
                                method: 'POST', headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    leader: myUsername,
                                    reelIndex: currentActive - 1,
                                    currentTime: v ? v.currentTime : 0,
                                    isPaused: v ? v.paused : false
                                })
                            });
                        } else {
                            syncLeader = null;
                            updateSyncUI(false);
                            fetch('/api/reels/force-sync', {
                                method: 'POST', headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ leader: null })
                            });
                        }
                    };

                    function updateSyncUI(enabled) {
                        const btn = document.getElementById('master-sync-btn');
                        const status = document.getElementById('sync-status');
                        const text = document.getElementById('sync-text');
                        const glow = document.getElementById('sync-glow');

                        if (enabled) {
                            btn.classList.add('active');
                            status.classList.add('active');
                            text.innerText = "Soul Sync Active ❤️";
                            glow.classList.add('active');
                            if(window.navigator.vibrate) window.navigator.vibrate([30, 50, 30]);
                        } else {
                            btn.classList.remove('active');
                            status.classList.remove('active');
                            text.innerText = "Soul Sync Off";
                            glow.classList.remove('active');
                        }
                    }

                    // ========== CORE REELS LOGIC ==========
                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach(entry => {
                            if (isTeleporting) return;
                            const index = parseInt(entry.target.id.split('-')[1]);
                            if (entry.isIntersecting && entry.intersectionRatio >= 0.6) {
                                if (index !== currentActive) handleReelVisible(index);
                            } else { stopVideo(index); }
                        });
                    }, { root: container, threshold: 0.6 });

                    function handleReelVisible(index) {
                        currentActive = index;
                        if (index === 0) teleportTo(totalItems);
                        else if (index === totalItems + 1) teleportTo(1);
                        else {
                            playVideo(index);
                            if (isSyncEnabled && !isProcessingRemoteScroll) {
                                fetch('/api/reels/sync-scroll', {
                                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ reelIndex: index - 1 })
                                });
                            }
                            preLoadVideo(index + 1);
                            preLoadVideo(index - 1);
                        }
                    }

                    function preLoadVideo(index) {
                        const slide = document.getElementById('reel-' + index);
                        if (!slide || videoElements[index]) return;
                        const wrapper = document.getElementById('video-wrapper-' + index);
                        const videoUrl = slide.getAttribute('data-video-url');
                        const video = document.createElement('video');
                        video.src = videoUrl; video.className = 'reel-native-video'; video.loop = true;
                        video.muted = isGlobalMuted; video.playsInline = true; video.preload = 'auto';

                        video.onplaying = () => {
                            const loader = slide.querySelector('.reel-loader');
                            if (loader) loader.classList.add('hidden');
                        };
                        video.ontimeupdate = () => {
                            const progressBar = document.getElementById('progress-' + index);
                            if (progressBar && video.duration) {
                                progressBar.style.width = (video.currentTime / video.duration * 100) + '%';
                            }
                        };
                        video.onplay = () => {
                            if (isSyncEnabled && !isProcessingRemotePlayback) {
                                fetch('/api/reels/play', {
                                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ reelIndex: index - 1, currentTime: video.currentTime })
                                });
                            }
                        };
                        video.onpause = () => {
                            if (isSyncEnabled && !isProcessingRemotePlayback) {
                                fetch('/api/reels/pause', {
                                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ reelIndex: index - 1 })
                                });
                            }
                        };
                        wrapper.appendChild(video);
                        videoElements[index] = video;
                    }

                    function playVideo(index) {
                        if (!videoElements[index]) preLoadVideo(index);
                        const v = videoElements[index];
                        if (v) { v.muted = isGlobalMuted; v.play().catch(() => { }); }
                    }

                    function stopVideo(index) {
                        const v = videoElements[index];
                        if (v) { v.pause(); v.currentTime = 0; }
                    }

                    function teleportTo(targetIndex) {
                        isTeleporting = true;
                        container.style.scrollSnapType = 'none';
                        container.scrollTop = targetIndex * window.innerHeight;
                        currentActive = targetIndex;
                        setTimeout(() => {
                            container.style.scrollSnapType = 'y mandatory';
                            isTeleporting = false;
                            playVideo(targetIndex);
                        }, 50);
                    }

                    function scrollToIndex(index) {
                        container.scrollTo({ top: index * window.innerHeight, behavior: 'smooth' });
                    }

                    window.handleInteraction = (e, index) => {
                        const now = Date.now();
                        const delta = now - lastTapTime;
                        if (delta < 300 && delta > 0) {
                            handleDoubleTap(e, index);
                            lastTapTime = 0;
                        } else {
                            lastTapTime = now;
                            setTimeout(() => { if (Date.now() - lastTapTime >= 250) toggleMute(index); }, 300);
                        }
                    };

                    function toggleMute(index) {
                        isGlobalMuted = !isGlobalMuted;
                        const v = videoElements[index];
                        if (v) { v.muted = isGlobalMuted; if (!isGlobalMuted && v.paused) v.play(); }
                        const ind = document.getElementById('mute-indicator-' + index);
                        if (ind) { ind.innerText = isGlobalMuted ? '🔇' : '🔊'; ind.classList.add('visible'); setTimeout(() => ind.classList.remove('visible'), 1000); }
                    }

                    function handleDoubleTap(e, index) {
                        const bigHeart = document.getElementById('big-heart-' + index);
                        if (bigHeart) { bigHeart.classList.add('animate'); setTimeout(() => bigHeart.classList.remove('animate'), 1000); }
                        triggerLove(null, e, index);
                    }

                    window.triggerLove = (btn, event, index) => {
                        const x = event ? (event.clientX || (event.touches && event.touches[0].clientX)) : window.innerWidth / 2;
                        const y = event ? (event.clientY || (event.touches && event.touches[0].clientY)) : window.innerHeight / 2;
                        spawnHeart(x, y);
                        fetch('/api/reels/heart', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reelIndex: index - 1 }) });
                    };

                    function initReels() {
                        container.scrollTop = window.innerHeight;
                        document.querySelectorAll('.reel-slide').forEach(s => observer.observe(s));
                        preLoadVideo(1);
                    }

                    initReels();
                    if (window.barba && barba.hooks) {
                        barba.hooks.after(() => initReels());
                        barba.hooks.before(() => {
                            Object.values(videoElements).forEach(v => v.pause());
                        });
                    }
                })();
            </script>
    </div>
    <%- include('partials/footer') %>