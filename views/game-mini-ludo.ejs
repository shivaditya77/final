<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="game-mini-ludo">
    <style>
        :root {
            --red: #ff4d6d; --blue: #00d2ff; --green: #00ff88; --yellow: #ffd700;
            --bg-dark: #0a0a0a; --border-glass: rgba(255, 255, 255, 0.1);
        }

        .game-body {
            min-height: 100vh; background: var(--bg-dark); color: white;
            font-family: 'Outfit', sans-serif; display: flex; flex-direction: column;
            align-items: center; padding-top: 80px; position: relative; overflow-x: hidden;
        }

        .game-bg { position: fixed; inset: 0; background: radial-gradient(circle at center, #1a0b1a 0%, #0a0a0a 100%); z-index: 0; }
        .game-bg::after { content: ''; position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Cfilter id='noiseFilter'%3%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3%3C/filter%3%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3%3C/svg%3"); opacity: 0.05; pointer-events: none; }

        .game-container { position: relative; z-index: 10; text-align: center; width: 100%; max-width: 500px; padding: 20px; display: flex; flex-direction: column; align-items: center; }

        .status-badge { background: rgba(255, 255, 255, 0.02); padding: 12px 30px; border-radius: 50px; border: 1px solid var(--border-glass); margin-bottom: 25px; font-size: 1.1rem; font-weight: 700; color: #fff; backdrop-filter: blur(20px); box-shadow: 0 10px 30px rgba(0,0,0,0.3); letter-spacing: 0.5px; }
        
        .board-wrapper { background: rgba(255, 255, 255, 0.02); padding: 20px; border-radius: 32px; border: 1px solid var(--border-glass); box-shadow: 0 25px 60px rgba(0,0,0,0.6); backdrop-filter: blur(15px); margin-bottom: 35px; }
        .board { display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(4, 1fr); gap: 12px; width: 320px; height: 320px; }
        .cell { background: rgba(255, 255, 255, 0.01); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.03); display: flex; align-items: center; justify-content: center; position: relative; transition: all 0.3s ease; }
        .cell.path { background: rgba(255, 255, 255, 0.03); border-color: rgba(255, 255, 255, 0.08); }
        .cell.start { background: rgba(255, 77, 109, 0.1); border-color: rgba(255, 77, 109, 0.3); box-shadow: inset 0 0 15px rgba(255, 77, 109, 0.1); }
        .cell.end { background: rgba(255, 215, 0, 0.1); border-color: rgba(255, 215, 0, 0.3); box-shadow: inset 0 0 15px rgba(255, 215, 0, 0.1); }
        .cell.end::after { content: '👑'; position: absolute; font-size: 1.4rem; opacity: 0.2; }
        .cell-index { position: absolute; top: 6px; left: 8px; font-size: 0.65rem; opacity: 0.2; font-weight: 800; }

        .token { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; position: absolute; z-index: 20; box-shadow: 0 8px 20px rgba(0,0,0,0.5); transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); cursor: pointer; border: 2.5px solid rgba(255, 255, 255, 0.8); }
        .token:hover { transform: scale(1.2) translateY(-5px); }
        .token.active { animation: bounce 1.2s infinite; border-color: #fff; }
        @keyframes bounce { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-8px) scale(1.1); } }

        .p0 { background: radial-gradient(circle at 30% 30%, #ff758c, #c9184a); filter: drop-shadow(0 0 8px var(--neon-red)); }
        .p1 { background: radial-gradient(circle at 30% 30%, #4facfe, #00d2ff); filter: drop-shadow(0 0 8px var(--neon-blue)); }

        .controls-area { display: flex; flex-direction: column; align-items: center; gap: 25px; width: 100%; }
        .dice-container { display: flex; align-items: center; gap: 25px; }
        .dice { width: 80px; height: 80px; background: white; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 3rem; color: #1a1a1a; cursor: pointer; box-shadow: 0 15px 35px rgba(0,0,0,0.4); transition: all 0.2s; user-select: none; border: 1px solid #fff; }
        .dice.rolling { animation: shake 0.3s infinite; }
        @keyframes shake { 0%, 100% { transform: rotate(0); } 25% { transform: rotate(10deg); } 75% { transform: rotate(-10deg); } }

        .btn-roll { background: linear-gradient(135deg, #6e45e2, #88d3ce); border: none; color: white; padding: 16px 45px; border-radius: 50px; font-weight: 800; font-size: 1.2rem; cursor: pointer; }
        .btn-roll:disabled { opacity: 0.4; }

        .player-indicators { display: flex; gap: 20px; margin-bottom: 25px; position: relative; }
        .player-box { display: flex; flex-direction: column; align-items: center; gap: 8px; opacity: 0.3; transition: all 0.4s; background: rgba(255,255,255,0.02); padding: 12px 20px; border-radius: 20px; }
        .player-box.active { opacity: 1; transform: scale(1.1); background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); }
        .p-dot { width: 14px; height: 14px; border-radius: 50%; box-shadow: 0 0 10px currentColor; }

        #win-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 1000; display: none; align-items: center; justify-content: center; backdrop-filter: blur(15px); }
        .modal-content { background: #1a1a1a; padding: 50px; border-radius: 40px; border: 1px solid rgba(255, 255, 255, 0.1); text-align: center; max-width: 420px; width: 90%; }

        .settings-bar { margin-top: 40px; display: flex; gap: 15px; }
        .btn-setting { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.5); padding: 10px 25px; border-radius: 50px; cursor: pointer; font-size: 0.8rem; }
    </style>

    <div class="game-body">
        <div class="game-bg"></div>
        <%- include('partials/navbar') %>

        <div class="game-container">
            <div class="status-badge" id="status-text">Mini Ludo ⚡</div>
            <div class="player-indicators" id="player-indicators"></div>
            <div class="board-wrapper"><div class="board" id="board"></div></div>
            <div class="controls-area">
                <div class="dice-container">
                    <div class="dice" id="dice" onclick="rollDice()">🎲</div>
                    <button class="roll-btn btn-roll" id="roll-btn" onclick="rollDice()">ROLL DICE</button>
                </div>
            </div>
            <div class="settings-bar">
                <button class="btn-setting" onclick="requestReset()">🔄 Restart</button>
                <button class="btn-setting" onclick="syncBoardState()">📡 Sync</button>
            </div>
        </div>
    </div>

    <div id="win-modal">
        <div class="modal-content">
            <span class="win-icon" id="win-icon" style="font-size: 5rem;">🏆</span>
            <h2 class="win-title" id="win-title" style="font-size: 2.5rem; margin: 15px 0; font-weight:900;">Victory!</h2>
            <p class="win-desc" style="margin-bottom: 25px; opacity: 0.7;">The mini crown is yours!</p>
            <button class="btn-roll" onclick="location.reload()">Play Again</button>
        </div>
    </div>

    <audio id="sound-roll" src="https://assets.mixkit.co/active_storage/sfx/2004/2004-preview.mp3"></audio>
    <audio id="sound-move" src="https://assets.mixkit.co/active_storage/sfx/2571/2571-preview.mp3"></audio>
    <audio id="sound-win" src="https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3"></audio>
    <audio id="sound-kick" src="https://assets.mixkit.co/active_storage/sfx/2658/2658-preview.mp3"></audio>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        (function() {
            const PATH_INDICES = [0, 1, 2, 3, 7, 11, 15, 14, 13, 12, 8, 4, 5, 6, 10, 9];
            const username = "<%= username %>";
            const otherUser = "<%= otherUser %>";
            const myPlayerIndex = username.toLowerCase() === 'bhondu' ? 0 : 1;
            
            let players = [], currentPlayer = 0, currentRoll = 0, gameActive = false, isRolling = false;
            let rollPromise = null, rollResolve = null, lastSeq = 0, messageQueue = [], isProcessingQueue = false;

            const boardEl = document.getElementById('board'), statusText = document.getElementById('status-text'), diceEl = document.getElementById('dice'), rollBtn = document.getElementById('roll-btn'), indicatorsEl = document.getElementById('player-indicators');
            const icons = ['❤️', '💋', '🍀', '☀️'], names = ['Bhondu', 'Vishu', 'Guest 1', 'Guest 2'];

            function initGame() {
                boardEl.innerHTML = ''; indicatorsEl.innerHTML = ''; players = []; currentPlayer = 0; gameActive = true;
                for (let i = 0; i < 16; i++) {
                    const cell = document.createElement('div'); cell.className = 'cell';
                    if (PATH_INDICES.includes(i)) cell.classList.add('path');
                    if (i === PATH_INDICES[0]) cell.classList.add('start');
                    if (i === PATH_INDICES[PATH_INDICES.length - 1]) cell.classList.add('end');
                    cell.innerHTML = `<span class="cell-index">${i}</span>`; cell.id = `cell-mini-${i}`; boardEl.appendChild(cell);
                }
                for (let i = 0; i < 2; i++) {
                    const p = { id: i, pathIndex: 0, token: document.createElement('div') };
                    p.token.className = `token p${i}`; p.token.innerHTML = icons[i];
                    p.token.id = `token-mini-${i}`; document.getElementById(`cell-mini-${PATH_INDICES[0]}`).appendChild(p.token);
                    players.push(p);
                    const box = document.createElement('div'); box.className = `player-box ${i === 0 ? 'active' : ''}`;
                    box.id = `p-box-mini-${i}`; box.innerHTML = `<div class="p-dot" style="background:${i===0?'var(--red)':'var(--blue)'}"></div><span class="p-name">${names[i]}</span>`;
                    indicatorsEl.appendChild(box);
                }
                updateStatus(); updateTokenLayout();
            }

            function updateStatus() {
                const isMyTurn = currentPlayer === myPlayerIndex;
                statusText.innerText = isMyTurn ? `Your Turn! 🎲` : `Waiting for ${names[currentPlayer]}...`;
                document.querySelectorAll('.player-box').forEach((box, i) => box.classList.toggle('active', i === currentPlayer));
                rollBtn.disabled = !isMyTurn || isRolling;
            }

            window.rollDice = async function(remoteVal = null) {
                if (!gameActive || isRolling || (!remoteVal && currentPlayer !== myPlayerIndex)) return;
                isRolling = true; rollPromise = new Promise(r => rollResolve = r);
                diceEl.classList.add('rolling'); playSound('roll');
                setTimeout(async () => {
                    const val = remoteVal || Math.floor(Math.random() * 6) + 1;
                    diceEl.innerText = ['','⚀','⚁','⚂','⚃','⚄','⚅'][val]; diceEl.classList.remove('rolling');
                    currentRoll = val;
                    if (!remoteVal) syncMove({ type:'roll', dice:val });
                    await processMove(currentPlayer, val);
                    rollResolve();
                }, 800);
            };

            async function processMove(pIdx, val) {
                const p = players[pIdx];
                if (p.pathIndex + val >= PATH_INDICES.length) {
                    if (!window.isRemoteSync) syncMove({ type:'move', dice:val, nextTurnIdx:(pIdx+1)%2 });
                    setTimeout(nextTurn, 1000); return;
                }
                for (let i=1; i<=val; i++) { p.pathIndex++; await animateToken(p, p.pathIndex); playSound('move'); }
                checkCollisions(p);
                if (p.pathIndex === PATH_INDICES.length - 1) { gameActive = false; showWinner(pIdx); return; }
                const nextIdx = (val === 6) ? pIdx : (pIdx + 1) % 2;
                if (!window.isRemoteSync) syncMove({ type:'move', dice:val, nextTurnIdx:nextIdx });
                nextTurn(nextIdx);
            }

            function animateToken(p, pathIdx) {
                return new Promise(r => {
                    const target = document.getElementById(`cell-mini-${PATH_INDICES[pathIdx]}`);
                    const old = p.token.getBoundingClientRect(); target.appendChild(p.token); updateTokenLayout();
                    const cur = p.token.getBoundingClientRect();
                    gsap.fromTo(p.token, { x:old.left-cur.left, y:old.top-cur.top }, { x:0, y:0, duration:0.3, onComplete:r });
                });
            }

            function checkCollisions(activeP) {
                players.forEach(p => { if (p.id !== activeP.id && p.pathIndex === activeP.pathIndex && p.pathIndex !== 0) {
                    p.pathIndex = 0; playSound('kick'); document.getElementById(`cell-mini-${PATH_INDICES[0]}`).appendChild(p.token); updateTokenLayout();
                }});
            }

            function nextTurn(forcedIdx = null) { currentPlayer = (forcedIdx !== null) ? forcedIdx : (currentPlayer + 1) % 2; isRolling = false; updateStatus(); }
            
            function updateTokenLayout() {
                for (let i=0; i<16; i++) {
                    const cell = document.getElementById(`cell-mini-${i}`); if(!cell) continue;
                    const tokens = cell.querySelectorAll('.token');
                    tokens.forEach((t, idx) => {
                        const off = (idx - (tokens.length-1)/2) * 12;
                        t.style.transform = `translate(${off}px, ${off}px)`;
                    });
                }
            }

            function showWinner(idx) {
                playSound('win'); document.getElementById('win-title').innerText = `${names[idx]} WINS!`;
                document.getElementById('win-icon').innerText = icons[idx];
                document.getElementById('win-modal').style.display = 'flex';
            }

            function initSync() {
                if (!window.globalPusher) return setTimeout(initSync, 500);
                const channel = window.globalPusher.subscribe('private-notifications-' + username.toLowerCase());
                channel.bind('ludo-move', (data) => { if(data.from.toLowerCase() === otherUser.toLowerCase()) { messageQueue.push({event:'move', data}); processQueue(); }});
                channel.bind('ludo-state-sync', (data) => { if(data.from.toLowerCase() === otherUser.toLowerCase() && data.seq > lastSeq) { messageQueue.push({event:'state', data}); processQueue(); }});
                channel.bind('ludo-reset', () => location.reload());
            }

            async function processQueue() {
                if (isProcessingQueue || messageQueue.length === 0) return;
                isProcessingQueue = true; const { event, data } = messageQueue.shift();
                if (event === 'move') {
                    window.isRemoteSync = true;
                    if (data.type === 'roll') await rollDice(data.dice);
                    else if (data.type === 'move') { if(rollPromise) await rollPromise; if(data.nextTurnIdx !== undefined) nextTurn(data.nextTurnIdx); }
                    window.isRemoteSync = false;
                } else if (event === 'state') {
                    lastSeq = data.seq; currentPlayer = data.currentPlayer;
                    data.players.forEach((rp, i) => { players[i].pathIndex = rp.pathIndex; document.getElementById(`cell-mini-${PATH_INDICES[rp.pathIndex]}`).appendChild(players[i].token); });
                    updateTokenLayout(); updateStatus();
                }
                isProcessingQueue = false; processQueue();
            }

            async function syncMove(data) { try { await fetch('/api/games/ludo/move', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({...data, to:otherUser}) }); } catch(e){} }
            async function syncBoardState() { if(!gameActive) return; syncMove({ type:'state-sync', seq:++lastSeq, currentPlayer, players:players.map(p=>({pathIndex:p.pathIndex})) }); }
            window.requestReset = () => { if(confirm("Restart for both?")) { syncMove({ type:'reset' }); location.reload(); } };

            setInterval(() => { if(gameActive && currentPlayer === myPlayerIndex) syncBoardState(); }, 20000);
            setTimeout(() => { if(gameActive) syncBoardState(); }, 1500);
            function playSound(type) { const s = document.getElementById(`sound-${type}`); if(s) { s.currentTime=0; s.play().catch(()=>{}); } }

            initGame(); initSync();
        })();
    </script>
</div>
<%- include('partials/footer') %>
