<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="game-mini-ludo">
    <style>
        :root {
            --red: #ff4d6d;
            --blue: #00d2ff;
            --green: #00ff88;
            --yellow: #ffd700;
            --bg-dark: #0a0a0a;
            --card-bg: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.1);
            --neon-red: rgba(255, 77, 109, 0.3);
            --neon-blue: rgba(0, 210, 255, 0.3);
        }

        .game-body {
            min-height: 100vh;
            background: var(--bg-dark);
            color: white;
            font-family: 'Outfit', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 80px;
            position: relative;
            overflow-x: hidden;
        }

        .game-bg {
            position: fixed; inset: 0;
            background: radial-gradient(circle at center, #1a0b1a 0%, #0a0a0a 100%);
            z-index: 0;
        }

        .game-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Cfilter id='noiseFilter'%3%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3%3C/filter%3%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3%3C/svg%3");
            opacity: 0.05;
            pointer-events: none;
        }

        .game-container {
            position: relative; z-index: 10;
            text-align: center;
            width: 100%;
            max-width: 500px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .status-badge {
            background: rgba(255, 255, 255, 0.02);
            padding: 12px 30px;
            border-radius: 50px;
            border: 1px solid var(--border-glass);
            margin-bottom: 25px;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            backdrop-filter: blur(20px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            letter-spacing: 0.5px;
        }
        
        /* Board Styles */
        .board-wrapper {
            background: rgba(255, 255, 255, 0.02);
            padding: 20px;
            border-radius: 32px;
            border: 1px solid var(--border-glass);
            box-shadow: 0 25px 60px rgba(0,0,0,0.6);
            backdrop-filter: blur(15px);
            margin-bottom: 35px;
        }

        .board {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-template-rows: repeat(4, 1fr);
            gap: 12px;
            width: 320px;
            height: 320px;
        }

        .cell {
            background: rgba(255, 255, 255, 0.01);
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.03);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            transition: all 0.3s ease;
        }

        .cell.path {
            background: rgba(255, 255, 255, 0.03);
            border-color: rgba(255, 255, 255, 0.08);
        }

        .cell.start { 
            background: rgba(255, 77, 109, 0.1); 
            border-color: rgba(255, 77, 109, 0.3);
            box-shadow: inset 0 0 15px rgba(255, 77, 109, 0.1);
        }

        .cell.end { 
            background: rgba(255, 215, 0, 0.1); 
            border-color: rgba(255, 215, 0, 0.3);
            box-shadow: inset 0 0 15px rgba(255, 215, 0, 0.1);
        }

        .cell.end::after {
            content: '👑';
            position: absolute;
            font-size: 1.4rem;
            opacity: 0.2;
            filter: drop-shadow(0 0 5px rgba(255,215,0,0.5));
        }
        
        .cell-index {
            position: absolute;
            top: 6px;
            left: 8px;
            font-size: 0.65rem;
            opacity: 0.2;
            font-weight: 800;
        }

        /* Token Styles */
        .token {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            position: absolute;
            z-index: 20;
            box-shadow: 0 8px 20px rgba(0,0,0,0.5);
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            border: 2.5px solid rgba(255, 255, 255, 0.8);
        }
        .token:hover { transform: scale(1.2) translateY(-5px); box-shadow: 0 12px 25px rgba(0,0,0,0.6); }
        .token.active { animation: bounce 1.2s infinite; border-color: #fff; }

        @keyframes bounce {
            0%, 100% { transform: translateY(0) scale(1); filter: brightness(1); }
            50% { transform: translateY(-8px) scale(1.1); filter: brightness(1.2); box-shadow: 0 15px 30px rgba(0,0,0,0.7); }
        }

        /* Player Colors */
        .p0 { background: radial-gradient(circle at 30% 30%, #ff758c, #c9184a); filter: drop-shadow(0 0 8px var(--neon-red)); }
        .p1 { background: radial-gradient(circle at 30% 30%, #4facfe, #00d2ff); filter: drop-shadow(0 0 8px var(--neon-blue)); }

        /* Controls */
        .controls-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            width: 100%;
        }
        
        .dice-container {
            display: flex;
            align-items: center;
            gap: 25px;
        }
        
        .dice {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: #1a1a1a;
            cursor: pointer;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4), inset 0 -5px 0 rgba(0,0,0,0.15);
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            user-select: none;
            border: 1px solid #fff;
        }
        .dice:active { transform: scale(0.9) translateY(6px); }
        .dice.rolling { animation: roll 0.5s infinite; pointer-events: none; }
        
        @keyframes roll {
            0% { transform: rotate(0deg) scale(1); filter: blur(0); }
            50% { transform: rotate(180deg) scale(1.1); filter: blur(2px); }
            100% { transform: rotate(360deg) scale(1); filter: blur(0); }
        }

        .btn-roll {
            background: linear-gradient(135deg, #6e45e2, #88d3ce);
            border: none;
            color: white;
            padding: 16px 45px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.4s;
            box-shadow: 0 12px 25px rgba(110, 69, 226, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .btn-roll:hover:not(:disabled) { transform: translateY(-4px); box-shadow: 0 18px 35px rgba(110, 69, 226, 0.4); }
        .btn-roll:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

        .player-indicators {
            display: flex;
            gap: 20px;
            margin-bottom: 25px;
        }
        .player-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            opacity: 0.3;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: rgba(255,255,255,0.02);
            padding: 12px 20px;
            border-radius: 20px;
            border: 1px solid transparent;
        }
        .player-box.active {
            opacity: 1;
            transform: scale(1.1);
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.1);
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
        .p-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            box-shadow: 0 0 10px currentColor;
        }
        .p-name { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; }

        /* Modal */
        #win-modal {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.92);
            z-index: 1000;
            display: none;
            align-items: center; justify-content: center;
            backdrop-filter: blur(15px);
        }
        .modal-content {
            background: linear-gradient(145deg, #1a0b1a 0%, #0a0a0a 100%);
            padding: 50px;
            border-radius: 40px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
            max-width: 420px;
            width: 90%;
            box-shadow: 0 40px 100px rgba(0,0,0,0.9), 0 0 50px rgba(139, 92, 246, 0.2);
        }
        .win-icon { font-size: 5rem; margin-bottom: 25px; display: block; filter: drop-shadow(0 0 20px rgba(255,215,0,0.4)); }
        .win-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 15px; background: linear-gradient(to right, #ff4d6d, #ffd700); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .win-desc { color: rgba(255,255,255,0.6); margin-bottom: 35px; line-height: 1.7; font-size: 1.1rem; }
        .btn-restart {
            background: white;
            color: black;
            border: none;
            padding: 16px 50px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.4s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .btn-restart:hover { transform: scale(1.05) translateY(-3px); box-shadow: 0 10px 30px rgba(255,255,255,0.4); }

        .settings-bar {
            margin-top: 40px;
            display: flex;
            gap: 15px;
        }
        .btn-setting {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: rgba(255, 255, 255, 0.5);
            padding: 10px 25px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-setting:hover { background: rgba(255, 255, 255, 0.08); color: white; border-color: rgba(255,255,255,0.2); }
    </style>

    <div class="game-body">
        <div class="game-bg"></div>
        <%- include('partials/navbar') %>

        <div class="game-container">
            <div class="status-badge" id="status-text">Mini Ludo ⚡</div>

            <div class="player-indicators" id="player-indicators">
                <!-- Will be populated by JS -->
            </div>

            <div class="board-wrapper">
                <div class="board" id="board">
                    <!-- 16 cells generated by JS -->
                </div>
            </div>

            <div class="controls-area">
                <div class="dice-container">
                    <div class="dice" id="dice" onclick="rollDice()">🎲</div>
                    <button class="roll-btn btn-roll" id="roll-btn" onclick="rollDice()">ROLL DICE</button>
                </div>
            </div>

            <div class="settings-bar">
                <button class="btn-setting" onclick="window.requestReset()">🔄 Restart Game</button>
                <button class="btn-setting" onclick="location.reload()">🔄 Force Refresh</button>
            </div>
        </div>
    </div>

    <!-- Winner Modal -->
    <div id="win-modal">
        <div class="modal-content">
            <span class="win-icon" id="win-icon">🏆</span>
            <h2 class="win-title" id="win-title">Player 1 Wins!</h2>
            <p class="win-desc" id="win-desc">Congratulations! You've conquered the mini board and claimed the crown.</p>
            <button class="btn-restart" onclick="closeModal(); initGame(playerCount)">Play Again</button>
        </div>
    </div>

    <!-- Audio -->
    <audio id="sound-roll" src="https://assets.mixkit.co/active_storage/sfx/2004/2004-preview.mp3"></audio>
    <audio id="sound-move" src="https://assets.mixkit.co/active_storage/sfx/2571/2571-preview.mp3"></audio>
    <audio id="sound-win" src="https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3"></audio>
    <audio id="sound-kick" src="https://assets.mixkit.co/active_storage/sfx/2658/2658-preview.mp3"></audio>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        (function() {
            const PATH_INDICES = [0, 1, 2, 3, 7, 11, 15, 14, 13, 12, 8, 4, 5, 6, 10, 9];
            const username = "<%= username %>";
            const otherUser = "<%= otherUser %>";
            const myPlayerIndex = username.toLowerCase() === 'bhondu' ? 0 : 1;
            
            let playerCount = 2;
            let players = [];
            let currentPlayer = 0;
            let gameActive = false;
            let isRolling = false;

            const boardEl = document.getElementById('board');
            const statusText = document.getElementById('status-text');
            const diceEl = document.getElementById('dice');
            const rollBtn = document.getElementById('roll-btn');
            const indicatorsEl = document.getElementById('player-indicators');
            const winModal = document.getElementById('win-modal');

            const icons = ['❤️', '💋', '🍀', '☀️'];
            const names = ['Bhondu', 'Vishu', 'Guest 1', 'Guest 2'];

            function initGame(count) {
                playerCount = count;
                boardEl.innerHTML = '';
                indicatorsEl.innerHTML = '';
                players = [];
                currentPlayer = 0;
                gameActive = true;
                isRolling = false;
                
                for (let i = 0; i < 16; i++) {
                    const cell = document.createElement('div');
                    cell.className = 'cell';
                    if (PATH_INDICES.includes(i)) cell.classList.add('path');
                    if (i === PATH_INDICES[0]) cell.classList.add('start');
                    if (i === PATH_INDICES[PATH_INDICES.length - 1]) cell.classList.add('end');
                    cell.innerHTML = `<span class="cell-index">${i}</span>`;
                    cell.id = `cell-mini-${i}`;
                    boardEl.appendChild(cell);
                }

                for (let i = 0; i < count; i++) {
                    const player = { id: i, pathIndex: 0, token: document.createElement('div') };
                    player.token.className = `token p${i}`;
                    player.token.innerHTML = icons[i];
                    player.token.id = `token-mini-${i}`;
                    const startCell = document.getElementById(`cell-mini-${PATH_INDICES[0]}`);
                    startCell.appendChild(player.token);
                    players.push(player);

                    const box = document.createElement('div');
                    box.className = `player-box ${i === 0 ? 'active' : ''}`;
                    box.id = `p-box-mini-${i}`;
                    box.innerHTML = `
                        <div class="p-dot p${i}" style="color: ${i===0?'var(--red)':'var(--blue)'}"></div>
                        <span class="p-name">${names[i]}</span>
                    `;
                    indicatorsEl.appendChild(box);
                }
                updateStatus();
                updateTokenLayout();
                closeModal();
            }

            function updateStatus() {
                const isMyTurn = currentPlayer === myPlayerIndex;
                statusText.innerText = isMyTurn ? `Your Turn! Roll the Dice! 🎲` : `Waiting for ${names[currentPlayer]}... ⌛`;
                statusText.style.color = players[currentPlayer].id === 0 ? 'var(--red)' : 'var(--blue)';
                document.querySelectorAll('.player-box').forEach((box, i) => box.classList.toggle('active', i === currentPlayer));
                rollBtn.disabled = !isMyTurn;
                diceEl.style.cursor = isMyTurn ? 'pointer' : 'default';
            }

            window.rollDice = async function() {
                if (!gameActive || isRolling || currentPlayer !== myPlayerIndex) return;
                isRolling = true;
                diceEl.classList.add('rolling');
                playSound('roll');
                let rollInterval = setInterval(() => { diceEl.innerText = Math.floor(Math.random() * 6) + 1; }, 80);
                setTimeout(async () => {
                    clearInterval(rollInterval);
                    const diceValue = Math.floor(Math.random() * 6) + 1;
                    diceEl.innerText = getDiceEmoji(diceValue);
                    diceEl.classList.remove('rolling');
                    syncMove(currentPlayer, diceValue);
                    processMove(currentPlayer, diceValue);
                }, 800);
            };

            function getDiceEmoji(val) {
                const map = {1: '⚀', 2: '⚁', 3: '⚂', 4: '⚃', 5: '⚄', 6: '⚅'};
                return map[val] || '🎲';
            }

            async function processMove(playerIdx, diceValue) {
                const player = players[playerIdx];
                const startIdx = player.pathIndex;
                const nextPathIndex = startIdx + diceValue;
                if (nextPathIndex >= PATH_INDICES.length) {
                    statusText.innerText = `${names[playerIdx]} needs exactly ${PATH_INDICES.length - 1 - startIdx} to win!`;
                    setTimeout(nextTurn, 1500);
                    return;
                }
                for (let i = 1; i <= diceValue; i++) {
                    player.pathIndex++;
                    await animateToken(player, player.pathIndex);
                    playSound('move');
                }
                checkCollisions(player);
                if (player.pathIndex === PATH_INDICES.length - 1) { gameActive = false; showWinner(playerIdx); return; }
                if (diceValue === 6) {
                    statusText.innerText = `A SIX! ${names[playerIdx]} rolls again! 🔥`;
                    isRolling = false;
                    updateStatus();
                } else { nextTurn(); }
            }

            function animateToken(player, pathIdx) {
                return new Promise(resolve => {
                    const targetCell = document.getElementById(`cell-mini-${PATH_INDICES[pathIdx]}`);
                    const oldRect = player.token.getBoundingClientRect();
                    targetCell.appendChild(player.token);
                    updateTokenLayout();
                    const newRect = player.token.getBoundingClientRect();
                    gsap.fromTo(player.token, { x: oldRect.left - newRect.left, y: oldRect.top - newRect.top }, { x: 0, y: 0, duration: 0.3, ease: "power2.out", onComplete: resolve });
                });
            }

            function checkCollisions(activePlayer) {
                if (activePlayer.pathIndex === 0) return;
                players.forEach(p => {
                    if (p.id !== activePlayer.id && p.pathIndex === activePlayer.pathIndex) {
                        p.pathIndex = 0;
                        const startCell = document.getElementById(`cell-mini-${PATH_INDICES[0]}`);
                        playSound('kick');
                        gsap.to(p.token, { scale: 0, duration: 0.3, onComplete: () => { startCell.appendChild(p.token); updateTokenLayout(); gsap.to(p.token, { scale: 1, duration: 0.3 }); } });
                        statusText.innerText = `BOOM! ${names[activePlayer.id]} kicked ${names[p.id]} back! 👊`;
                    }
                });
            }

            function nextTurn() { currentPlayer = (currentPlayer + 1) % playerCount; isRolling = false; updateStatus(); }

            function updateTokenLayout() {
                for (let i = 0; i < 16; i++) {
                    const cell = document.getElementById(`cell-mini-${i}`);
                    if (!cell) continue;
                    const tokens = cell.querySelectorAll('.token');
                    if (tokens.length > 1) {
                        tokens.forEach((t, idx) => {
                            const offset = (idx - (tokens.length-1)/2) * 12;
                            t.style.transform = `translate(${offset}px, ${offset}px)`;
                        });
                    } else if (tokens.length === 1) { tokens[0].style.transform = 'translate(0, 0)'; }
                }
            }

            function showWinner(idx) {
                playSound('win');
                document.getElementById('win-title').innerText = `${names[idx]} WINS!`;
                document.getElementById('win-icon').innerText = icons[idx];
                winModal.style.display = 'flex';
                gsap.from('.modal-content', { scale: 0.5, opacity: 0, duration: 0.5, ease: "back.out(1.7)" });
            }

            window.closeModal = function() { winModal.style.display = 'none'; };

            function playSound(type) {
                const sound = document.getElementById(`sound-${type}`);
                if (sound) { sound.currentTime = 0; sound.play().catch(() => {}); }
            }

            async function syncMove(playerIndex, dice) {
                try { await fetch('/api/games/ludo/move', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ playerIndex, dice, to: otherUser }) }); } catch (e) {}
            }

            function initSync() {
                if (!window.globalPusher) return setTimeout(initSync, 500);
                const channel = window.globalPusher.subscribe('private-notifications-' + username.toLowerCase());
                channel.bind('ludo-move', async (data) => {
                    if (data.from.toLowerCase() === otherUser.toLowerCase()) {
                        diceEl.classList.add('rolling');
                        playSound('roll');
                        setTimeout(() => {
                            diceEl.classList.remove('rolling');
                            diceEl.innerText = getDiceEmoji(data.dice);
                            processMove(data.playerIndex, data.dice);
                        }, 800);
                    }
                });
                channel.bind('ludo-reset', () => location.reload());
            }

            window.requestReset = async () => {
                if (!confirm("Restart the game for both players?")) return;
                try {
                    await fetch('/api/games/ludo/reset', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ to: otherUser }) });
                    location.reload();
                } catch (e) { location.reload(); }
            };

            initGame(2);
            initSync();
        })();
    </script>
</div>
<%- include('partials/footer') %>
