<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="game-snake">
    <style>
        .game-body {
            min-height: 100vh;
            background: #0a0a0a;
            color: white;
            font-family: 'Poppins', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 80px;
            padding-bottom: 40px;
            position: relative;
            overflow-x: hidden;
        }
        .game-bg {
            position: fixed; inset: 0;
            background: radial-gradient(circle at center, #1a1a2e 0%, #0a0a0a 100%);
            z-index: 0;
        }
        .game-container {
            position: relative; z-index: 10;
            text-align: center;
            width: 100%;
            max-width: 500px;
            padding: 15px;
        }
        .status-badge {
            background: rgba(139, 92, 246, 0.15);
            padding: 8px 20px;
            border-radius: 50px;
            border: 1px solid rgba(139, 92, 246, 0.3);
            margin-bottom: 20px;
            font-size: 0.9rem;
            color: #a78bfa;
            display: inline-block;
        }
        
        /* BOARD ARCHITECTURE */
        .board-wrapper {
            position: relative;
            width: 100%;
            aspect-ratio: 1 / 1;
            background: rgba(255, 255, 255, 0.05);
            padding: 10px;
            border-radius: 20px;
            border: 2px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        .board {
            display: grid;
            grid-template-columns: repeat(10, 1fr);
            grid-template-rows: repeat(10, 1fr);
            width: 100%;
            height: 100%;
            gap: 4px;
        }
        .cell {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.6rem;
            color: rgba(255, 255, 255, 0.2);
            font-weight: 600;
            transition: all 0.3s;
        }
        .cell.highlight { background: rgba(139, 92, 246, 0.1); }
        
        /* PAWNS */
        .pawn {
            position: absolute;
            width: 8%;
            height: 8%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            z-index: 100;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            filter: drop-shadow(0 0 5px rgba(255,255,255,0.3));
        }
        #pawn-me { transform: translate(-50%, -50%); }
        #pawn-opp { transform: translate(-50%, -50%); }

        /* DICE */
        .controls {
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }
        .dice-container {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #3b82f6, #1d4ed8);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: 800;
            color: white;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
            transition: all 0.2s;
            border: 3px solid rgba(255,255,255,0.2);
        }
        .dice-container:active { transform: scale(0.9); }
        .dice-container.rolling { animation: shakeDice 0.3s infinite; }
        @keyframes shakeDice {
            0%, 100% { transform: rotate(0); }
            25% { transform: rotate(10deg) scale(1.1); }
            75% { transform: rotate(-10deg) scale(1.1); }
        }
        .dice-container.disabled { opacity: 0.5; cursor: not-allowed; filter: grayscale(1); }

        .btn-action {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.6);
            padding: 10px 25px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-action:hover { background: rgba(255, 255, 255, 0.1); color: white; }

        /* SPECIAL TILES (SNAKES/LADDERS) */
        .tile-special { font-size: 0.8rem; position: absolute; bottom: 2px; right: 2px; opacity: 0.8; }
        .ladder { color: #10b981; }
        .snake { color: #ef4444; }

        @media (min-width: 800px) {
            .game-container { max-width: 600px; }
            .board-wrapper { width: 500px; margin: 0 auto; }
            .cell { font-size: 0.8rem; }
        }
    </style>

    <div class="game-body">
        <div class="game-bg"></div>
        <%- include('partials/navbar') %>

        <div class="game-container">
            <div class="status-badge" id="status-text">Your Turn! Roll the dice! 🎲</div>

            <div class="board-wrapper">
                <div class="board" id="board">
                    <!-- 100 Cells generated via JS -->
                </div>
                <div id="pawn-me" class="pawn">❤️</div>
                <div id="pawn-opp" class="pawn">💋</div>
                <canvas id="special-lines" style="position:absolute; inset:0; pointer-events:none; z-index:50;"></canvas>
            </div>

            <div class="controls">
                <div class="dice-container" id="dice-btn" onclick="window.rollDice()">?</div>
                <p id="turn-label" style="font-size: 0.8rem; opacity: 0.6;">Tap the dice to play</p>
                
                <div style="display: flex; gap: 10px;">
                    <button class="btn-action" onclick="window.syncGameState()">🔄 Sync Game</button>
                    <button class="btn-action" onclick="window.emergencyReset()">🛑 Emergency Reset</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const username = "<%= username %>";
            const otherUser = "<%= otherUser %>";
            const channelName = 'private-notifications-' + username.toLowerCase();
            
            let myPos = 1;
            let oppPos = 1;
            let isMyTurn = username.toLowerCase() === 'bhondu'; 
            let gameActive = true;
            let isRolling = false;

            // BOARD CONFIG
            const boardEl = document.getElementById('board');
            const statusText = document.getElementById('status-text');
            const diceBtn = document.getElementById('dice-btn');
            const turnLabel = document.getElementById('turn-label');
            const pawnMe = document.getElementById('pawn-me');
            const pawnOpp = document.getElementById('pawn-opp');
            const canvas = document.getElementById('special-lines');
            const ctx = canvas.getContext('2d');

            const snakes = { 
                17: 7, 54: 34, 62: 19, 64: 60, 87: 24, 93: 73, 95: 75, 99: 78 
            };
            const ladders = { 
                4: 14, 9: 31, 20: 38, 21: 42, 28: 84, 51: 67, 71: 91, 80: 100 
            };

            function initBoard() {
                boardEl.innerHTML = '';
                // Generate 100 cells in snake pattern (Boustrophedon)
                for (let r = 9; r >= 0; r--) {
                    if (r % 2 === 1) { // Left to Right
                        for (let c = 0; c < 10; c++) createCell(r, c);
                    } else { // Right to Left
                        for (let c = 9; c >= 0; c--) createCell(r, c);
                    }
                }
                updatePawnPositions();
                setTimeout(drawSpecials, 500);
            }

            function createCell(r, c) {
                const val = r * 10 + c + 1;
                const cell = document.createElement('div');
                cell.className = 'cell';
                cell.id = `cell-${val}`;
                cell.innerText = val;
                
                if (snakes[val]) cell.innerHTML += `<span class="tile-special snake">🐍</span>`;
                if (ladders[val]) cell.innerHTML += `<span class="tile-special ladder">🪜</span>`;
                
                boardEl.appendChild(cell);
            }

            function getCellPos(val) {
                const cell = document.getElementById(`cell-${val}`);
                if (!cell) return { x: 0, y: 0 };
                const rect = cell.getBoundingClientRect();
                const boardRect = boardEl.getBoundingClientRect();
                return {
                    x: rect.left - boardRect.left + rect.width / 2,
                    y: rect.top - boardRect.top + rect.height / 2
                };
            }

            function updatePawnPositions() {
                const me = getCellPos(myPos);
                const opp = getCellPos(oppPos);
                
                gsap.to(pawnMe, { left: me.x, top: me.y, duration: 0.5, ease: "power2.out" });
                gsap.to(pawnOpp, { left: opp.x, top: opp.y, duration: 0.5, ease: "power2.out", delay: 0.1 });
            }

            function drawSpecials() {
                const rect = boardEl.getBoundingClientRect();
                canvas.width = rect.width;
                canvas.height = rect.height;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.setLineDash([5, 5]);
                
                // Draw Ladders
                ctx.strokeStyle = "rgba(16, 185, 129, 0.4)";
                ctx.lineWidth = 4;
                for (let start in ladders) {
                    const s = getCellPos(start);
                    const e = getCellPos(ladders[start]);
                    ctx.beginPath();
                    ctx.moveTo(s.x, s.y);
                    ctx.lineTo(e.x, e.y);
                    ctx.stroke();
                }

                // Draw Snakes
                ctx.strokeStyle = "rgba(239, 68, 68, 0.4)";
                for (let start in snakes) {
                    const s = getCellPos(start);
                    const e = getCellPos(snakes[start]);
                    ctx.beginPath();
                    ctx.moveTo(s.x, s.y);
                    ctx.lineTo(e.x, e.y);
                    ctx.stroke();
                }
            }

            window.rollDice = async function() {
                if (!gameActive || !isMyTurn || isRolling) return;
                
                isRolling = true;
                diceBtn.classList.add('rolling');
                diceBtn.innerText = "?";
                
                // Fake roll delay
                setTimeout(async () => {
                    const roll = Math.floor(Math.random() * 6) + 1;
                    diceBtn.classList.remove('rolling');
                    diceBtn.innerText = roll;
                    
                    try {
                        await fetch('/api/games/snake/roll', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ dice: roll, to: otherUser })
                        });
                    } catch (e) {}
                    
                    movePlayer('me', roll);
                }, 800);
            };

            async function movePlayer(who, roll) {
                let current = who === 'me' ? myPos : oppPos;
                let target = current + roll;
                
                if (target > 100) {
                    // Stay put if overshoot
                    finishTurn();
                    return;
                }

                // Animate step by step
                for (let i = current + 1; i <= target; i++) {
                    if (who === 'me') myPos = i; else oppPos = i;
                    updatePawnPositions();
                    await new Promise(r => setTimeout(r, 200));
                }

                // Check for snake/ladder
                let finalPos = who === 'me' ? myPos : oppPos;
                if (ladders[finalPos]) {
                    showToast("🪜 Up we go! ❤️");
                    if (who === 'me') myPos = ladders[finalPos]; else oppPos = ladders[finalPos];
                    updatePawnPositions();
                } else if (snakes[finalPos]) {
                    showToast("🐍 Oops! Sliding down... 💔");
                    if (who === 'me') myPos = snakes[finalPos]; else oppPos = snakes[finalPos];
                    updatePawnPositions();
                }

                if ((who === 'me' ? myPos : oppPos) === 100) {
                    gameActive = false;
                    statusText.innerText = who === 'me' ? "🎉 YOU WON! ❤️" : `💔 ${otherUser} WON!`;
                    statusText.style.background = who === 'me' ? "rgba(0, 255, 204, 0.2)" : "rgba(255, 77, 109, 0.2)";
                    return;
                }

                finishTurn();
            }

            function finishTurn() {
                isRolling = false;
                isMyTurn = !isMyTurn;
                updateTurnUI();
            }

            function updateTurnUI() {
                diceBtn.classList.toggle('disabled', !isMyTurn);
                statusText.innerText = isMyTurn ? "Your Turn! Roll the dice! 🎲" : `Waiting for ${otherUser}... ⌛`;
                turnLabel.innerText = isMyTurn ? "Tap to roll!" : "Waiting...";
            }

            // SYNC LOGIC
            function initGameSync() {
                if (!window.globalPusher) return setTimeout(initGameSync, 500);
                const channel = window.globalPusher.subscribe(channelName);
                
                channel.bind('snake-roll', (data) => {
                    if (data.from.toLowerCase() !== otherUser.toLowerCase()) return;
                    diceBtn.innerText = data.dice;
                    movePlayer('opp', data.dice);
                });

                channel.bind('snake-reset', (data) => {
                    location.reload();
                });

                channel.bind('snake-sync', (data) => {
                    if (data.from.toLowerCase() !== otherUser.toLowerCase()) return;
                    myPos = data.oppPos;
                    oppPos = data.myPos;
                    isMyTurn = !data.turn;
                    updatePawnPositions();
                    updateTurnUI();
                });
            }

            window.syncGameState = async function() {
                try {
                    await fetch('/api/games/snake/sync', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ to: otherUser, myPos, oppPos, turn: isMyTurn })
                    });
                    showToast("Sync signal sent! 📡");
                } catch (e) {}
            };

            window.emergencyReset = async function() {
                if (!confirm("Reset game for BOTH players?")) return;
                try {
                    await fetch('/api/games/snake/reset', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ to: otherUser })
                    });
                    location.reload();
                } catch (e) { location.reload(); }
            };

            window.addEventListener('resize', drawSpecials);
            
            initBoard();
            initGameSync();
            updateTurnUI();
        })();
    </script>
</div>
<%- include('partials/footer') %>
