<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="home">
    <link rel="stylesheet" href="/css/Home.css">
    <link rel="stylesheet" href="/css/BirthdayCountdown.css">
    <script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
    <div class="home-body">
        <div class="animated-bg"></div>
        <div class="vignette"></div>
        <div class="particles" id="particles-container"></div>

        <%- include('partials/navbar', { showMusic: true }) %>

        <div class="home-container">
            <div class="intro-badge">
                <span class="badge-text">A Love Story</span>
                <span class="badge-heart">❤️</span>
            </div>

            <!-- BIRTHDAY FEATURE CONTAINER -->
            <div id="birthday-feature-wrapper"></div>

            <div class="heading-wrapper">
                <h1 class="home-h1" id="typing-heading"></h1>
                <span class="cursor" id="typing-cursor">|</span>
            </div>

            <div class="subtitle" id="subtitle">
                <p>Choose your journey, my love... 💕</p>
            </div>

            <!-- THREE CARDS -->
            <div class="cards-grid">
                <!-- Card 1: Birthday -->
                <a href="/memories" class="section-card card-birthday">
                    <span class="card-tag">✨ New</span>
                    <span class="card-icon">🎂</span>
                    <div class="card-label">Soul Journey</div>
                    <h2 class="card-title">Soul Journey</h2>
                    <div class="journey-steps">
                        <span class="step-dot">Memories</span>
                        <span class="step-arrow">→</span>
                        <span class="step-dot">Promises</span>
                        <span class="step-arrow">→</span>
                        <span class="step-dot">Our Story</span>
                        <span class="step-arrow">→</span>
                        <span class="step-dot">Final ❤️</span>
                    </div>
                    <p class="card-desc">Relive every chapter of our story — from the first moment to forever.</p>
                    <button class="card-btn">
                        Begin <span class="card-btn-arrow">→</span>
                    </button>
                </a>

                <!-- Card 2: Journal -->
                <a href="/journal" class="section-card card-journal">
                    <span class="card-tag">📓 Diary</span>
                    <span class="card-icon card-icon-journal">📓</span>
                    <div class="card-label">Our Journal</div>
                    <h2 class="card-title">Memory Journal</h2>
                    <p class="card-desc">Add photos, videos & memories. Our private diary — keep our moments forever. 💜</p>
                    <button class="card-btn">
                        Open <span class="card-btn-arrow">→</span>
                    </button>
                </a>

                <!-- Card 3: Chat -->
                <a href="/chat" class="section-card card-chat">
                    <span class="card-tag">💌 Private</span>
                    <span class="card-icon card-icon-chat">💬</span>
                    <div class="card-label">Private Space</div>
                    <h2 class="card-title">Love Chat</h2>
                    <p class="card-desc">Our private corner to talk, share hearts, and whisper sweet things in real-time. 💛</p>
                    <button class="card-btn">
                        Chat <span class="card-btn-arrow">→</span>
                    </button>
                </a>

                <!-- Card 4: Reels -->
                <a href="/reels" class="section-card card-reels">
                    <span class="card-tag">🔥 Trending</span>
                    <span class="card-icon">📽️</span>
                    <div class="card-label">Bhondu Feed</div>
                    <h2 class="card-title">Bhondu Feed</h2>
                    <p class="card-desc">A curated feed of reels that remind me of us. Swipe up to feel the connection. ❤️</p>
                    <button class="card-btn">
                        Watch <span class="card-btn-arrow">→</span>
                    </button>
                </a>

                <!-- Card 5: BhonduTube -->
                <a href="/watch-together" class="section-card card-watch">
                    <span class="card-tag">🎬 Cinema</span>
                    <span class="card-icon">📺</span>
                    <div class="card-label">Watch Together</div>
                    <h2 class="card-title">BhonduTube</h2>
                    <p class="card-desc">Watch your favorite YouTube videos together in real-time. Control the player for both! 🍿</p>
                    <button class="card-btn">
                        Enter <span class="card-btn-arrow">→</span>
                    </button>
                </a>


                <!-- Card 6: Bhondu Games -->
                <a href="/games" class="section-card card-games">
                    <span class="card-tag">🎮 Fun</span>
                    <span class="card-icon">🎮</span>
                    <div class="card-label">Interactive</div>
                    <h2 class="card-title">Bhondu Games</h2>
                    <p class="card-desc">Play Tic-Tac-Toe, Heart Seeker & more together. Let's see who wins! 🏆</p>
                    <button class="card-btn">
                        Play <span class="card-btn-arrow">→</span>
                    </button>
                </a>
            </div>
        </div>
    </div>

    <script>
        // ========== TYPING ANIMATION ==========
        (function() {
            const username = "<%= username %>";
            const text = `Hey ${username} ❤️, I made something for you...`;
            let i = 0;
            const heading = document.getElementById('typing-heading');
            const cursor = document.getElementById('typing-cursor');
            const subtitle = document.getElementById('subtitle');

            window.startHomeAnimations = function() {
                // Show the container
                const homeContainer = document.querySelector('.home-container');
                if (homeContainer) homeContainer.style.opacity = '1';
                
                typeWriter();
            };

            function typeWriter() {
                if (i < text.length) {
                    if (heading) heading.innerText = text.substring(0, i + 1);
                    i++;
                    setTimeout(typeWriter, 70);
                } else {
                    if (cursor) cursor.style.display = 'none';
                    if (subtitle) subtitle.classList.add('show');
                    initParticles();
                }
            }
            // Will be triggered after birthday check if not birthday
            // setTimeout(typeWriter, 500); 

            // ========== PARTICLES ==========
            function initParticles() {
                const container = document.getElementById('particles-container');
                if (!container) return;
                container.innerHTML = '';
                for (let j = 0; j < 50; j++) {
                    const p = document.createElement('div');
                    p.className = 'particle';
                    const size = Math.random() * 4 + 2;
                    p.style.width = `${size}px`;
                    p.style.height = `${size}px`;
                    p.style.left = `${Math.random() * 100}%`;
                    p.style.animationDuration = `${Math.random() * 8 + 4}s`;
                    p.style.animationDelay = `${Math.random() * 5}s`;
                    p.style.opacity = Math.random() * 0.5 + 0.2;
                    container.appendChild(p);
                }
            }

            // ========== CLICK HEART EFFECT ==========
            document.body.addEventListener('click', (e) => {
                if (e.target.tagName === 'BUTTON' || e.target.tagName === 'INPUT' || e.target.tagName === 'A') return;
                const heart = document.createElement('div');
                heart.innerHTML = ['❤️', '💖', '💕', '💜'][Math.floor(Math.random() * 4)];
                heart.style.cssText = `position:fixed;left:${e.clientX}px;top:${e.clientY}px;font-size:20px;pointer-events:none;z-index:99999;animation:floatUpEffect 1s ease-out forwards;`;
                document.body.appendChild(heart);
                setTimeout(() => heart.remove(), 1000);
            });

            // ========== MUSIC TOGGLE ==========
            const musicToggle = document.getElementById('music-toggle');
            const musicIcon = document.getElementById('music-icon');
            const musicStatus = document.getElementById('music-status');

            if (musicToggle) {
                musicToggle.addEventListener('click', () => {
                    const isPlaying = window.toggleMusic();
                    if (musicIcon) musicIcon.innerText = isPlaying ? '🎶' : '🎵';
                    if (musicStatus) musicStatus.innerText = isPlaying ? 'On' : 'Off';
                });
            }

            // Sync music UI with global state
            function syncMusicUI() {
                const audio = document.getElementById('global-audio');
                if (!audio) return;
                const isPlaying = !audio.paused;
                if (musicIcon) musicIcon.innerText = isPlaying ? '🎶' : '🎵';
                if (musicStatus) musicStatus.innerText = isPlaying ? 'On' : 'Off';
            }
            setTimeout(syncMusicUI, 100);

            function updateHomeStatus(isOnline) {
                // Feature removed
            }

            // ========== DYNAMIC BIRTHDAY LOGIC ==========
            function getNextBirthday() {
                const now = new Date();
                let year = now.getFullYear();
                let birthday = new Date(`${year}-06-09T00:00:00`);
                
                // If today is after June 9th, the next birthday is next year
                if (now > new Date(`${year}-06-09T23:59:59`)) {
                    birthday.setFullYear(year + 1);
                }
                return birthday;
            }

            const wrapper = document.getElementById('birthday-feature-wrapper');

            function checkBirthdayStatus() {
                const now = new Date();
                const birthday = getNextBirthday();
                const isBirthday = now.getMonth() === 5 && now.getDate() === 9; // June is index 5
                
                if (isBirthday) {
                    // Hide main container during celebration
                    const homeContainer = document.querySelector('.home-container');
                    if (homeContainer) homeContainer.style.opacity = '0';
                    showBirthdayCelebration();
                } else {
                    showCountdown(birthday);
                    if (window.startHomeAnimations) window.startHomeAnimations();
                }
            }

            function showCountdown(targetDate) {
                wrapper.innerHTML = `
                    <div class="birthday-countdown-container">
                        <div class="countdown-birthday-vibe">
                            <h2 class="birthday-title-vibe">Bhondu's Birthday</h2>
                            
                            <div class="vibe-icon vibe-icon-cake">🎂</div>
                            <div class="vibe-icon vibe-icon-balloon">🎈</div>
                            <div class="vibe-icon vibe-icon-popper">🎉</div>
                            <div class="vibe-icon vibe-icon-gift">🎁</div>

                            <div class="countdown-label-vibe">Countdown to the craze</div>
                            <div class="countdown-timer-vibe" id="timer-display">
                                <div class="time-segment-vibe">
                                    <span class="time-value-vibe" id="days">00</span>
                                    <span class="time-label-vibe">Days</span>
                                </div>
                                <div class="time-segment-vibe">
                                    <span class="time-value-vibe" id="hours">00</span>
                                    <span class="time-label-vibe">Hours</span>
                                </div>
                                <div class="time-segment-vibe">
                                    <span class="time-value-vibe" id="minutes">00</span>
                                    <span class="time-label-vibe">Mins</span>
                                </div>
                                <div class="time-segment-vibe">
                                    <span class="time-value-vibe" id="seconds">00</span>
                                    <span class="time-label-vibe">Secs</span>
                                </div>
                            </div>
                        </div>
                    </div>
                `;

                function updateTimer() {
                    const now = new Date().getTime();
                    const distance = targetDate.getTime() - now;

                    if (distance < 0) {
                        checkBirthdayStatus();
                        return;
                    }

                    const d = Math.floor(distance / (1000 * 60 * 60 * 24));
                    const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const s = Math.floor((distance % (1000 * 60)) / 1000);

                    document.getElementById('days').innerText = d.toString().padStart(2, '0');
                    document.getElementById('hours').innerText = h.toString().padStart(2, '0');
                    document.getElementById('minutes').innerText = m.toString().padStart(2, '0');
                    document.getElementById('seconds').innerText = s.toString().padStart(2, '0');
                }

                updateTimer();
                setInterval(updateTimer, 1000);
            }

            function showBirthdayCelebration() {
                const celebrationHtml = `
                    <div class="birthday-celebration-overlay" id="birthday-overlay">
                        <div class="celebration-bg"></div>
                        <div class="confetti-container" id="confetti-container"></div>
                        <div class="birthday-text-container">
                            <h1 class="birthday-h1">Happy Birthday Bhondu! 🎂</h1>
                            <h2 class="birthday-h2">You are my whole world ❤️</h2>
                        </div>
                        <audio id="birthday-audio" loop>
                            <source src="https://www.chosic.com/wp-content/uploads/2021/04/Happy-Birthday-To-You.mp3" type="audio/mpeg">
                        </audio>
                    </div>
                `;
                document.body.insertAdjacentHTML('beforeend', celebrationHtml);
                
                const overlay = document.getElementById('birthday-overlay');
                const confettiContainer = document.getElementById('confetti-container');
                const bdayAudio = document.getElementById('birthday-audio');

                // Handle Music: Pause global, play birthday
                const globalAudio = document.getElementById('global-audio');
                let wasGlobalPlaying = false;
                if (globalAudio && !globalAudio.paused) {
                    wasGlobalPlaying = true;
                    globalAudio.pause();
                }

                if (bdayAudio) {
                    bdayAudio.volume = 0.6;
                    bdayAudio.play().catch(e => console.log("Autoplay blocked, waiting for interaction..."));
                }

                // Create Confetti
                for (let j = 0; j < 100; j++) {
                    setTimeout(() => {
                        const confetti = document.createElement('div');
                        confetti.className = 'confetti';
                        confetti.style.left = Math.random() * 100 + 'vw';
                        confetti.style.backgroundColor = ['#ff4d6d', '#ffccd5', '#ff1e4d', '#ffffff'][Math.floor(Math.random() * 4)];
                        confetti.style.width = Math.random() * 10 + 5 + 'px';
                        confetti.style.height = Math.random() * 10 + 5 + 'px';
                        confetti.style.animationDuration = Math.random() * 3 + 2 + 's';
                        confettiContainer.appendChild(confetti);
                        setTimeout(() => confetti.remove(), 5000);
                    }, j * 100);
                }

                // Create Balloons
                for (let j = 0; j < 12; j++) {
                    setTimeout(() => {
                        const balloon = document.createElement('div');
                        balloon.className = 'balloon';
                        balloon.innerHTML = ['🎈', '✨', '💖'][Math.floor(Math.random() * 3)];
                        balloon.style.fontSize = Math.random() * 20 + 30 + 'px';
                        balloon.style.left = Math.random() * 100 + 'vw';
                        balloon.style.animationDuration = Math.random() * 5 + 7 + 's';
                        balloon.style.opacity = Math.random() * 0.5 + 0.5;
                        document.body.appendChild(balloon);
                        setTimeout(() => balloon.remove(), 12000);
                    }, j * 800);
                }

                // Create Floating Hearts
                for (let j = 0; j < 20; j++) {
                    setTimeout(() => {
                        const heart = document.createElement('div');
                        heart.className = 'celebration-heart';
                        heart.innerHTML = '❤️';
                        heart.style.left = Math.random() * 100 + 'vw';
                        heart.style.fontSize = Math.random() * 15 + 10 + 'px';
                        heart.style.animationDuration = Math.random() * 3 + 4 + 's';
                        document.body.appendChild(heart);
                        setTimeout(() => heart.remove(), 7000);
                    }, j * 500);
                }

                // Remove overlay after 15 seconds
                setTimeout(() => {
                    overlay.classList.add('fade-out');
                    if (bdayAudio) {
                        gsap.to(bdayAudio, { volume: 0, duration: 2, onComplete: () => bdayAudio.pause() });
                    }
                    setTimeout(() => {
                        overlay.remove();
                        // Resume global music if it was playing
                        if (wasGlobalPlaying && globalAudio) {
                            globalAudio.play().catch(() => {});
                            if (window.syncMusicUI) window.syncMusicUI();
                        }
                        // START THE HOME APP
                        if (window.startHomeAnimations) window.startHomeAnimations();
                    }, 1000);
                }, 15000);
            }

            checkBirthdayStatus();
        })();
    </script>

    <style>
    @keyframes floatUpEffect {
        0% { opacity: 1; transform: translateY(0) scale(1); }
        100% { opacity: 0; transform: translateY(-80px) scale(0.5); }
    }
    </style>
</div>
<%- include('partials/footer') %>
