<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="chat">
    <link rel="stylesheet" href="/css/Chat.css">
    <link rel="stylesheet" href="/css/VideoCall.css">
    <div class="chat-body" id="chat-page-root">
        <canvas id="heartParticles"></canvas>

        <!-- HEADER -->
        <div class="chat-header">
            <div class="chat-header-left">
                <h1>Private Space ❤️</h1>
                <div class="chat-status-container">
                    <div class="chat-status-dot" id="status-dot"></div>
                    <span class="chat-status-text" id="status-text">Connecting...</span>
                </div>
                <span class="typing-indicator" id="typing-indicator"></span>
            </div>
            <div class="chat-header-right">
                <button class="chat-nav-btn" onclick="toggleMediaView()">📁 <span>Media</span></button>
                <button class="chat-nav-btn" onclick="toggleSearchView()">🔍 <span>Search</span></button>
                <button class="chat-nav-btn" onclick="toggleWallpaperPicker()">🎨 <span>Wallpaper</span></button>
                <button class="chat-nav-btn" onclick="toggleStarredView()">⭐ <span>Starred</span></button>
                <a href="/" class="chat-nav-btn" style="text-decoration: none;">🏠 <span>Home</span></a>
                <a href="/logout" class="chat-nav-btn chat-logout-btn" style="text-decoration: none;" onclick="confirmLogout(event)" data-barba-prevent="true">💋 <span>Logout</span></a>
            </div>
        </div>

        <!-- UPLOAD PROGRESS -->
        <div class="upload-progress-bar-container" id="upload-progress-container" style="display:none">
            <div class="upload-progress-bar-fill" id="upload-progress-fill"></div>
            <span class="upload-progress-label" id="upload-progress-label">Uploading...</span>
        </div>

        <!-- MESSAGES -->
        <div class="chat-messages" id="messages-container">
            <% if (history.length === 0) { %>
                <div class="chat-empty" id="chat-empty">
                    <div class="chat-empty-icon">💌</div>
                    <p>No messages yet... say something sweet! ❤️</p>
                </div>
            <% } %>

            <% history.forEach(msg => { %>
                <div class="chat-message <%= msg.sender === username ? 'sent' : 'received' %>" id="msg-<%= msg._id %>">
                    <div class="msg-options" onclick="toggleDropdown('<%= msg._id %>')">⋮</div>
                    <div class="msg-dropdown" id="dropdown-<%= msg._id %>">
                        <button onclick="showReplyPreview('<%= msg._id %>', '<%= msg.sender %>', '<%= (msg.text || "Media").replace(/'/g, "\\'") %>')">⤴️ Reply</button>
                        <% if (msg.sender === username && msg.fileType === 'text') { %>
                            <button onclick="startEditing('<%= msg._id %>', '<%= msg.text.replace(/'/g, "\\'") %>')">✏️ Edit</button>
                        <% } %>
                        <button onclick="toggleStar('<%= msg._id %>')" id="star-btn-<%= msg._id %>"><%= (msg.isStarredBy || []).includes(username) ? '⭐ Unstar' : '⭐ Star' %></button>
                        
                        <div class="divider"></div>

                        <button class="delete-btn" onclick="deleteForMe('<%= msg._id %>')">🗑 Delete for me</button>
                        <% if (msg.sender === username) { %>
                            <button class="delete-btn" onclick="deleteForEveryone('<%= msg._id %>')">🚫 Delete for everyone</button>
                        <% } %>
                    </div>

                    <div class="reaction-picker-btn" onclick="showReactionPicker('<%= msg._id %>')">❤️+</div>
                    <div class="reaction-picker" id="picker-<%= msg._id %>">
                        <span onclick="react('<%= msg._id %>', '❤️')">❤️</span>
                        <span onclick="react('<%= msg._id %>', '😂')">😂</span>
                        <span onclick="react('<%= msg._id %>', '😮')">😮</span>
                        <span onclick="react('<%= msg._id %>', '😢')">😢</span>
                        <span onclick="react('<%= msg._id %>', '👍')">👍</span>
                    </div>

                    <div class="sender-name"><%= msg.sender %></div>

                    <% if (msg.replyTo) { %>
                        <div class="reply-quote">
                            <div class="reply-quote-sender"><%= msg.replyTo.sender %></div>
                            <div class="reply-quote-text"><%= msg.replyTo.text || (msg.replyTo.fileUrl ? "Media" : "...") %></div>
                        </div>
                    <% } %>

                    <% if (msg.fileUrl) { %>
                        <% if (msg.fileType === 'image') { %>
                            <img src="<%= msg.fileUrl %>" class="chat-media-img" onclick="openLightbox('<%= msg.fileUrl %>', 'image')">
                        <% } else if (msg.fileType === 'video') { %>
                            <video src="<%= msg.fileUrl %>" class="chat-media-video" onclick="openLightbox('<%= msg.fileUrl %>', 'video')"></video>
                        <% } else if (msg.fileType === 'audio') { %>
                            <audio src="<%= msg.fileUrl %>" class="chat-media-audio" controls></audio>
                        <% } %>
                    <% } %>

                    <% if (msg.text) { %>
                        <div class="text"><%= msg.text %></div>
                    <% } %>

                    <% if (msg.linkPreview && msg.linkPreview.url) { %>
                        <a href="<%= msg.linkPreview.url %>" target="_blank" class="link-preview">
                            <% if (msg.linkPreview.image) { %>
                                <img src="<%= msg.linkPreview.image %>" class="lp-image">
                            <% } %>
                            <div class="lp-content">
                                <div class="lp-title"><%= msg.linkPreview.title %></div>
                                <% if (msg.linkPreview.description) { %>
                                    <div class="lp-desc"><%= msg.linkPreview.description %></div>
                                <% } %>
                                <div class="lp-url"><%= new URL(msg.linkPreview.url).hostname %></div>
                            </div>
                        </a>
                    <% } %>

                    <div class="reactions-display" id="reactions-<%= msg._id %>">
                        <% 
                            const emojiGroups = {};
                            (msg.reactions || []).forEach(r => {
                                emojiGroups[r.emoji] = (emojiGroups[r.emoji] || 0) + 1;
                            });
                            Object.keys(emojiGroups).forEach(emoji => { 
                        %>
                            <span class="reaction-bubble"><%= emoji %> <small><%= emojiGroups[emoji] %></small></span>
                        <% }) %>
                    </div>

                    <div class="msg-time">
                        <%= new Date(msg.timestamp || msg.createdAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true }) %>
                        <% if (msg.sender === username) { %>
                            <span class="tick <%= msg.status === 'read' ? 'read' : '' %>">✔✔</span>
                        <% } %>
                        <span class="msg-star-icon <%= (msg.isStarredBy || []).includes(username) ? 'active' : '' %>" id="star-icon-<%= msg._id %>">⭐</span>
                        <span class="edited-label" id="edited-<%= msg._id %>" style="<%= msg.isEdited ? '' : 'display:none' %>">(edited)</span>
                    </div>
<% if (msg.sender !== username && msg.status === 'sent') { %>
    <script>fetch('/api/chat/mark-read', {method:'POST'})</script>
<% } %>
                </div>
            <% }) %>
            <div id="messages-end"></div>
        </div>

        <!-- REPLY PREVIEW -->
        <div class="reply-preview-container" id="reply-preview" style="display:none">
            <div class="reply-preview-content">
                <span class="reply-preview-sender" id="reply-preview-sender"></span>
                <p class="reply-preview-text" id="reply-preview-text"></p>
            </div>
            <button type="button" class="reply-preview-close" onclick="cancelReply()">✕</button>
        </div>

        <!-- EDIT PREVIEW -->
        <div class="reply-preview-container" id="edit-preview" style="display:none; border-left-color: #ffc107;">
            <div class="reply-preview-content">
                <span class="reply-preview-sender" style="color: #ffc107;">Editing Message</span>
                <p class="reply-preview-text" id="edit-preview-text"></p>
            </div>
            <button type="button" class="reply-preview-close" onclick="cancelEdit()">✕</button>
        </div>

        <!-- INPUT AREA -->
        <form class="chat-input-area" id="chat-form">
            <div class="media-btns">
                <button type="button" class="chat-media-btn" title="Attach file" id="attach-btn">📎</button>
                <button type="button" class="chat-media-btn" title="Voice message" id="voice-btn">🎤</button>
            </div>

            <input type="file" id="chat-file-input" hidden accept="image/*,video/*,audio/*">

            <input class="chat-input-field" id="chat-input" autocomplete="off" placeholder="Say something sweet...">

            <button type="submit" class="chat-send-btn" id="send-btn">❤️</button>
        </form>

        <div class="chat-toast" id="chat-toast"></div>

        <!-- MEDIA GALLERY VIEW -->
        <div class="starred-view" id="media-view">
            <div class="starred-header">
                <h2>📁 Media Gallery</h2>
                <button onclick="toggleMediaView()">✕</button>
            </div>
            <div class="starred-list">
                <div class="media-gallery-grid" id="media-gallery-list">
                    <!-- Media items injected here -->
                </div>
            </div>
        </div>

        <!-- SEARCH VIEW -->
        <div class="starred-view" id="search-view">
            <div class="starred-header">
                <h2>🔍 Search Messages</h2>
                <button onclick="toggleSearchView()">✕</button>
            </div>
            <div class="search-input-container">
                <input type="text" id="search-input" placeholder="Search for memories..." oninput="handleSearch(this.value)">
            </div>
            <div class="starred-list" id="search-results">
                <p style="text-align:center; opacity:0.5; padding:20px;">Type something to search... ❤️</p>
            </div>
        </div>

        <!-- STARRED MESSAGES VIEW -->
        <div class="starred-view" id="starred-view">
            <div class="starred-header">
                <h2>⭐ Starred Messages</h2>
                <button onclick="toggleStarredView()">✕</button>
            </div>
            <div class="starred-list" id="starred-list">
                <!-- Starred messages injected here -->
            </div>
        </div>


        <!-- WALLPAPER PICKER -->
        <div class="starred-view" id="wallpaper-picker">
            <div class="starred-header">
                <h2>🎨 Chat Wallpaper</h2>
                <button onclick="toggleWallpaperPicker()">✕</button>
            </div>
            <div class="starred-list">
                <div class="wallpaper-grid">
                    <div class="wallpaper-item" style="background: var(--bg-dark);" onclick="setWallpaper('')">
                        <span>Default</span>
                    </div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1518199266791-5375a83190b7?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1518199266791-5375a83190b7?auto=format&fit=crop&q=80')"></div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1516589174184-c68526673fd0?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1516589174184-c68526673fd0?auto=format&fit=crop&q=80')"></div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1494774157365-9e04c6720e47?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1494774157365-9e04c6720e47?auto=format&fit=crop&q=80')"></div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1581022295087-35e593704911?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1581022295087-35e593704911?auto=format&fit=crop&q=80')"></div>
                </div>
                <hr style="opacity:0.1; margin: 20px 0;">
                <button class="chat-nav-btn" style="width:100%" onclick="document.getElementById('wallpaper-upload').click()">📤 Upload Custom Photo</button>
                <input type="file" id="wallpaper-upload" style="display:none" accept="image/*" onchange="handleWallpaperUpload(this)">
            </div>
        </div>

        <!-- LIGHTBOX -->
        <div class="lightbox" id="lightbox" onclick="closeLightbox()">
            <span class="lightbox-close">&times;</span>
            <div class="lightbox-content" onclick="event.stopPropagation()">
                <img id="lightbox-img" src="" style="display:none">
                <video id="lightbox-video" src="" controls style="display:none"></video>
            </div>
        </div>
    </div>

    <script>
        (function() {
            if (typeof Pusher === 'undefined') return;

            // ========== PUSHER INITIALIZATION ==========
            const pusher = window.globalPusher;
            if (!pusher) {
                console.error('Pusher not initialized globally');
                const statusText = document.getElementById('status-text');
                if (statusText) statusText.innerText = 'Initialization Error 💔';
                return;
            }

            const username = "<%= username %>";
            const otherUser = username.toLowerCase() === 'bhondu' ? 'vishu' : 'bhondu';
            const channel = window.globalChannel;
            const container = document.getElementById('messages-container');
            const chatForm = document.getElementById('chat-form');
            const chatInput = document.getElementById('chat-input');
            const statusDot = document.getElementById('status-dot');
            const statusText = document.getElementById('status-text');
            
            // ========== NATIVE APP UTILITIES ==========
            const haptic = (type) => {
                if (!navigator.vibrate) return;
                switch(type) {
                    case 'click': navigator.vibrate(10); break;
                    case 'success': navigator.vibrate([15, 30, 15]); break;
                    case 'error': navigator.vibrate([50, 100, 50]); break;
                    case 'longpress': navigator.vibrate(25); break;
                }
            };

            // Keyboard/Viewport Adjustment for Native Feel
            if (window.visualViewport) {
                window.visualViewport.addEventListener('resize', () => {
                    const viewHeight = window.visualViewport.height;
                    document.querySelector('.chat-body').style.height = `${viewHeight}px`;
                    scrollToBottom(false);
                });
            }

            function scrollToBottom(smooth = true) {
                if (!container || !msgEnd) return;
                const behavior = smooth ? 'smooth' : 'auto';
                
                // Aggressive scroll to bottom
                container.scrollTo({ top: container.scrollHeight, behavior });
                
                // Fail-safe for mobile browsers/keyboard jumps
                setTimeout(() => {
                    container.scrollTop = container.scrollHeight;
                }, 100);
            }

            // Initial scroll sequence for absolute reliability
            scrollToBottom(false);
            setTimeout(() => scrollToBottom(false), 100);
            setTimeout(() => scrollToBottom(false), 500);
            setTimeout(() => scrollToBottom(false), 1500); 

            // If images load later, they might push the scroll up. Fix that:
            container.querySelectorAll('img, video').forEach(el => {
                el.addEventListener('load', () => scrollToBottom(false));
                el.addEventListener('loadedmetadata', () => scrollToBottom(false));
            });

            // Status indication
            function updateConnectionUI(state) {
                if (!statusText || !statusDot) return;
                console.log("Pusher Connection State:", state);
                
                if (state === 'connected') {
                    statusText.innerText = 'Connected';
                    statusText.style.color = '#4caf50';
                    statusDot.style.background = '#4caf50';
                    // Re-check online status
                    if (channel && channel.subscribed) {
                        updateStatusUI(channel.members.count > 1);
                    }
                } else if (state === 'connecting') {
                    statusText.innerText = 'Connecting...';
                    statusText.style.color = '#ffeb3b';
                    statusDot.style.background = '#ffeb3b';
                } else {
                    statusText.innerText = 'Offline';
                    statusText.style.color = '#f44336';
                    statusDot.style.background = '#f44336';
                }
            }

            // Set initial state and start heartbeat
            if (pusher) {
                updateConnectionUI(pusher.connection.state);
                
                // If stuck in connecting, check again in 2 seconds
                setTimeout(() => {
                    if (pusher.connection.state === 'connecting') {
                        console.log("Stuck in connecting, forcing UI update...");
                        updateConnectionUI(pusher.connection.state);
                    }
                }, 2000);

                pusher.connection.unbind('state_change');
                pusher.connection.bind('state_change', (states) => {
                    updateConnectionUI(states.current);
                });
            }

            pusher.connection.bind('connected', () => {
                // Initial check will happen in subscription_succeeded
            });

            channel.bind('pusher:subscription_succeeded', (members) => {
                const isOtherOnline = members.count > 1;
                updateStatusUI(isOtherOnline);
            });

            channel.bind('pusher:member_added', (member) => {
                if (member.id !== username.toLowerCase()) {
                    updateStatusUI(true);
                }
            });

            channel.bind('pusher:member_removed', (member) => {
                if (member.id !== username.toLowerCase()) {
                    updateStatusUI(false);
                }
            });

            async function updateStatusUI(isOnline) {
                if (statusDot) statusDot.style.background = isOnline ? '#4caf50' : '#f44336';
                if (statusText) {
                    if (isOnline) {
                        statusText.innerText = 'Online';
                        statusText.style.color = '#4caf50';
                    } else {
                        // Fetch last seen
                        try {
                            const res = await fetch(`/api/user/status/${otherUser}`);
                            const data = await res.json();
                            if (data.lastSeen) {
                                statusText.innerText = `Last seen ${formatLastSeen(data.lastSeen)}`;
                            } else {
                                statusText.innerText = 'Offline';
                            }
                            statusText.style.color = '#f44336';
                        } catch (e) {
                            statusText.innerText = 'Offline';
                        }
                    }
                }
            }

            function formatLastSeen(dateStr) {
                const date = new Date(dateStr);
                const now = new Date();
                const diffMs = now - date;
                const diffMins = Math.floor(diffMs / 60000);
                
                if (diffMins < 1) return 'just now';
                if (diffMins < 60) return `${diffMins}m ago`;
                
                const diffHours = Math.floor(diffMins / 60);
                if (diffHours < 24) return `${diffHours}h ago`;
                
                return date.toLocaleDateString();
            }

            pusher.connection.bind('disconnected', () => {
                if (statusDot) statusDot.style.background = '#f44336';
                if (statusText) {
                    statusText.innerText = 'Disconnected';
                    statusText.style.color = '#f44336';
                }
            });

            // Listen for new messages
            channel.bind('new-message', (msg) => {
                const empty = document.getElementById('chat-empty');
                if (empty) empty.remove();

                // If this is our own message and we already added it optimistically, just update the ID
                if (msg.tempId && document.getElementById('msg-' + msg.tempId)) {
                    const el = document.getElementById('msg-' + msg.tempId);
                    el.id = 'msg-' + msg._id;
                    el.classList.remove('optimistic');
                    
                    // Update dropdown buttons with real ID
                    const dropdown = document.getElementById('dropdown-' + msg.tempId);
                    if (dropdown) {
                        dropdown.id = 'dropdown-' + msg._id;
                        dropdown.innerHTML = `
                            <button onclick="showReplyPreview('${msg._id}', '${msg.sender}', '${(msg.text || "Media").replace(/'/g, "\\'")}')">⤴️ Reply</button>
                            ${msg.sender === username && msg.fileType === 'text' ? `<button onclick="startEditing('${msg._id}', '${msg.text.replace(/'/g, "\\'")}')">✏️ Edit</button>` : ''}
                            <button onclick="toggleStar('${msg._id}')" id="star-btn-${msg._id}">⭐ Star</button>
                            
                            <div class="divider"></div>

                            <button class="delete-btn" onclick="deleteForMe('${msg._id}')">🗑 Delete for me</button>
                            ${msg.sender === username ? `<button class="delete-btn" onclick="deleteForEveryone('${msg._id}')">🚫 Delete for everyone</button>` : ''}
                        `;
                    }
                    const options = el.querySelector('.msg-options');
                    if (options) options.setAttribute('onclick', `toggleDropdown('${msg._id}')`);
                    
                    return;
                }

                appendMessage(msg);
                if (msg.sender !== username) {
                    createHeartBurst();
                    if (navigator.vibrate) navigator.vibrate(50); // Subtle buzz for new message
                    // Mark as read immediately to trigger secret timers if any
                    fetch('/api/chat/mark-read', { method: 'POST' });
                }
                scrollToBottom(true);
            });

            // Listen for deletions
            channel.bind('message-deleted', (msgId) => {
                const el = document.getElementById('msg-' + msgId);
                if (el) el.remove();
            });

            // Listen for edits
            channel.bind('message-edited', (data) => {
                const msgEl = document.getElementById('msg-' + data.msgId);
                if (msgEl) {
                    const textEl = msgEl.querySelector('.text');
                    if (textEl) textEl.innerText = data.newText;
                    
                    const editedEl = document.getElementById('edited-' + data.msgId);
                    if (editedEl) editedEl.style.display = 'inline';

                    // Update link preview if needed
                    const existingLP = msgEl.querySelector('.link-preview');
                    if (existingLP) existingLP.remove();
                    
                    if (data.linkPreview) {
                        const lpHTML = `
                            <a href="${data.linkPreview.url}" target="_blank" class="link-preview">
                                ${data.linkPreview.image ? `<img src="${data.linkPreview.image}" class="lp-image">` : ''}
                                <div class="lp-content">
                                    <div class="lp-title">${data.linkPreview.title}</div>
                                    ${data.linkPreview.description ? `<div class="lp-desc">${data.linkPreview.description}</div>` : ''}
                                    <div class="lp-url">${new URL(data.linkPreview.url).hostname}</div>
                                </div>
                            </a>
                        `;
                        const textContainer = msgEl.querySelector('.text') || msgEl.querySelector('.sender-name');
                        textContainer.insertAdjacentHTML('afterend', lpHTML);
                    }
                }
            });

            // Listen for read receipts
            channel.bind('messages-read', (data) => {
                if (data.reader !== username) {
                    document.querySelectorAll('.chat-message.sent .tick').forEach(tick => {
                        tick.classList.add('read');
                    });
                }
            });


            // Listen for reactions
            channel.bind('message-reaction', (data) => {
                const reactionsEl = document.getElementById('reactions-' + data.msgId);
                if (reactionsEl) {
                    const emojiGroups = {};
                    data.reactions.forEach(r => {
                        emojiGroups[r.emoji] = (emojiGroups[r.emoji] || 0) + 1;
                    });
                    
                    reactionsEl.innerHTML = Object.keys(emojiGroups).map(emoji => 
                        `<span class="reaction-bubble">${emoji} <small>${emojiGroups[emoji]}</small></span>`
                    ).join('');
                }
            });

            // Listen for typing indicator
            let typingTimeout;
            channel.bind('user-typing', (data) => {
                if (data.username !== username) {
                    const indicator = document.getElementById('typing-indicator');
                    if (indicator) {
                        indicator.innerText = `${data.username} is typing...`;
                        indicator.classList.add('active');
                        
                        clearTimeout(typingTimeout);
                        typingTimeout = setTimeout(() => {
                            indicator.classList.remove('active');
                        }, 3000);
                    }
                }
            });

                if (chatForm) {
                let lastTypingTime = 0;
                let currentReplyId = null;
                let currentEditId = null;

                window.startEditing = (id, text) => {
                    cancelReply();
                    currentEditId = id;
                    chatInput.value = text;
                    document.getElementById('edit-preview-text').innerText = text;
                    document.getElementById('edit-preview').style.display = 'flex';
                    chatInput.focus();
                };

                window.cancelEdit = () => {
                    currentEditId = null;
                    chatInput.value = '';
                    document.getElementById('edit-preview').style.display = 'none';
                };


                window.showReplyPreview = (id, sender, text) => {
                    currentReplyId = id;
                    document.getElementById('reply-preview-sender').innerText = sender;
                    document.getElementById('reply-preview-text').innerText = text;
                    document.getElementById('reply-preview').style.display = 'flex';
                    chatInput.focus();
                };

                window.cancelReply = () => {
                    currentReplyId = null;
                    document.getElementById('reply-preview').style.display = 'none';
                };

                window.toggleDropdown = (id) => {
                    const dropdown = document.getElementById('dropdown-' + id);
                    if (!dropdown) return;
                    
                    const isOpen = dropdown.classList.contains('show');
                    document.querySelectorAll('.msg-dropdown').forEach(d => d.classList.remove('show'));
                    
                    if (!isOpen) {
                        // Check if message is in bottom half of screen
                        const msgEl = document.getElementById('msg-' + id);
                        const rect = msgEl.getBoundingClientRect();
                        const isBottomHalf = rect.bottom > (window.innerHeight / 1.5);
                        
                        if (isBottomHalf) {
                            dropdown.style.top = 'auto';
                            dropdown.style.bottom = '32px';
                        } else {
                            dropdown.style.top = '32px';
                            dropdown.style.bottom = 'auto';
                        }
                        
                        dropdown.classList.add('show');
                    }
                };

                window.addEventListener('click', (e) => {
                    if (!e.target.classList.contains('msg-options')) {
                        document.querySelectorAll('.msg-dropdown').forEach(d => d.classList.remove('show'));
                    }
                });

                chatInput.addEventListener('input', () => {
                    const now = Date.now();
                    if (now - lastTypingTime > 2000) { // Throttle typing events
                        lastTypingTime = now;
                        fetch('/api/chat/typing', { method: 'POST' });
                    }
                });

                chatForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const text = chatInput.value.trim();
                    if (text === '' && !currentEditId) return;

                    if (currentEditId) {
                        const msgId = currentEditId;
                        cancelEdit();
                        try {
                            await fetch('/api/chat/edit', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ msgId, newText: text })
                            });
                        } catch (e) { alert('Edit failed 💔'); }
                        return;
                    }

                    const tempId = 'temp_' + Date.now();
                    const msgData = {
                        sender: username,
                        text,
                        tempId,
                        timestamp: new Date().toISOString()
                    };

                    appendMessage(msgData, true);
                    createHeartBurst();
                    haptic('click'); // Sending haptic

                    // Optimistic UI: Reset input immediately
                    chatInput.value = '';
                    chatInput.style.height = 'auto'; // Reset height
                    scrollToBottom(true);

                    try {
                        const res = await fetch('/api/chat/send', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ 
                                text, 
                                tempId,
                                replyTo: currentReplyId
                            })
                        });
                        cancelReply();
                        if (!res.ok) throw new Error('Send failed');
                    } catch (err) {
                        console.error("Send error:", err);
                        const el = document.getElementById('msg-' + tempId);
                        if (el) el.style.opacity = '0.5';
                        alert('Failed to send message 💔');
                    }
                });
            }

            function appendMessage(msg, isOptimistic = false) {
                if (!container || !msgEnd) return;
                const div = document.createElement('div');
                div.className = `chat-message ${msg.sender === username ? 'sent' : 'received'} ${isOptimistic ? 'optimistic' : ''}`;
                div.id = 'msg-' + (msg._id || msg.tempId);
                if (msg.isSecret) div.classList.add('secret-msg');
                
                const time = new Date(msg.timestamp || Date.now()).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true });
                
                let mediaHtml = '';
                if (msg.fileUrl) {
                    if (msg.fileType === 'image') mediaHtml = `<img src="${msg.fileUrl}" class="chat-media-img" onclick="openLightbox('${msg.fileUrl}', 'image')">`;
                    else if (msg.fileType === 'video') mediaHtml = `<video src="${msg.fileUrl}" class="chat-media-video" onclick="openLightbox('${msg.fileUrl}', 'video')"></video>`;
                    else if (msg.fileType === 'audio') mediaHtml = `<audio src="${msg.fileUrl}" class="chat-media-audio" controls></audio>`;
                }

                div.innerHTML = `
                    <div class="msg-options" onclick="haptic('click'); toggleDropdown('${msg._id || msg.tempId}')">⋮</div>
                    <div class="msg-dropdown" id="dropdown-${msg._id || msg.tempId}">
                        <button onclick="showReplyPreview('${msg._id}', '${msg.sender}', '${(msg.text || "Media").replace(/'/g, "\\'")}')">⤴️ Reply</button>
                        ${msg.sender === username && msg.fileType === 'text' ? `<button onclick="startEditing('${msg._id}', '${msg.text.replace(/'/g, "\\'")}')">✏️ Edit</button>` : ''}
                        <button onclick="toggleStar('${msg._id}')" id="star-btn-${msg._id}">⭐ Star</button>
                        
                        <div class="divider"></div>

                        <button class="delete-btn" onclick="deleteForMe('${msg._id}')">🗑 Delete for me</button>
                        ${msg.sender === username ? `<button class="delete-btn" onclick="deleteForEveryone('${msg._id}')">🚫 Delete for everyone</button>` : ''}
                    </div>
                    <div class="reaction-picker-btn" onclick="haptic('click'); showReactionPicker('${msg._id || msg.tempId}')">❤️+</div>
                    <div class="reaction-picker" id="picker-${msg._id || msg.tempId}">
                        <span onclick="react('${msg._id || msg.tempId}', '❤️')">❤️</span>
                        <span onclick="react('${msg._id || msg.tempId}', '😂')">😂</span>
                        <span onclick="react('${msg._id || msg.tempId}', '😮')">😮</span>
                        <span onclick="react('${msg._id || msg.tempId}', '😢')">😢</span>
                        <span onclick="react('${msg._id || msg.tempId}', '👍')">👍</span>
                    </div>
                    <div class="sender-name">${msg.sender}</div>
                    ${msg.replyTo ? `
                        <div class="reply-quote">
                            <div class="reply-quote-sender">${msg.replyTo.sender}</div>
                            <div class="reply-quote-text">${msg.replyTo.text || (msg.replyTo.fileUrl ? "Media" : "...")}</div>
                        </div>
                    ` : ''}
                    ${mediaHtml}
                    ${msg.text ? `<div class="text">${msg.text}</div>` : ''}
                    ${msg.linkPreview ? `
                        <a href="${msg.linkPreview.url}" target="_blank" class="link-preview">
                            ${msg.linkPreview.image ? `<img src="${msg.linkPreview.image}" class="lp-image">` : ''}
                            <div class="lp-content">
                                <div class="lp-title">${msg.linkPreview.title}</div>
                                ${msg.linkPreview.description ? `<div class="lp-desc">${msg.linkPreview.description}</div>` : ''}
                                <div class="lp-url">${new URL(msg.linkPreview.url).hostname}</div>
                            </div>
                        </a>
                    ` : ''}
                    <div class="reactions-display" id="reactions-${msg._id || msg.tempId}"></div>
                    <div class="msg-time">
                        ${time}
                        ${msg.sender === username ? `<span class="tick ${msg.status === 'read' ? 'read' : ''}">✔✔</span>` : ''}
                        <span class="msg-star-icon" id="star-icon-${msg._id || msg.tempId}">⭐</span>
                        <span class="edited-label" id="edited-${msg._id || msg.tempId}" style="${msg.isEdited ? '' : 'display:none'}">(edited)</span>
                    </div>
                `;
                container.insertBefore(div, msgEnd);
            }

            window.toggleDropdown = (id) => {
                const el = document.getElementById('dropdown-' + id);
                if (!el) return;
                const isOpen = el.classList.contains('show');
                document.querySelectorAll('.msg-dropdown').forEach(d => d.classList.remove('show'));
                if (!isOpen) el.classList.add('show');
            };

            window.deleteForMe = async (id) => {
                if (!confirm('Delete this message for you? ❤️')) return;
                try {
                    await fetch('/api/chat/delete-for-me', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ msgId: id })
                    });
                    const el = document.getElementById('msg-' + id);
                    if (el) {
                        el.style.transform = 'scale(0.8)';
                        el.style.opacity = '0';
                        setTimeout(() => el.remove(), 300);
                    }
                } catch (err) {
                    alert('Delete failed');
                }
            };

            window.deleteForEveryone = async (id) => {
                if (confirm('Delete this message for everyone? 🚫')) {
                    try {
                        await fetch('/api/chat/delete-for-everyone', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ msgId: id })
                        });
                        const el = document.getElementById('msg-' + id);
                        if (el) {
                            el.style.transform = 'scale(0.8)';
                            el.style.opacity = '0';
                            setTimeout(() => el.remove(), 300);
