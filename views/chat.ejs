                    } catch (err) {
                        alert('Delete failed');
                    }
                }
            };

            const fileInput = document.getElementById('chat-file-input');
            const attachBtn = document.getElementById('attach-btn');
            if (attachBtn && fileInput) attachBtn.addEventListener('click', () => fileInput.click());

            // ========== VOICE NOTES ==========
            const voiceBtn = document.getElementById('voice-btn');
            let mediaRecorder;
            let audioChunks = [];

            if (voiceBtn) {
                const startRecording = async () => {
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                        mediaRecorder = new MediaRecorder(stream);
                        audioChunks = [];

                        mediaRecorder.ondataavailable = (e) => {
                            if (e.data.size > 0) audioChunks.push(e.data);
                        };

                        mediaRecorder.onstop = async () => {
                            const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                            if (audioBlob.size < 1000) return; // Too short

                            const formData = new FormData();
                            formData.append('file', audioBlob, 'voice_note.webm');
                            
                            const progressFill = document.getElementById('upload-progress-fill');
                            const progressLabel = document.getElementById('upload-progress-label');
                            
                            const xhr = new XMLHttpRequest();
                            xhr.open('POST', '/api/chat/upload', true);
                            
                            xhr.upload.onprogress = (e) => {
                                if (e.lengthComputable) {
                                    const percent = Math.round((e.loaded / e.total) * 100);
                                    if (progressFill) progressFill.style.width = percent + '%';
                                    if (progressLabel) progressLabel.innerText = `Uploading... ${percent}%`;
                                }
                            };

                            xhr.onload = async () => {
                                if (xhr.status === 200) {
                                    const data = JSON.parse(xhr.responseText);
                                    await fetch('/api/chat/send', {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ 
                                            fileUrl: data.fileUrl, 
                                            fileType: 'audio' 
                                        })
                                    });
                                } else {
                                    alert('Voice note upload failed');
                                }
                                if (progress) progress.style.display = 'none';
                            };

                            xhr.send(formData);
                        } catch (err) {
                            console.error(err);
                            if (progress) progress.style.display = 'none';
                        }
                            
                            // Stop all tracks to release microphone
                            stream.getTracks().forEach(track => track.stop());
                        };

                        mediaRecorder.start();
                        voiceBtn.classList.add('recording');
                        haptic('click');
                    } catch (err) {
                        console.error("Mic access error:", err);
                        alert("Microphone access denied! 💔");
                    }
                };

                const stopRecording = () => {
                    if (mediaRecorder && mediaRecorder.state !== 'inactive') {
                        mediaRecorder.stop();
                        voiceBtn.classList.remove('recording');
                        haptic('success');
                    }
                };

                // Desktop
                voiceBtn.addEventListener('mousedown', (e) => { 
                    e.preventDefault(); 
                    if (navigator.vibrate) navigator.vibrate(20);
                    startRecording(); 
                });
                window.addEventListener('mouseup', stopRecording);
                
                // Mobile
                voiceBtn.addEventListener('touchstart', (e) => { 
                    e.preventDefault(); 
                    if (navigator.vibrate) navigator.vibrate(20);
                    startRecording(); 
                }, {passive: false});
                window.addEventListener('touchend', stopRecording);
            }

            if (fileInput) {
                fileInput.addEventListener('change', async (e) => {
                    const file = e.target.files[0];
                    if (!file) return;

                    const progressFill = document.getElementById('upload-progress-fill');
                    const progressLabel = document.getElementById('upload-progress-label');
                    const progress = document.getElementById('upload-progress-container');
                    
                    if (progress) progress.style.display = 'block';

                    const formData = new FormData();
                    formData.append('file', file);

                    const xhr = new XMLHttpRequest();
                    xhr.open('POST', '/api/chat/upload', true);
                    
                    xhr.upload.onprogress = (e) => {
                        if (e.lengthComputable) {
                            const percent = Math.round((e.loaded / e.total) * 100);
                            if (progressFill) progressFill.style.width = percent + '%';
                            if (progressLabel) progressLabel.innerText = `Uploading... ${percent}%`;
                        }
                    };

                    xhr.onload = async () => {
                        if (xhr.status === 200) {
                            const data = JSON.parse(xhr.responseText);
                            await fetch('/api/chat/send', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ 
                                    fileUrl: data.fileUrl, 
                                    fileType: data.fileType 
                                })
                            });
                            fileInput.value = '';
                        } else {
                            alert('Upload failed');
                        }
                        if (progress) progress.style.display = 'none';
                    };

                    xhr.onerror = () => {
                        alert('Upload failed due to connection error');
                        if (progress) progress.style.display = 'none';
                    };

                    xhr.send(formData);
                });
            }

            // ========== HEART PARTICLES ==========
            const canvas = document.getElementById('heartParticles');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                let particles = [];
                function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
                window.addEventListener('resize', resize); resize();

                function animate() {
                    if (!document.getElementById('heartParticles')) return;
                    ctx.clearRect(0,0,canvas.width,canvas.height);
                    particles = particles.filter(p => p.opacity > 0);
                    particles.forEach(p => {
                        p.y += p.speedY; p.x += p.speedX; p.opacity -= 0.012;
                        ctx.globalAlpha = p.opacity; ctx.font = `${p.size}px Arial`;
                        ctx.fillText('❤️', p.x, p.y);
                    });
                    requestAnimationFrame(animate);
                }
                animate();

                window.createHeartBurst = () => {
                    for(let i=0; i<12; i++) {
                        particles.push({
                            x: Math.random() * canvas.width,
                            y: canvas.height + 10,
                            size: Math.random() * 18 + 8,
                            speedY: Math.random() * -4 - 2,
                            speedX: Math.random() * 2.4 - 1.2,
                            opacity: 1
                        });
                    }
                }
            }

            window.showReactionPicker = (id) => {
                const picker = document.getElementById('picker-' + id);
                if (!picker) return;
                const isOpen = picker.classList.contains('show');
                document.querySelectorAll('.reaction-picker').forEach(p => p.classList.remove('show'));
                if (!isOpen) picker.classList.add('show');
            };

            // Wallpaper Logic
