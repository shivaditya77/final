            window.handleSearch = (query) => {
                clearTimeout(searchTimeout);
                const resultsEl = document.getElementById('search-results');
                
                if (!query.trim()) {
                    resultsEl.innerHTML = '<p style="text-align:center; opacity:0.5; padding:20px;">Type something to search... ❤️</p>';
