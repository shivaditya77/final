                lightbox.classList.remove('show');
            };

            // ========== SWIPE TO REPLY GESTURE ==========
            let touchStartX = 0;
            let activeSwipeEl = null;

            document.addEventListener('touchstart', (e) => {
                const msg = e.target.closest('.chat-message');
                if (msg) {
                    touchStartX = e.touches[0].clientX;
                    activeSwipeEl = msg;
                }
            }, {passive: true});

            document.addEventListener('touchmove', (e) => {
                if (!activeSwipeEl) return;
                const touchX = e.touches[0].clientX;
                const diff = touchX - touchStartX;
                if (diff > 0 && diff < 80) { // Swipe right
                    activeSwipeEl.style.transform = `translateX(${diff}px)`;
                    if (diff > 50) activeSwipeEl.style.opacity = '0.7';
                }
            }, {passive: true});

            document.addEventListener('touchend', (e) => {
                if (!activeSwipeEl) return;
                const touchX = e.changedTouches[0].clientX;
                const diff = touchX - touchStartX;
                
                if (diff > 60) {
                    haptic('click');
                    const msgId = activeSwipeEl.id.replace('msg-', '');
                    const sender = activeSwipeEl.querySelector('.sender-name').innerText;
                    const text = activeSwipeEl.querySelector('.text')?.innerText || "Media";
                    showReplyPreview(msgId, sender, text);
                }
                
                activeSwipeEl.style.transform = '';
                activeSwipeEl.style.opacity = '';
                activeSwipeEl = null;
            });

            // Auto-expanding Input
            if (chatInput) {
                chatInput.addEventListener('input', function() {
                    this.style.height = 'auto';
                    this.style.height = (this.scrollHeight) + 'px';
                    if (this.scrollHeight > 150) {
                        this.style.overflowY = 'auto';
                        this.style.height = '150px';
                    } else {
                        this.style.overflowY = 'hidden';
                    }
                });
            }

            // Handle URL actions (Video/Voice Call)
            const handleUrlAction = () => {
                const urlParams = new URLSearchParams(window.location.search);
                const action = urlParams.get('action');
                if (action === 'video' || action === 'voice') {
                    // Remove the query param so refreshing doesn't restart call
                    window.history.replaceState({}, document.title, window.location.pathname);
                    
                    // Small delay to ensure Pusher is ready
                    setTimeout(() => {
                        if (window.startVideoCall) {
                            window.startVideoCall(action === 'voice');
                        }
                    }, 1500);
                }
            };
            handleUrlAction();

            // ========== LONG PRESS FOR NATIVE MENU ==========
            let pressTimer;
            document.addEventListener('mousedown', (e) => {
                const msg = e.target.closest('.chat-message');
                if (msg) {
                    pressTimer = window.setTimeout(() => {
                        haptic('longpress');
                        const msgId = msg.id.replace('msg-', '');
                        toggleMsgOptions(msgId);
                    }, 600);
                }
            });
            document.addEventListener('mouseup', () => clearTimeout(pressTimer));
            document.addEventListener('touchstart', (e) => {
                const msg = e.target.closest('.chat-message');
                if (msg) {
                    pressTimer = window.setTimeout(() => {
                        haptic('longpress');
                        const msgId = msg.id.replace('msg-', '');
                        toggleMsgOptions(msgId);
                    }, 600);
                }
            }, {passive: true});
            document.addEventListener('touchend', () => clearTimeout(pressTimer));

            // Barba cleanup
            barba.hooks.before(() => {
                clearTimeout(pressTimer);
            });
        })();
    </script>
</div>
<%- include('partials/footer') %>
