                searchTimeout = setTimeout(async () => {
                    resultsEl.innerHTML = '<p style="text-align:center; opacity:0.5; padding:20px;">Searching... 🔍</p>';
                    try {
                        const res = await fetch(`/api/chat/search?q=${encodeURIComponent(query)}`);
                        const data = await res.json();
                        
                        if (data.results.length === 0) {
                            resultsEl.innerHTML = '<p style="text-align:center; opacity:0.5; padding:20px;">No messages found. 💔</p>';
                            return;
                        }

                        resultsEl.innerHTML = data.results.map(msg => `
                            <div class="starred-item">
