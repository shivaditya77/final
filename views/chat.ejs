<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="chat">
    <link rel="stylesheet" href="/css/Chat.css">
    <link rel="stylesheet" href="/css/VideoCall.css">
    <div class="chat-body" id="chat-page-root">
        <canvas id="heartParticles"></canvas>

        <!-- HEADER -->
        <div class="chat-header">
            <div class="chat-header-left">
                <h1>Soul Space ❤️</h1>
                <div class="chat-status-container">
                    <div id="status-dot" class="chat-status-dot connecting"></div>
                    <span id="status-text" class="chat-status-text">Connecting...</span>
                    <span class="typing-indicator" id="typing-indicator"></span>
                </div>
            </div>
            <div class="chat-header-right">

                <button class="chat-nav-btn" onclick="toggleMediaView()">📁 <span>Media</span></button>
                <button class="chat-nav-btn" onclick="toggleSearchView()">🔍 <span>Search</span></button>
                <button class="chat-nav-btn" onclick="toggleWallpaperPicker()">🎨 <span>Wallpaper</span></button>
                <button class="chat-nav-btn" onclick="toggleStarredView()">⭐ <span>Starred</span></button>
                <button class="chat-nav-btn" onclick="toggleSettings()">⚙️</button>
                <a href="/" class="chat-nav-btn">🏠</a>
            </div>
        </div>



        <!-- UPLOAD PROGRESS -->
        <div class="upload-progress-bar-container" id="upload-progress-container" style="display:none">
            <div class="upload-progress-bar-fill" id="upload-progress-fill"></div>
            <span class="upload-progress-label" id="upload-progress-label">Uploading...</span>
        </div>

        <!-- MESSAGES -->
        <div class="chat-messages" id="messages-container">
            <% if (history.length === 0) { %>
                <div class="chat-empty" id="chat-empty">
                    <div class="chat-empty-icon">💌</div>
                    <p>No messages yet... say something sweet! ❤️</p>
                </div>
            <% } %>

            <% history.forEach(msg => { 
                const isSent = msg.sender === username;
                const safeSender = msg.sender.replace(/'/g, "\\'");
                const replyText = (msg.text || (msg.fileUrl ? "Media" : "...")).replace(/'/g, "\\'").replace(/\n/g, "\\n").replace(/\r/g, "");
                const msgTextForEdit = (msg.text || "").replace(/'/g, "\\'").replace(/\n/g, "\\n").replace(/\r/g, "");
                const isStarred = (msg.isStarredBy || []).includes(username);
            %>
                <div class="chat-message <%= isSent ? 'sent' : 'received' %>" id="msg-<%= msg._id %>">
                    <div class="msg-options" data-id="<%= msg._id %>">⋮</div>
                    <div class="msg-dropdown" id="dropdown-<%= msg._id %>">
                        <button class="msg-action-btn" data-action="reply" data-id="<%= msg._id %>" data-sender="<%= safeSender %>" data-text="<%= replyText %>">⤴️ Reply</button>
                        <% if (isSent && msg.fileType === 'text') { %>
                            <button class="msg-action-btn" data-action="edit" data-id="<%= msg._id %>" data-text="<%= msgTextForEdit %>">✏️ Edit</button>
                        <% } %>
                        <button class="msg-action-btn" data-action="star" data-id="<%= msg._id %>" id="star-btn-<%= msg._id %>"><%= isStarred ? '⭐ Unstar' : '⭐ Star' %></button>
                        
                        <div class="divider"></div>

                        <button class="msg-action-btn delete-btn" data-action="delete-me" data-id="<%= msg._id %>">🗑 Delete for me</button>
                        <% if (isSent) { %>
                            <button class="msg-action-btn delete-btn" data-action="delete-everyone" data-id="<%= msg._id %>">🚫 Delete for everyone</button>
                        <% } %>
                    </div>
                    <div class="reaction-picker-btn" data-id="<%= msg._id %>">❤️+</div>
                    <div class="reaction-picker" id="picker-<%= msg._id %>">
                        <span class="react-btn" data-id="<%= msg._id %>" data-emoji="❤️">❤️</span>
                        <span class="react-btn" data-id="<%= msg._id %>" data-emoji="😂">😂</span>
                        <span class="react-btn" data-id="<%= msg._id %>" data-emoji="😮">😮</span>
                        <span class="react-btn" data-id="<%= msg._id %>" data-emoji="😢">😢</span>
                        <span class="react-btn" data-id="<%= msg._id %>" data-emoji="👍">👍</span>
                    </div>

                    <div class="sender-name"><%= msg.sender %></div>

                    <% if (msg.replyTo) { %>
                        <div class="reply-quote">
                            <div class="reply-quote-sender"><%= msg.replyTo.sender %></div>
                            <div class="reply-quote-text"><%= msg.replyTo.text || (msg.replyTo.fileUrl ? "Media" : "...") %></div>
                        </div>
                    <% } %>

                    <% if (msg.fileUrl) { %>
                        <% if (msg.fileType === 'image') { %>
                            <img src="<%= msg.fileUrl %>" class="chat-media-img" onclick="openLightbox('<%= msg.fileUrl %>', 'image')">
                        <% } else if (msg.fileType === 'video') { %>
                            <video src="<%= msg.fileUrl %>" class="chat-media-video" onclick="openLightbox('<%= msg.fileUrl %>', 'video')"></video>
                        <% } else if (msg.fileType === 'audio') { %>
                            <audio src="<%= msg.fileUrl %>" class="chat-media-audio" controls></audio>
                        <% } %>
                    <% } %>

                    <% if (msg.text) { %>
                        <div class="text"><%= msg.text %></div>
                    <% } %>

                    <% if (msg.linkPreview && msg.linkPreview.url) { %>
                        <a href="<%= msg.linkPreview.url %>" target="_blank" class="link-preview">
                            <% if (msg.linkPreview.image) { %>
                                <img src="<%= msg.linkPreview.image %>" class="lp-image">
                            <% } %>
                            <div class="lp-content">
                                <div class="lp-title"><%= msg.linkPreview.title %></div>
                                <% if (msg.linkPreview.description) { %>
                                    <div class="lp-desc"><%= msg.linkPreview.description %></div>
                                <% } %>
                                <div class="lp-url"><%= new URL(msg.linkPreview.url).hostname %></div>
                            </div>
                        </a>
                    <% } %>

                    <div class="reactions-display" id="reactions-<%= msg._id %>">
                        <% 
                            const emojiGroups = {};
                            (msg.reactions || []).forEach(r => {
                                emojiGroups[r.emoji] = (emojiGroups[r.emoji] || 0) + 1;
                            });
                            Object.keys(emojiGroups).forEach(emoji => { 
                        %>
                            <span class="reaction-bubble"><%= emoji %> <small><%= emojiGroups[emoji] %></small></span>
                        <% }) %>
                    </div>

                    <div class="msg-time">
                        <%= new Date(msg.timestamp || msg.createdAt).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true }) %>
                        <% if (isSent) { %>
                            <span class="tick <%= msg.status === 'read' ? 'read' : '' %>">✔✔</span>
                        <% } %>
                        <span class="msg-star-icon <%= isStarred ? 'active' : '' %>" id="star-icon-<%= msg._id %>">⭐</span>
                        <span class="edited-label <%= msg.isEdited ? 'is-edited' : '' %>" id="edited-<%= msg._id %>">(edited)</span>
                    </div>
                </div>
            <% }) %>
            <div id="messages-end"></div>
        </div>

        <!-- REPLY PREVIEW -->
        <div class="reply-preview-container" id="reply-preview" style="display:none">
            <div class="reply-preview-content">
                <span class="reply-preview-sender" id="reply-preview-sender"></span>
                <p class="reply-preview-text" id="reply-preview-text"></p>
            </div>
            <button type="button" class="reply-preview-close" onclick="cancelReply()">✕</button>
        </div>

        <!-- EDIT PREVIEW -->
        <div class="reply-preview-container" id="edit-preview" style="display:none; border-left-color: #ffc107;">
            <div class="reply-preview-content">
                <span class="reply-preview-sender" style="color: #ffc107;">Editing Message</span>
                <p class="reply-preview-text" id="edit-preview-text"></p>
            </div>
            <button type="button" class="reply-preview-close" onclick="cancelEdit()">✕</button>
        </div>

        <!-- INPUT AREA -->
        <form class="chat-input-area" id="chat-form">
            <div class="media-btns">
                <button type="button" class="chat-media-btn" title="Attach file" id="attach-btn">📎</button>
                <button type="button" class="chat-media-btn" title="Voice message" id="voice-btn">🎤</button>
            </div>

            <input type="file" id="chat-file-input" hidden accept="image/*,video/*,audio/*">

            <input class="chat-input-field" id="chat-input" autocomplete="off" placeholder="Say something sweet...">

            <button type="submit" class="chat-send-btn" id="send-btn">❤️</button>
        </form>

        <div class="chat-toast" id="chat-toast"></div>

        <!-- MEDIA GALLERY VIEW -->
        <div class="starred-view" id="media-view">
            <div class="starred-header">
                <h2>📁 Media Gallery</h2>
                <button onclick="toggleMediaView()">✕</button>
            </div>
            <div class="starred-list">
                <div class="media-gallery-grid" id="media-gallery-list">
                    <!-- Media items injected here -->
                </div>
            </div>
        </div>

        <!-- SEARCH VIEW -->
        <div class="starred-view" id="search-view">
            <div class="starred-header">
                <h2>🔍 Search Messages</h2>
                <button onclick="toggleSearchView()">✕</button>
            </div>
            <div class="search-input-container">
                <input type="text" id="search-input" placeholder="Search for memories..." oninput="handleSearch(this.value)">
            </div>
            <div class="starred-list" id="search-results">
                <p style="text-align:center; opacity:0.5; padding:20px;">Type something to search... ❤️</p>
            </div>
        </div>

        <!-- STARRED MESSAGES VIEW -->
        <div class="starred-view" id="starred-view">
            <div class="starred-header">
                <h2>⭐ Starred Messages</h2>
                <button onclick="toggleStarredView()">✕</button>
            </div>
            <div class="starred-list" id="starred-list">
                <!-- Starred messages injected here -->
            </div>
        </div>


        <!-- WALLPAPER PICKER -->
        <div class="starred-view" id="wallpaper-picker">
            <div class="starred-header">
                <h2>🎨 Chat Wallpaper</h2>
                <button onclick="toggleWallpaperPicker()">✕</button>
            </div>
            <div class="starred-list">
                <div class="wallpaper-grid">
                    <div class="wallpaper-item" style="background: var(--bg-dark);" onclick="setWallpaper('')">
                        <span>Default</span>
                    </div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1518199266791-5375a83190b7?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1518199266791-5375a83190b7?auto=format&fit=crop&q=80')"></div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1516589174184-c68526673fd0?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1516589174184-c68526673fd0?auto=format&fit=crop&q=80')"></div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1494774157365-9e04c6720e47?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1494774157365-9e04c6720e47?auto=format&fit=crop&q=80')"></div>
                    <div class="wallpaper-item" style="background-image: url('https://images.unsplash.com/photo-1581022295087-35e593704911?auto=format&fit=crop&w=200');" onclick="setWallpaper('https://images.unsplash.com/photo-1581022295087-35e593704911?auto=format&fit=crop&q=80')"></div>
                </div>
                <hr style="opacity:0.1; margin: 20px 0;">
                <button class="chat-nav-btn" style="width:100%" onclick="document.getElementById('wallpaper-upload').click()">📤 Upload Custom Photo</button>
                <input type="file" id="wallpaper-upload" style="display:none" accept="image/*" onchange="handleWallpaperUpload(this)">
            </div>
        </div>

        <!-- LIGHTBOX -->
        <div class="lightbox" id="lightbox" onclick="closeLightbox()">
            <span class="lightbox-close">&times;</span>
            <div class="lightbox-content" onclick="event.stopPropagation()">
                <img id="lightbox-img" src="" style="display:none">
                <video id="lightbox-video" src="" controls style="display:none"></video>
            </div>
        </div>
    </div>

    <!-- PROFESSIONAL CHAT ENGINE -->
    <script src="/js/ChatEngine.js?v=1.1.0"></script>
    <script>
        // UI Toggles
        window.toggleMediaView = () => {
            const view = document.getElementById('media-view');
            if (view.style.display === 'flex') {
                view.style.display = 'none';
            } else {
                document.querySelectorAll('.starred-view').forEach(v => v.style.display = 'none');
                view.style.display = 'flex';
                // Render media items here
            }
        };
        window.toggleSearchView = () => {
            const view = document.getElementById('search-view');
            if (view.style.display === 'flex') {
                view.style.display = 'none';
            } else {
                document.querySelectorAll('.starred-view').forEach(v => v.style.display = 'none');
                view.style.display = 'flex';
                document.getElementById('search-input').focus();
            }
        };
        window.toggleStarredView = () => {
            const view = document.getElementById('starred-view');
            if (view.style.display === 'flex') {
                view.style.display = 'none';
            } else {
                document.querySelectorAll('.starred-view').forEach(v => v.style.display = 'none');
                view.style.display = 'flex';
            }
        };
        window.toggleWallpaperPicker = () => {
            const view = document.getElementById('wallpaper-picker');
            if (view.style.display === 'flex') {
                view.style.display = 'none';
            } else {
                document.querySelectorAll('.starred-view').forEach(v => v.style.display = 'none');
                view.style.display = 'flex';
            }
        };
        window.setWallpaper = async (url) => {
            const root = document.getElementById('chat-page-root');
            if (url) {
                root.style.backgroundImage = `url('${url}')`;
                root.style.backgroundSize = 'cover';
                root.style.backgroundPosition = 'center';
            } else {
                root.style.backgroundImage = '';
            }
            try {
                await fetch('/api/user/wallpaper', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ wallpaper: url })
                });
            } catch (err) {
                console.error('Failed to save wallpaper', err);
            }
        };
        window.handleWallpaperUpload = async (input) => {
            if (!input.files || !input.files[0]) return;
            const file = input.files[0];
            const formData = new FormData();
            formData.append('media', file);
            
            try {
                const res = await fetch('/api/chat/upload', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                if (data.fileUrl) {
                    setWallpaper(data.fileUrl);
                }
            } catch (err) {
                alert('Failed to upload wallpaper.');
            }
        };
        window.toggleSettings = () => {
            // Optional: Implement a generic settings menu
            alert("Settings coming soon! ❤️");
        };
        window.closeLightbox = () => {
            const lb = document.getElementById('lightbox');
            lb.style.display = 'none';
            document.getElementById('lightbox-video').pause();
        };
        
        window.handleSearch = (query) => {
            // Basic frontend search implementation
            const q = query.toLowerCase();
            const msgs = document.querySelectorAll('.message-bubble');
            const results = document.getElementById('search-results');
            results.innerHTML = '';
            
            if (!q) {
                results.innerHTML = '<p style="text-align:center; opacity:0.5; padding:20px;">Type something to search... ❤️</p>';
                return;
            }
            
            let found = 0;
            msgs.forEach(el => {
                const textEl = el.querySelector('.message-text');
                if (textEl && textEl.innerText.toLowerCase().includes(q)) {
                    found++;
                    const clone = el.cloneNode(true);
                    // Remove dropdown button from clone
                    const btn = clone.querySelector('.msg-options');
                    if (btn) btn.remove();
                    results.appendChild(clone);
                }
            });
            if (found === 0) {
                results.innerHTML = '<p style="text-align:center; opacity:0.5; padding:20px;">No matching messages found 😢</p>';
            }
        };
    </script>
</div>
<%- include('partials/footer') %>
