<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="game-heart-seeker">
    <style>
        .game-body {
            min-height: 100vh;
            background: #0a0a0a;
            color: white;
            font-family: 'Poppins', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 100px;
            position: relative;
        }
        .game-bg {
            position: fixed; inset: 0;
            background: radial-gradient(circle at center, #0f0c29 0%, #0a0a0a 100%);
            z-index: 0;
        }
        .game-container {
            position: relative; z-index: 10;
            text-align: center;
            width: 100%;
            max-width: 500px;
            padding: 20px;
        }
        .status-badge {
            background: rgba(139, 92, 246, 0.15);
            padding: 10px 20px;
            border-radius: 50px;
            border: 1px solid rgba(139, 92, 246, 0.3);
            margin-bottom: 30px;
            font-size: 0.9rem;
            color: #a78bfa;
            display: inline-block;
        }
        .grids-container {
            display: flex;
            flex-direction: column;
            gap: 30px;
            align-items: center;
        }
        .grid-wrapper {
            width: 100%;
            max-width: 300px;
        }
        .grid-title {
            font-size: 0.75rem;
            letter-spacing: 2px;
            margin-bottom: 10px;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            grid-template-rows: repeat(5, 1fr); /* Explicit rows for permanent fix */
            gap: 12px;
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 24px;
            border: 2px solid rgba(255, 255, 255, 0.1);
            width: 100%;
            aspect-ratio: 1 / 1; /* Force the whole container to be square */
            max-width: 400px;
            margin: 0 auto;
            box-sizing: border-box;
        }
        .cell {
            position: relative;
            width: 100%;
            height: 100%; /* Fill the grid slot perfectly */
            background: rgba(255, 255, 255, 0.06); 
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(255, 255, 255, 0.1);
            overflow: hidden;
            min-width: 0; min-height: 0; /* Prevent content stretching */
        }
        .cell:hover:not(.taken) {
            background: rgba(139, 92, 246, 0.15);
            border-color: #a78bfa;
            transform: scale(1.05);
            z-index: 2;
        }
        .cell-content {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            line-height: 1;
        }
        .cell.hidden-heart { background: rgba(139, 92, 246, 0.3); border-color: #a78bfa; }
        .cell.hit { background: rgba(255, 77, 109, 0.3); border-color: #ff4d6d; color: #ff4d6d; box-shadow: inset 0 0 15px rgba(255, 77, 109, 0.2); }
        .cell.miss { background: rgba(255, 255, 255, 0.15); color: rgba(255, 255, 255, 0.4); }
        .cell.taken { cursor: default; }
        
        .controls { margin-top: 30px; display: flex; flex-direction: column; align-items: center; gap: 15px; }
        .btn-ready {
            background: linear-gradient(135deg, #8b5cf6, #6d28d9);
            border: none; color: white; padding: 15px 45px;
            border-radius: 50px; font-weight: 700; cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);
            letter-spacing: 1px;
        }
        .btn-ready:active { transform: scale(0.95); }
        .btn-ready:disabled { opacity: 0.5; cursor: not-allowed; box-shadow: none; }
        
        .btn-emergency {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.6);
            padding: 12px 30px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-emergency:hover { background: rgba(255, 77, 109, 0.15); border-color: #ff4d6d; color: white; }

        @media (min-width: 800px) {
            .grids-container { flex-direction: row; max-width: 100%; justify-content: center; gap: 60px; padding: 0 20px; }
            .game-container { max-width: 1200px; }
            .grid { width: 350px; height: 350px; } /* Fixed square size for desktop */
        }
    </style>

    <div class="game-body">
        <div class="game-bg"></div>
        <%- include('partials/navbar') %>

        <div class="game-container">
            <div class="status-badge" id="status-text">Phase 1: Hide 3 Hearts on your grid! 💘</div>

            <div class="grids-container">
                <!-- MY GRID -->
                <div class="grid-wrapper" id="my-grid-wrapper">
                    <div class="grid-title">Your Grid (Hide Hearts)</div>
                    <div class="grid" id="my-grid">
                        <% for(let i=0; i<25; i++) { %>
                            <div class="cell" data-index="<%= i %>">
                                <div class="cell-content"></div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- OPPONENT GRID -->
                <div class="grid-wrapper" id="opponent-grid-wrapper" style="opacity: 0.2; pointer-events: none; transition: all 0.5s;">
                    <div class="grid-title"><%= otherUser %>'s Grid (Attack!)</div>
                    <div class="grid" id="opponent-grid">
                        <% for(let i=0; i<25; i++) { %>
                            <div class="cell" data-index="<%= i %>">
                                <div class="cell-content"></div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="controls">
                <button class="btn-ready" id="ready-btn" onclick="window.sendReady()" disabled>I'm Ready! 🚀</button>
                <div style="display: flex; gap: 10px;">
                    <button class="btn-emergency" onclick="window.syncPhase()" style="border-color: #a78bfa; color: #a78bfa;">🔄 Sync Game</button>
                    <button class="btn-emergency" onclick="window.emergencyReset()">🛑 Emergency Reset</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const username = "<%= username %>";
            const otherUser = "<%= otherUser %>";
            const channelName = 'private-notifications-' + username.toLowerCase();
            
            let myHearts = [];
            let opponentHits = 0;
            let myHits = 0;
            let phase = 1; // 1: Placing, 2: Waiting, 3: Playing, 4: Ended
            let isMyTurn = false;
            let otherReady = false;

            const myCells = document.querySelectorAll('#my-grid .cell');
            const oppCells = document.querySelectorAll('#opponent-grid .cell');
            const statusText = document.getElementById('status-text');
            const readyBtn = document.getElementById('ready-btn');
            const oppGridWrapper = document.getElementById('opponent-grid-wrapper');
            const oppGrid = document.getElementById('opponent-grid');

            function initGameSync() {
                if (!window.globalPusher) return setTimeout(initGameSync, 500);
                const channel = window.globalPusher.subscribe(channelName);
                
                channel.unbind('heart-seeker-ready');
                channel.unbind('heart-seeker-start');
                channel.unbind('heart-seeker-attack');
                channel.unbind('heart-seeker-result');
                channel.unbind('heart-seeker-reset');

                channel.bind('heart-seeker-ready', (data) => {
                    console.log("🎮 Heart Seeker Ready:", data);
                    otherReady = true;
                    if (phase === 2) {
                        startGame(true); 
                    } else {
                        showToast(otherUser + " is ready! 🚀");
                    }
                });

                channel.bind('heart-seeker-sync-request', async (data) => {
                    if (data.from.toLowerCase() !== otherUser.toLowerCase()) return;
                    try {
                        await fetch('/api/games/heart-seeker/sync-response', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ to: otherUser, phase, isReady: (phase >= 2) })
                        });
                    } catch (e) {}
                });

                channel.bind('heart-seeker-sync-response', (data) => {
                    if (data.from.toLowerCase() !== otherUser.toLowerCase()) return;
                    console.log("🔄 Sync Response:", data);
                    if (data.isReady) otherReady = true;
                    if (phase === 2 && otherReady) startGame(true);
                    if (data.phase === 3 && phase < 3) startGame(false);
                });

                channel.bind('heart-seeker-start', (data) => {
                    console.log("🎮 Heart Seeker Force Start:", data);
                    if (phase < 3) startGame(false);
                });

                channel.bind('heart-seeker-attack', async (data) => {
                    const idx = parseInt(data.index);
                    const isHit = myHearts.includes(idx);
                    const cell = myCells[idx];
                    const content = cell.querySelector('.cell-content');
                    
                    cell.classList.add('taken');
                    gsap.from(cell, { scale: 1.5, duration: 0.3, repeat: 1, yoyo: true });

                    if (isHit) {
                        cell.classList.add('hit');
                        content.innerText = '💥';
                        opponentHits++;
                    } else {
                        cell.classList.add('miss');
                        content.innerText = '❌';
                    }

                    try {
                        await fetch('/api/games/heart-seeker/result', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ index: idx, isHit, to: otherUser })
                        });
                    } catch (e) {}

                    if (opponentHits === 3) {
                        statusText.innerText = "💔 " + otherUser + " Won!";
                        statusText.style.color = "#ff4d6d";
                        phase = 4;
                    } else {
                        isMyTurn = true;
                        updateTurnUI();
                    }
                });

                channel.bind('heart-seeker-result', (data) => {
                    const cell = oppCells[data.index];
                    const content = cell.querySelector('.cell-content');
                    cell.classList.add('taken');
                    
                    if (data.isHit) {
                        cell.classList.add('hit');
                        content.innerText = '💖';
                        myHits++;
                        if (myHits === 3) {
                            statusText.innerText = "🎉 You Won! 🏆";
                            statusText.style.color = "#00ffcc";
                            phase = 4;
                        }
                    } else {
                        cell.classList.add('miss');
                        content.innerText = '🌊';
                    }
                    
                    // After my result, it's not my turn anymore if I didn't win
                    if (phase !== 4) {
                        isMyTurn = false;
                        updateTurnUI();
                    }
                });

                channel.bind('heart-seeker-reset', () => location.reload());
            }

            myCells.forEach(cell => {
                cell.addEventListener('click', () => {
                    if (phase !== 1) return;
                    const idx = parseInt(cell.getAttribute('data-index'));
                    const content = cell.querySelector('.cell-content');
                    
                    if (myHearts.includes(idx)) {
                        myHearts = myHearts.filter(h => h !== idx);
                        cell.classList.remove('hidden-heart');
                        content.innerText = '';
                    } else if (myHearts.length < 3) {
                        myHearts.push(idx);
                        cell.classList.add('hidden-heart');
                        content.innerText = '💘';
                        gsap.from(cell, { 
                            scale: 0.5, 
                            duration: 0.2,
                            onComplete: () => gsap.set(cell, { clearProps: "all" })
                        });
                    }
                    readyBtn.disabled = myHearts.length !== 3;
                });
            });

            oppCells.forEach(cell => {
                cell.addEventListener('click', () => {
                    if (phase !== 3 || !isMyTurn) return;
                    if (cell.classList.contains('taken')) return;
                    
                    const idx = cell.getAttribute('data-index');
                    attackOpponent(idx);
                });
            });

            window.sendReady = async function() {
                phase = 2;
                readyBtn.style.display = 'none';
                statusText.innerText = "Waiting for " + otherUser + "... ⌛";
                
                try {
                    await fetch('/api/games/heart-seeker/hide', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ to: otherUser })
                    });
                    if (otherReady) startGame(true);
                } catch (e) {}
            };

            async function startGame(shouldBroadcast) {
                phase = 3;
                oppGridWrapper.style.opacity = '1';
                oppGridWrapper.style.pointerEvents = 'all';
                isMyTurn = username.toLowerCase() === 'bhondu'; 
                
                updateTurnUI();
                
                // Entrance animation for attack grid
                gsap.to(oppGridWrapper, { opacity: 1, scale: 1, duration: 0.5 });
                gsap.from(oppCells, { 
                    scale: 0, 
                    stagger: 0.02, 
                    duration: 0.4, 
                    ease: "back.out",
                    onComplete: () => {
                        gsap.set(oppCells, { clearProps: "all" });
                    }
                });

                if (shouldBroadcast) {
                    try {
                        await fetch('/api/games/heart-seeker/start', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ to: otherUser })
                        });
                    } catch (e) {}
                }
            }

            function updateTurnUI() {
                if (phase !== 3) return;
                
                if (isMyTurn) {
                    statusText.innerText = "Your Turn! Attack! 🎯";
                    statusText.style.color = "#00ffcc";
                    oppGrid.style.boxShadow = "0 0 20px rgba(0, 255, 204, 0.3)";
                    gsap.to(oppGrid, { borderColor: "#00ffcc", duration: 0.3 });
                } else {
                    statusText.innerText = `Waiting for ${otherUser}... ⌛`;
                    statusText.style.color = "rgba(255,255,255,0.6)";
                    oppGrid.style.boxShadow = "none";
                    gsap.to(oppGrid, { borderColor: "rgba(255,255,255,0.1)", duration: 0.3 });
                }
            }

            async function attackOpponent(index) {
                if (!isMyTurn) return;
                
                // Optimistic UI: temporary disable
                isMyTurn = false;
                updateTurnUI();

                try {
                    await fetch('/api/games/heart-seeker/attack', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ index, to: otherUser })
                    });
                } catch (e) {
                    isMyTurn = true; // Rollback
                    updateTurnUI();
                }
            }

            window.syncPhase = async function() {
                const btn = document.querySelector('button[onclick="window.syncPhase()"]');
                btn.innerText = "⌛ Syncing...";
                try {
                    await fetch('/api/games/heart-seeker/sync-request', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ to: otherUser })
                    });
                    setTimeout(() => { btn.innerText = "🔄 Sync Game"; }, 2000);
                } catch (e) { btn.innerText = "❌ Error"; }
            };

            window.emergencyReset = async function() {
                if (!confirm("This will reload the game for BOTH players. Continue?")) return;
                try {
                    await fetch('/api/games/heart-seeker/reset', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ to: otherUser })
                    });
                    location.reload(); // Reload locally after sending signal
                } catch (e) { location.reload(); }
            };

            initGameSync();
        })();
    </script>
</div>
<%- include('partials/footer') %>
