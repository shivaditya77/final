<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="movies">
    <link rel="stylesheet" href="/css/Home.css">
    <script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
    
    <div class="home-body cinema-bg">
        <div class="vignette"></div>
        
        <%- include('partials/navbar') %>

        <div class="movies-app-wrapper">
            <!-- MAIN CONTENT -->
            <div class="movies-main-panel">
                <div class="movies-header">
                    <div class="movies-title-box">
                        <span class="movies-icon">🍿</span>
                        <h1>Bhondu's Picture House</h1>
                        <p>Exclusive access to your private theater</p>
                    </div>
                </div>

                <div class="cinema-launcher-card">
                    <div class="launcher-visual">
                        <div class="glow-orb"></div>
                        <span class="launcher-emoji">🎬</span>
                    </div>
                    <h2>Soulmate Cinema</h2>
                    <p>Open a theater window below to start watching. Use the chat on the right to talk while you watch! ❤️</p>
                    
                    <div class="launcher-actions">
                        <button onclick="launchCinema('https://net22.cc/home')" class="main-launch-btn">
                            <img src="https://net22.cc/favicon.ico" class="btn-icon" onerror="this.src='/images/popcorn.png';">
                            NetMirror
                        </button>
                        <button onclick="launchCinema('https://movie-box.co/')" class="main-launch-btn server-2">
                            <img src="https://movie-box.co/favicon.ico" class="btn-icon" onerror="this.src='/images/video.png';">
                            MoviesBox
                        </button>
                    </div>

                    <!-- REACTION BAR -->
                    <div class="reaction-strip genz-style">
                        <button class="reaction-btn" data-emoji="❤️">❤️</button>
                        <button class="reaction-btn" data-emoji="😂">😂</button>
                        <button class="reaction-btn" data-emoji="😍">😍</button>
                        <button class="reaction-btn" data-emoji="🔥">🔥</button>
                        <button class="reaction-btn" data-emoji="🍿">🍿</button>
                        <button class="reaction-btn" data-emoji="💋">💋</button>
                    </div>
                </div>
            </div>

            <!-- SIDE CHAT PANEL -->
            <div class="movies-chat-panel glass-card">
                <div class="chat-header">
                    <h3>Popcorn Chat 🍿</h3>
                    <div class="online-status">
                        <span class="status-dot"></span>
                        <span id="status-text">Connecting...</span>
                    </div>
                </div>
                <div id="cinema-chat-messages" class="chat-messages classy-scroll">
                    <div class="chat-system-msg">Welcome to our private cinema chat! ❤️</div>
                </div>
                <div class="chat-input-area">
                    <div class="glass-input-wrapper">
                        <input type="text" id="chat-input" placeholder="Type a message..." autocomplete="off">
                        <button id="send-chat-btn">➔</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .cinema-bg { background: radial-gradient(circle at center, #1a0b0f 0%, #050505 100%) !important; }
        .movies-app-wrapper { display: grid; grid-template-columns: 1fr 400px; height: calc(100vh - 80px); margin-top: 80px; max-width: 1600px; margin-left: auto; margin-right: auto; padding: 20px; gap: 20px; position: relative; z-index: 10; }
        
        .movies-main-panel { display: flex; flex-direction: column; gap: 20px; overflow-y: auto; padding-right: 10px; }
        .movies-header { margin-bottom: 10px; }
        .movies-title-box h1 { font-size: 2.2rem; color: #fff; margin-bottom: 5px; font-weight: 800; }
        .movies-title-box p { color: rgba(255, 255, 255, 0.4); font-size: 0.9rem; }
        
        .cinema-launcher-card { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 32px; padding: 40px; text-align: center; backdrop-filter: blur(20px); }
        .launcher-visual { position: relative; margin-bottom: 20px; display: inline-block; }
        .launcher-emoji { font-size: 5rem; display: block; animation: floatIcon 3s ease-in-out infinite; }
        .glow-orb { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 120px; height: 120px; background: radial-gradient(circle, rgba(255, 77, 109, 0.3) 0%, transparent 70%); filter: blur(20px); z-index: -1; }
        
        .launcher-actions { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; margin: 30px 0; }
        .main-launch-btn { display: flex; align-items: center; justify-content: center; gap: 10px; background: linear-gradient(135deg, #ff4d6d, #ff1e4d); color: white; border: none; padding: 15px 30px; border-radius: 50px; font-weight: 700; cursor: pointer; transition: 0.3s; box-shadow: 0 10px 20px rgba(255,77,109,0.3); }
        .server-2 { background: linear-gradient(135deg, #8b5cf6, #6d28d9); box-shadow: 0 10px 20px rgba(139, 92, 246, 0.3); }
        .main-launch-btn:hover { transform: translateY(-3px); filter: brightness(1.1); }
        .btn-icon { width: 20px; height: 20px; border-radius: 4px; }

        /* REACTION STRIP */
        .reaction-strip { display: flex; gap: 12px; justify-content: center; padding: 15px; background: rgba(255,255,255,0.03); border-radius: 50px; border: 1px solid rgba(255,255,255,0.05); margin-top: 20px; }
        .reaction-btn { width: 45px; height: 45px; font-size: 1.5rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 50%; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; }
        .reaction-btn:hover { transform: scale(1.2) translateY(-5px); background: rgba(255,77,109,0.1); border-color: #ff4d6d; }

        /* CHAT PANEL */
        .movies-chat-panel { display: flex; flex-direction: column; background: rgba(10,10,10,0.5); border-radius: 32px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden; height: 100%; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
        .chat-header { padding: 20px; background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center; }
        .chat-header h3 { font-size: 1.1rem; color: #fff; margin: 0; }
        .online-status { display: flex; align-items: center; gap: 8px; font-size: 0.75rem; color: rgba(255,255,255,0.5); }
        .status-dot { width: 8px; height: 8px; background: #ff4d6d; border-radius: 50%; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 12px; }
        .msg-bubble { padding: 10px 15px; border-radius: 18px; max-width: 85%; font-size: 0.9rem; position: relative; animation: fadeIn 0.3s ease; }
        .msg-other { background: rgba(255,255,255,0.08); color: #fff; align-self: flex-start; border-bottom-left-radius: 4px; }
        .msg-me { background: linear-gradient(135deg, #ff4d6d 0%, #ff1e4d 100%); color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }
        .msg-user { font-size: 0.7rem; font-weight: 800; margin-bottom: 3px; display: block; opacity: 0.7; }
        .chat-system-msg { text-align: center; font-size: 0.75rem; color: rgba(255,255,255,0.3); margin: 10px 0; }
        
        .chat-input-area { padding: 20px; background: rgba(5,5,5,0.3); }
        .glass-input-wrapper { display: flex; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 50px; padding: 5px 5px 5px 15px; align-items: center; }
        .glass-input-wrapper input { flex: 1; background: transparent; border: none; color: #fff; outline: none; font-size: 0.9rem; padding: 8px 0; }
        #send-chat-btn { background: #ff4d6d; border: none; width: 35px; height: 35px; border-radius: 50%; color: white; cursor: pointer; transition: 0.3s; }
        #send-chat-btn:hover { transform: scale(1.1); background: #ff1e4d; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes floatUp { 0% { transform: translateY(0) scale(1); opacity: 1; } 100% { transform: translateY(-200px) scale(1.5); opacity: 0; } }
        
        @media (max-width: 1000px) {
            .movies-app-wrapper { grid-template-columns: 1fr; height: auto; margin-top: 60px; }
            .movies-chat-panel { min-height: 500px; }
        }
    </style>

    <script>
        const username = "<%= username %>";
        let pusher, channel;

        function initPusher() {
            pusher = new Pusher("<%= pusherKey %>", { cluster: "<%= pusherCluster %>", authEndpoint: "/pusher/auth" });
            channel = pusher.subscribe("presence-soul-connect");
            
            channel.bind("pusher:subscription_succeeded", (m) => updateStatus(m.count > 1));
            channel.bind("pusher:member_added", () => updateStatus(true));
            channel.bind("pusher:member_removed", () => updateStatus(false));
            
            channel.bind("movie-chat-message", (data) => {
                if (data.username === username) return;
                appendChatMessage(data.username, data.text, false);
            });

            channel.bind("movie-reaction", (data) => {
                if (data.username === username) return;
                showFloatingEmoji(data.emoji);
            });
        }

        function updateStatus(online) {
            const t = document.getElementById("status-text"), d = document.querySelector(".status-dot");
            t.innerText = online ? "Soulmate is here! ❤️" : "Watching alone...";
            d.style.background = online ? "#00ff88" : "#ff4d6d";
        }

        function appendChatMessage(user, text, isMe) {
            const container = document.getElementById("cinema-chat-messages");
            const div = document.createElement("div");
            div.className = `msg-bubble ${isMe ? 'msg-me' : 'msg-other'}`;
            div.innerHTML = `<span class="msg-user">${user}</span><span class="msg-text">${text}</span>`;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        function sendChatMessage() {
            const input = document.getElementById("chat-input");
            const text = input.value.trim();
            if (!text) return;
            
            fetch("/api/movie/chat", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ text })
            });
            
            appendChatMessage(username, text, true);
            input.value = "";
        }

        function showFloatingEmoji(emoji) {
            const div = document.createElement("div");
            div.innerText = emoji;
            div.style.cssText = `position:fixed; left:${Math.random()*60+20}%; bottom:20%; font-size:3rem; z-index:2000; animation:floatUp 2s forwards; pointer-events:none;`;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 2000);
        }

        document.getElementById("send-chat-btn").onclick = sendChatMessage;
        document.getElementById("chat-input").onkeypress = (e) => { if (e.key === "Enter") sendChatMessage(); };
        
        document.querySelectorAll(".reaction-btn").forEach(btn => {
            btn.onclick = () => {
                const emoji = btn.getAttribute("data-emoji");
                showFloatingEmoji(emoji);
                fetch("/api/movie/reaction", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ emoji })
                });
            };
        });

        function launchCinema(url) {
            const width = 1200;
            const height = 800;
            const left = (screen.width - width) / 2;
            const top = (screen.height - height) / 2;
            window.open(url, 'PrivateCinema', `width=${width},height=${height},left=${left},top=${top},menubar=no,toolbar=no,location=no,status=no,resizable=yes,scrollbars=yes`);
        }

        initPusher();
    </script>
</div>
<%- include('partials/footer') %>
