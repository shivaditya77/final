<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="movies">
    <link rel="stylesheet" href="/css/Home.css">
    <div class="home-body cinema-bg">
        <div class="vignette"></div>
        
        <%- include('partials/navbar') %>

        <div class="movies-container">
            <div class="movies-header">
                <div class="movies-title-box">
                    <span class="movies-icon">🍿</span>
                    <h1>Bhondu's Picture House</h1>
                    <p>Exclusive access to your favorite movies & shows</p>
                </div>
                <a href="/" class="back-home-btn">← Back to Dashboard</a>
            </div>

            <div class="cinema-launcher-card">
                <div class="launcher-visual">
                    <div class="glow-orb"></div>
                    <span class="launcher-emoji">🎬</span>
                </div>
                <h2>Soulmate Cinema Mode</h2>
                <p>Because of security restrictions, movies must run in "App Mode" to work correctly. This will open a dedicated theater window for you.</p>
                
                <div class="launcher-actions">
                    <button onclick="launchCinema('https://net22.cc/home')" class="main-launch-btn">
                        <img src="https://net22.cc/favicon.ico" class="btn-icon" onerror="this.src='/images/popcorn.png'; this.onerror=null;">
                        NetMirror
                    </button>
                    <button onclick="launchCinema('https://movie-box.co/')" class="main-launch-btn server-2">
                        <img src="https://movie-box.co/favicon.ico" class="btn-icon" onerror="this.src='/images/video.png'; this.onerror=null;">
                        MoviesBox
                    </button>
                </div>

                <div class="launcher-features">
                    <div class="feature-tag"><span>🔒</span> Secure</div>
                    <div class="feature-tag"><span>✨</span> Full HD</div>
                    <div class="feature-tag"><span>🚀</span> High Speed</div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .cinema-bg {
            background: radial-gradient(circle at center, #1a0b0f 0%, #050505 100%) !important;
        }
        .movies-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 100px 20px 40px;
            position: relative;
            z-index: 10;
        }
        .movies-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 50px;
        }
        .movies-title-box h1 {
            font-size: 2.5rem;
            color: #fff;
            margin: 10px 0 5px;
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
        }
        .movies-title-box p {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.9rem;
        }
        .back-home-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            padding: 12px 24px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 0.9rem;
            transition: 0.3s;
            backdrop-filter: blur(10px);
        }
        .back-home-btn:hover {
            background: rgba(255, 77, 109, 0.15);
            border-color: #ff4d6d;
            transform: translateX(-5px);
        }

        .cinema-launcher-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 40px;
            padding: 60px 40px;
            text-align: center;
            backdrop-filter: blur(20px);
            box-shadow: 0 40px 100px rgba(0,0,0,0.8);
        }
        .launcher-visual {
            position: relative;
            margin-bottom: 30px;
            display: inline-block;
        }
        .launcher-emoji {
            font-size: 6rem;
            display: block;
            animation: floatIcon 3s ease-in-out infinite;
        }
        .glow-orb {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 150px;
            height: 150px;
            background: radial-gradient(circle, rgba(255, 77, 109, 0.4) 0%, transparent 70%);
            filter: blur(25px);
            z-index: -1;
        }
        .cinema-launcher-card h2 {
            font-size: 2.2rem;
            color: #fff;
            margin-bottom: 15px;
            font-weight: 700;
        }
        .cinema-launcher-card p {
            color: rgba(255, 255, 255, 0.6);
            max-width: 500px;
            margin: 0 auto 40px;
            line-height: 1.6;
        }
        .launcher-actions {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }
        .main-launch-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: linear-gradient(135deg, #ff4d6d, #ff1e4d);
            color: white;
            border: none;
            padding: 18px 40px;
            border-radius: 60px;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 15px 40px rgba(255, 77, 109, 0.3);
            flex: 1;
            max-width: 280px;
        }
        .btn-icon {
            width: 24px;
            height: 24px;
            border-radius: 6px;
            object-fit: contain;
            background: rgba(255, 255, 255, 0.1);
        }
        .server-2 {
            background: linear-gradient(135deg, #8b5cf6, #6d28d9);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.3);
        }
        .main-launch-btn:hover {
            transform: scale(1.05) translateY(-5px);
            box-shadow: 0 20px 50px rgba(255, 77, 109, 0.5);
        }
        .server-2:hover {
            box-shadow: 0 20px 50px rgba(139, 92, 246, 0.5);
        }
        .launcher-features {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 50px;
        }
        .feature-tag {
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        @keyframes floatIcon {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(5deg); }
        }
    </style>

    <script>
        function launchCinema(url) {
            const width = 1200;
            const height = 800;
            const left = (screen.width - width) / 2;
            const top = (screen.height - height) / 2;
            
            window.open(
                url, 
                'PrivateCinema', 
                `width=${width},height=${height},left=${left},top=${top},menubar=no,toolbar=no,location=no,status=no,resizable=yes,scrollbars=yes`
            );
        }
    </script>
</div>
<%- include('partials/footer') %>
