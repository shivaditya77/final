<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="love-letter">
    <link rel="stylesheet" href="/css/LoveLetter.css">
    <div class="love-letter-body">
        <div class="love-letter-vignette"></div>
        <div class="floating-petals" id="petals-container"></div>

        <%- include('partials/navbar') %>

        <div class="love-letter-music-control" id="music-toggle-btn">
            <div class="music-icon" id="love-music-icon">🎶</div>
        </div>

        <div class="love-letter-container">
            <div class="envelope-icon">💌</div>
            <h1>My Dearest Love, Bhondu</h1>
            
            <div class="letter-content" id="letter-text" style="white-space: pre-wrap"></div>
            
            <div class="signature" id="signature">
                Forever Yours,<br />
                ❤️
            </div>
            
            <a href="/questions" class="love-letter-next-btn" id="next-btn" style="text-decoration: none;">Continue →</a>
        </div>
    </div>

    <script>
        (function() {
            const fullLetterText = `I don't even know where to start. I never thought I would write so much for someone… but then, there is you.

When you came into my life, everything changed. The colors changed, my dreams changed, I changed. I became a better person, all because of you.

Do you remember when we talked for the first time? That day, I had no idea that this conversation would become the most important part of my life. Your voice, your laughter, your words… everything found a place in my heart.

You are not just my girlfriend. You are my best friend, my strength, my peace. When you are not around, something feels missing. Like a day without the sun, or a night without the moon.

I am not always able to tell you how important you are to me. That’s why I made this website—to make you feel how special you are to me.

Every little thing about you—your expressions, your habits, your ways… everything is perfect for me. Even your imperfections are perfect, because you are mine.

I thank God every day for sending you into my life. You are a blessing to me… a dream that came true.`;

            const letterEl = document.getElementById('letter-text');
            const signature = document.getElementById('signature');
            const nextBtn = document.getElementById('next-btn');

            let charIndex = 0;
            const typingInterval = setInterval(() => {
                if (!document.getElementById('letter-text')) {
                    clearInterval(typingInterval);
                    return;
                }
                if (charIndex < fullLetterText.length) {
                    letterEl.innerText = fullLetterText.substring(0, charIndex + 1);
                    charIndex++;
                } else {
                    clearInterval(typingInterval);
                    if (signature) signature.style.display = 'block';
                    if (nextBtn) nextBtn.style.display = 'inline-block';
                }
            }, 10);

            // ========== PETALS ==========
            const petalsContainer = document.getElementById('petals-container');
            if (petalsContainer) {
                const petalEmojis = ['🌸', '🌹', '🌺', '🌷', '💮'];
                for (let i = 0; i < 30; i++) {
                    const p = document.createElement('div');
                    p.className = 'petal';
                    p.innerText = petalEmojis[Math.floor(Math.random() * petalEmojis.length)];
                    p.style.left = Math.random() * 100 + '%';
                    p.style.fontSize = (Math.random() * 20 + 15) + 'px';
                    p.style.animationDuration = (Math.random() * 6 + 5) + 's';
                    p.style.animationDelay = Math.random() * 10 + 's';
                    petalsContainer.appendChild(p);
                }
            }

            // ========== MUSIC TOGGLE ==========
            const lMusicIcon = document.getElementById('love-music-icon');
            const musicBtn = document.getElementById('music-toggle-btn');
            if (musicBtn) {
                musicBtn.addEventListener('click', () => {
                    const isPlaying = window.toggleMusic();
                    if (lMusicIcon) lMusicIcon.innerText = isPlaying ? '🎶' : '🎵';
                });
            }

            // Barba cleanup
            barba.hooks.before(() => {
                clearInterval(typingInterval);
            });
        })();
    </script>
</div>
<%- include('partials/footer') %>
