<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="questions">
    <link rel="stylesheet" href="/css/Questions.css">
    <div class="questions-body">
        <div class="questions-vignette"></div>
        <div class="questions-floating-hearts" id="hearts-container"></div>

        <%- include('partials/navbar') %>

        <div class="questions-music-control" id="music-toggle-btn">
            <div class="music-icon" id="questions-music-icon">🎶</div>
        </div>

        <div class="questions-container">
            <h1>9 Questions 💕</h1>
            <div class="questions-subtitle">Answer these from your heart... I'll read every word ❤️</div>
            
            <div class="questions-status-bar">
                <div class="questions-progress-bar-container">
                    <div class="questions-progress-fill" id="progress-fill" style="width: 0%"></div>
                </div>
                <div id="save-status" class="save-status">Checking connection...</div>
            </div>

            <form id="questions-form">
                <% 
                const questionsListItems = [
                    { id: 'q1', num: 1, icon: '💭', text: "What's your favorite memory of us?" },
                    { id: 'q2', num: 2, icon: '💖', text: "When did you first realize you loved me?" },
                    { id: 'q3', num: 3, icon: '😊', text: "What's something I do that always makes you smile?" },
                    { id: 'q4', num: 4, icon: '💕', text: "What's your favorite thing about our relationship?" },
                    { id: 'q5', num: 5, icon: '✨', text: "Where do you see us in 5 years?" },
                    { id: 'q6', num: 6, icon: '🎵', text: "What song reminds you of us?" },
                    { id: 'q7', num: 7, icon: '💑', text: "What's one thing you want us to do together?" },
                    { id: 'q8', num: 8, icon: '🌟', text: "What's your favorite quality of mine?" },
                    { id: 'q9', num: 9, icon: '💘', text: "When do you feel closest to me?" }
                ];
                %>

                <% questionsListItems.forEach(q => { %>
                    <div class="question-card">
                        <div class="question-number"><%= q.icon %> QUESTION <%= q.num %> / 9</div>
                        <div class="question-text"><%= q.text %></div>
                        
                        <div class="answer-wrapper">
                            <label class="input-label">My Heart:</label>
                            <textarea
                                class="answer-input"
                                id="<%= q.id %>"
                                placeholder="Type your heartfelt answer here..."
                                rows="2"
                            ></textarea>
                        </div>

                        <div class="partner-answer-container" id="partner-<%= q.id %>-container" style="display: none;">
                            <label class="input-label partner-label"><span id="partner-name-label">Soulmate</span>'s Heart:</label>
                            <div class="partner-answer-text" id="partner-<%= q.id %>"></div>
                        </div>
                    </div>
                <% }) %>
            </form>

            <div class="questions-button-group">
                <button class="questions-save-btn" id="save-btn">💾 Save Now</button>
                <button class="questions-final-btn" id="final-btn">💕 Continue to Timeline 💕</button>
                <button class="questions-skip-btn" id="skip-btn">⏩ Skip</button>
            </div>
        </div>

        <div class="questions-toast" id="questions-toast"></div>
    </div>

    <script>
        (function() {
            // ========== BG HEARTS ==========
            const heartsContainer = document.getElementById('hearts-container');
            const emojis = ['❤️', '💖', '💕', '💗', '💓'];
            if (heartsContainer) {
                for (let i = 0; i < 25; i++) {
                    const h = document.createElement('div');
                    h.className = 'heart-floating';
                    h.innerText = emojis[Math.floor(Math.random() * emojis.length)];
                    h.style.left = Math.random() * 100 + '%';
                    h.style.fontSize = (Math.random() * 25 + 15) + 'px';
                    h.style.animationDuration = (Math.random() * 10 + 5) + 's';
                    h.style.animationDelay = Math.random() * 10 + 's';
                    heartsContainer.appendChild(h);
                }
            }

            // ========== LOGIC ==========
            const progressFill = document.getElementById('progress-fill');
            const toast = document.getElementById('questions-toast');
            const inputs = document.querySelectorAll('.answer-input');
            const saveStatus = document.getElementById('save-status');

            function updateProgress() {
                if (!progressFill) return;
                let filled = 0;
                inputs.forEach(i => { if (i.value.trim() !== '') filled++; });
                progressFill.style.width = (filled / 9 * 100) + '%';
            }

            let saveTimeout;
            inputs.forEach(i => i.addEventListener('input', () => {
                updateProgress();
                if (saveStatus) saveStatus.innerText = 'Typing...';
                clearTimeout(saveTimeout);
                saveTimeout = setTimeout(() => saveAnswers(false), 2000); 
            }));

            const currentUsername = '<%= (username || "Bhondu").toLowerCase() %>';
            const otherUsername = currentUsername === 'vishu' ? 'bhondu' : 'vishu';
            const otherDisplayName = otherUsername === 'vishu' ? 'Vishu' : 'Bhondu';

            async function fetchAnswers() {
                try {
                    const res = await fetch('/api/questions');
                    const data = await res.json();
                    
                    // Helper to get data regardless of case
                    const getCaseInsensitive = (obj, key) => {
                        const foundKey = Object.keys(obj).find(k => k.toLowerCase() === key.toLowerCase());
                        return foundKey ? obj[foundKey] : null;
                    };

                    // Populate My Answers
                    let myData = getCaseInsensitive(data, currentUsername) || {};
                    // Handle rare case of double nesting from old save bug
                    if (myData.answers) myData = myData.answers;

                    Object.keys(myData).forEach(id => {
                        const input = document.getElementById(id);
                        if (input && myData[id]) input.value = myData[id];
                    });

                    // Populate Partner's Answers
                    let partnerData = getCaseInsensitive(data, otherUsername) || {};
                    if (partnerData.answers) partnerData = partnerData.answers;

                    Object.keys(partnerData).forEach(id => {
                        const partnerText = partnerData[id];
                        if (partnerText && partnerText.trim() !== '') {
                            const partnerDiv = document.getElementById(`partner-${id}`);
                            const partnerContainer = document.getElementById(`partner-${id}-container`);
                            if (partnerDiv && partnerContainer) {
                                partnerDiv.innerText = partnerText;
                                partnerContainer.style.display = 'block';
                            }
                        }
                    });

                    const partnerLabels = document.querySelectorAll('#partner-name-label');
                    partnerLabels.forEach(l => l.innerText = otherDisplayName);

                    updateProgress();
                    if (saveStatus) {
                        if (Object.keys(myData).length > 0) saveStatus.innerText = 'Saved to database ✅';
                        else saveStatus.innerText = 'Ready to start ❤️';
                    }
                } catch (err) {
                    console.error("Fetch Error:", err);
                    if (saveStatus) saveStatus.innerText = 'Offline ❌';
                }
            }
            fetchAnswers();

            async function saveAnswers(showMsg = true) {
                if (saveStatus) saveStatus.innerText = 'Saving... 💾';
                const answers = {};
                inputs.forEach(i => answers[i.id] = i.value);
                try {
                    const res = await fetch('/api/questions/save', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ answers })
                    });
                    if (res.ok) {
                        if (saveStatus) saveStatus.innerText = 'All changes saved ✅';
                        if (showMsg) {
                            let allFilled = true;
                            inputs.forEach(i => { if (i.value.trim() === '') allFilled = false; });
                            displayToast(allFilled ? '💕 All answers saved! Thank you my love! 💕' : '💾 Answers saved! (Empty ones can be filled later) 💾');
                        }
                    } else {
                        if (saveStatus) saveStatus.innerText = 'Save failed ⚠️';
                    }
                } catch (err) {
                    if (saveStatus) saveStatus.innerText = 'Connection error ❌';
                }
            }

            const saveBtn = document.getElementById('save-btn');
            if (saveBtn) {
                saveBtn.addEventListener('click', () => saveAnswers(true));
            }

            const skipBtn = document.getElementById('skip-btn');
            if (skipBtn) {
                skipBtn.addEventListener('click', () => {
                    if (confirm('Are you sure you want to skip these questions? 🥺 Your answers mean the world to me, but I respect your choice! ❤️')) {
                        barba.go('/timeline');
                    }
                });
            }

            const finalBtn = document.getElementById('final-btn');
            if (finalBtn) {
                finalBtn.addEventListener('click', async () => {
                    await saveAnswers(false);
                    let allFilled = true;
                    inputs.forEach(i => { if (i.value.trim() === '') allFilled = false; });
                    if (allFilled) {
                        createHeartExplosion();
                        setTimeout(() => barba.go('/timeline'), 2000);
                    } else {
                        displayToast('💔 Please answer all questions first! 💔');
                    }
                });
            }

            function displayToast(msg) {
                if (!toast) return;
                toast.innerText = msg;
                toast.classList.add('show');
                setTimeout(() => {
                    if (toast) toast.classList.remove('show');
                }, 3000);
            }

            function createHeartExplosion() {
                for (let i = 0; i < 50; i++) {
                    setTimeout(() => {
                        const h = document.createElement('div');
                        h.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];
                        h.style.cssText = `position:fixed;left:${Math.random()*100}%;top:${Math.random()*100}%;font-size:${Math.random()*25+15}px;pointer-events:none;z-index:2000;animation:floatHeartEffect 1s ease-out forwards;`;
                        document.body.appendChild(h);
                        setTimeout(() => h.remove(), 1000);
                    }, i * 30);
                }
            }

            // ========== MUSIC TOGGLE ==========
            const qMusicIcon = document.getElementById('questions-music-icon');
            const musicBtn = document.getElementById('music-toggle-btn');
            if (musicBtn) {
                musicBtn.addEventListener('click', () => {
                    const isPlaying = window.toggleMusic();
                    if (qMusicIcon) qMusicIcon.innerText = isPlaying ? '🎶' : '🎵';
                });
            }
        })();
    </script>

    <style>
    @keyframes floatHeartEffect {
        0% { transform: translateY(0); opacity: 1; }
        100% { transform: translateY(-50px); opacity: 0; }
    }

    .answer-wrapper {
        margin-top: 15px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .input-label {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .partner-answer-container {
        margin-top: 20px;
        padding: 15px;
        background: rgba(255, 77, 109, 0.05);
        border-left: 3px solid #ff4d6d;
        border-radius: 0 15px 15px 0;
        animation: fadeIn 0.5s ease-out;
    }

    .partner-label {
        color: #ffb3c1;
        margin-bottom: 5px;
        display: block;
    }

    .partner-answer-text {
        font-style: italic;
        color: rgba(255, 255, 255, 0.9);
        line-height: 1.6;
        white-space: pre-wrap;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
    </style>
</div>
<%- include('partials/footer') %>
