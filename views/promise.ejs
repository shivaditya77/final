<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="promise">
    <link rel="stylesheet" href="/css/Promise.css">
    <div class="promise-body">
        <div class="promise-vignette"></div>
        <div class="bg-hearts" id="bg-hearts-container"></div>
        <div class="promise-progress-bar" id="promise-progress"></div>

        <div class="nav-container">
            <a href="/" class="nav-btn" style="text-decoration: none;">
                <span>🏠</span><span class="nav-text">Home</span>
            </a>
            <a href="/logout" class="nav-btn premium-logout" style="text-decoration: none;" onclick="return confirm('Are you sure you want to logout? ❤️')" data-barba-prevent="true">
                <span>💋</span><span class="nav-text">Logout</span>
            </a>
        </div>

        <div class="promise-music-control" id="music-toggle-btn">
            <div class="music-icon" id="promise-music-icon">🎶</div>
        </div>

            <div class="promise-header hidden-anim">
                <div class="header-badge">Forever & Always</div>
                <h1 class="promise-main-title">My Sacred Promises to You</h1>
                <p class="promise-intro">Every word here is a vow I intend to keep for a lifetime... ❤️</p>
            </div>

            <div class="promise-grid">
            <% 
            const promiseList = [
                { num: 1, icon: '🤝', title: 'I Promise to Always Listen', text: "When you're happy, when you're sad, when you're feeling anything at all... I will always listen. Every word you say is the most important thing to me. No matter how small or big, I will never ignore it. Your voice is my favorite sound." },
                { num: 2, icon: '💪', title: 'I Promise to Always Support You', text: "Your dreams are my dreams. Whatever you want to become, I will stand by your side. I will celebrate every success with you, and lift you up in every failure. You will never face anything alone. I've got your back, always." },
                { num: 3, icon: '😊', title: 'I Promise to Make You Smile', text: "Every single day, I will find a way to make you smile. Whether it's silly jokes, random acts of love, or just being there... Your smile is the most beautiful thing in this world to me. And I promise to protect it, always." },
                { num: 4, icon: '❤️', title: 'I Promise to Never Give Up on Us', text: "No matter how many storms come our way, I will never walk away. Every problem, every challenge, we will face it together. I am your partner, your best friend, your home. And I will always choose us. Always." },
                { num: 5, icon: '💝', title: 'I Promise to Love You More Every Day', text: "The love I have for you today will grow even more tomorrow. And every single day after that, I will love you more. I will never take you for granted. Every day, I will remind you how special, how beautiful, and how loved you are." }
            ];
            %>

            <% promiseList.forEach((p, i) => { %>
                <div class="promise-card hidden-anim <%= i % 2 === 0 ? 'reveal-left' : 'reveal-right' %>">
                    <div class="promise-card-inner">
                        <div class="promise-icon-wrapper">
                            <span class="promise-icon"><%= p.icon %></span>
                            <div class="icon-glow"></div>
                        </div>
                        <div class="promise-content">
                            <div class="promise-number">Vow #<%= p.num %></div>
                            <h2 class="promise-title"><%= p.title %></h2>
                            <p class="promise-text"><%= p.text %></p>
                        </div>
                    </div>
                </div>
            <% }) %>
            </div>

        <a href="/love-letter" class="promise-next-btn" id="next-btn" style="display: none; text-decoration: none;">
            Continue to Next Chapter →
        </a>
    </div>

    <script>
        (function() {
            // ========== BG HEARTS ==========
            const heartsContainer = document.getElementById('bg-hearts-container');
            if (heartsContainer) {
                const emojis = ['❤️', '💖', '💕', '💗', '💓'];
                for (let i = 0; i < 20; i++) {
                    const h = document.createElement('div');
                    h.className = 'heart-bg';
                    h.innerText = emojis[Math.floor(Math.random() * emojis.length)];
                    h.style.left = Math.random() * 100 + '%';
                    h.style.fontSize = (Math.random() * 40 + 20) + 'px';
                    h.style.animationDuration = (Math.random() * 15 + 10) + 's';
                    h.style.animationDelay = Math.random() * 10 + 's';
                    heartsContainer.appendChild(h);
                }
            }

            // ========== SCROLL LOGIC ==========
            const progressBar = document.getElementById('promise-progress');
            const nextBtn = document.getElementById('next-btn');

            function handleScroll() {
                if (!progressBar) return;
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
                const pct = Math.round(scrolled);

                progressBar.style.width = pct + '%';
                
                if (nextBtn) {
                    if (pct > 85) {
                        nextBtn.style.display = 'flex';
                        setTimeout(() => nextBtn.classList.add('show'), 10);
                    } else {
                        nextBtn.classList.remove('show');
                        setTimeout(() => { if (!nextBtn.classList.contains('show')) nextBtn.style.display = 'none'; }, 500);
                    }
                }

                const revealItems = document.querySelectorAll('.promise-card, .promise-header');
                revealItems.forEach((item) => {
                    const rect = item.getBoundingClientRect();
                    if (rect.top < window.innerHeight * 0.85) {
                        item.classList.add('show-anim');
                    }
                });
            }

            window.addEventListener('scroll', handleScroll);
            handleScroll();

            // ========== MUSIC TOGGLE ==========
            const promMusicIcon = document.getElementById('promise-music-icon');
            const musicBtn = document.getElementById('music-toggle-btn');
            if (musicBtn) {
                musicBtn.addEventListener('click', () => {
                    const isPlaying = window.toggleMusic();
                    if (promMusicIcon) promMusicIcon.innerText = isPlaying ? '🎶' : '🎵';
                });
            }

            function syncMusicUI() {
                const audio = document.getElementById('global-audio');
                if (audio && promMusicIcon) {
                    const isPlaying = !audio.paused;
                    promMusicIcon.innerText = isPlaying ? '🎶' : '🎵';
                }
            }
            setTimeout(syncMusicUI, 100);

            // Barba cleanup
            barba.hooks.before(() => {
                window.removeEventListener('scroll', handleScroll);
            });
        })();
    </script>
</div>
<%- include('partials/footer') %>
