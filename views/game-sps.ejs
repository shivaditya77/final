<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="game-sps">
    <style>
        .game-body {
            min-height: 100vh;
            background: #0a0a0a;
            color: white;
            font-family: 'Poppins', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 100px;
            position: relative;
            overflow: hidden;
        }
        .game-bg {
            position: fixed; inset: 0;
            background: radial-gradient(circle at center, #1a1405 0%, #0a0a0a 100%);
            z-index: 0;
        }
        .game-container {
            position: relative; z-index: 10;
            text-align: center;
            width: 100%;
            max-width: 500px;
            padding: 20px;
        }
        .status-badge {
            background: rgba(255, 215, 0, 0.15);
            padding: 10px 20px;
            border-radius: 50px;
            border: 1px solid rgba(255, 215, 0, 0.3);
            margin-bottom: 30px;
            font-size: 0.9rem;
            color: #ffd700;
            display: inline-block;
        }
        .arena {
            display: flex;
            justify-content: space-around;
            align-items: center;
            margin: 40px 0;
            gap: 20px;
        }
        .player-hand {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }
        .hand-icon {
            font-size: 5rem;
            height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .player-label { font-size: 0.8rem; opacity: 0.6; text-transform: uppercase; letter-spacing: 2px; }
        
        .options {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 40px;
        }
        .option-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            width: 80px;
            height: 80px;
            border-radius: 20px;
            font-size: 2.5rem;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .option-btn:hover:not(:disabled) {
            background: rgba(255, 215, 0, 0.15);
            border-color: #ffd700;
            transform: translateY(-5px);
        }
        .option-btn.selected {
            background: #ffd700;
            border-color: #ffd700;
            color: #1a1405;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
        }
        .option-btn:disabled { opacity: 0.3; cursor: not-allowed; }

        .btn-play-again {
            background: linear-gradient(135deg, #ffd700, #daa520);
            border: none; color: #1a1405; padding: 12px 30px;
            border-radius: 50px; font-weight: 700; cursor: pointer;
            transition: all 0.3s;
            margin-top: 30px;
            display: none;
        }
        
        .btn-emergency {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: rgba(255, 255, 255, 0.6);
            padding: 10px 25px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 20px;
        }
        .btn-emergency:hover { background: rgba(255, 215, 0, 0.1); border-color: #ffd700; color: white; }

        .waiting-text {
            font-size: 0.8rem;
            color: #ffd700;
            margin-top: 10px;
            height: 20px;
        }

        /* Animations */
        .shake { animation: shakeHand 0.5s infinite; }
        @keyframes shakeHand {
            0%, 100% { transform: translateY(0) rotate(0); }
            50% { transform: translateY(-20px) rotate(-10deg); }
        }
    </style>

    <div class="game-body">
        <div class="game-bg"></div>
        <%- include('partials/navbar') %>

        <div class="game-container">
            <div class="status-badge" id="status-text">Pick your move! ✊✋✌️</div>

            <div class="arena">
                <div class="player-hand">
                    <div class="hand-icon" id="my-hand">✊</div>
                    <div class="player-label">YOU</div>
                </div>
                <div class="player-hand">
                    <div class="hand-icon" id="opp-hand">✊</div>
                    <div class="player-label" id="opp-name"><%= otherUser %></div>
                </div>
            </div>

            <div class="waiting-text" id="waiting-msg"></div>

            <div class="options">
                <button class="option-btn" onclick="makeMove('stone', '✊')">✊</button>
                <button class="option-btn" onclick="makeMove('paper', '✋')">✋</button>
                <button class="option-btn" onclick="makeMove('scissors', '✌️')">✌️</button>
            </div>

            <button class="btn-play-again" id="play-again-btn" onclick="resetGame()">Play Again! 🔄</button>
            <br>
            <button class="btn-emergency" onclick="window.emergencyReset()">🔄 Stuck? Emergency Reset</button>
        </div>
    </div>

    <script>
        (function() {
            const username = "<%= username %>";
            const otherUser = "<%= otherUser %>";
            const channelName = 'private-notifications-' + username.toLowerCase();
            
            let myMove = null;
            let oppMove = null;
            let gameEnded = false;

            const myHandEl = document.getElementById('my-hand');
            const oppHandEl = document.getElementById('opp-hand');
            const statusText = document.getElementById('status-text');
            const waitingMsg = document.getElementById('waiting-msg');
            const playAgainBtn = document.getElementById('play-again-btn');
            const optionBtns = document.querySelectorAll('.option-btn');

            function initGameSync() {
                if (!window.globalPusher) return setTimeout(initGameSync, 500);
                const channel = window.globalPusher.subscribe(channelName);
                
                channel.unbind('sps-move');
                channel.unbind('sps-reset');

                channel.bind('sps-move', (data) => {
                    if (data.from.toLowerCase() === otherUser.toLowerCase()) {
                        oppMove = data.move;
                        if (myMove) revealResult();
                        else {
                            waitingMsg.innerHTML = `<span style="color: #00ffcc">✨ ${otherUser} has picked!</span> Your turn...`;
                            oppHandEl.classList.add('shake');
                        }
                    }
                });

                channel.bind('sps-reset', (data) => {
                    location.reload();
                });
            }

            window.makeMove = async (move, icon) => {
                if (gameEnded || myMove) return;
                
                myMove = move;
                
                optionBtns.forEach(btn => {
                    btn.classList.remove('selected');
                    if (btn.innerText === icon) btn.classList.add('selected');
                    btn.disabled = true;
                });

                myHandEl.classList.add('shake');
                waitingMsg.innerText = "Waiting for " + otherUser + "... ⌛";

                if (navigator.vibrate) navigator.vibrate(50);

                try {
                    await fetch('/api/games/sps/move', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ move, to: otherUser })
                    });
                } catch (e) {}

                if (oppMove) revealResult();
            };

            function revealResult() {
                if (gameEnded) return;
                gameEnded = true;
                
                myHandEl.classList.remove('shake');
                oppHandEl.classList.remove('shake');
                waitingMsg.innerText = "";

                const icons = { 'stone': '✊', 'paper': '✋', 'scissors': '✌️' };
                
                gsap.to([myHandEl, oppHandEl], {
                    scale: 1.5,
                    duration: 0.3,
                    yoyo: true,
                    repeat: 1,
                    onComplete: () => {
                        myHandEl.innerText = icons[myMove];
                        oppHandEl.innerText = icons[oppMove];
                        
                        let result = "";
                        let color = "#ffd700";
                        if (myMove === oppMove) {
                            result = "It's a Tie! 🤝";
                        } else if (
                            (myMove === 'stone' && oppMove === 'scissors') ||
                            (myMove === 'paper' && oppMove === 'stone') ||
                            (myMove === 'scissors' && oppMove === 'paper')
                        ) {
                            result = "🎉 You Won! 🏆";
                            color = "#00ffcc";
                            confettiEffect();
                        } else {
                            result = "💔 " + otherUser + " Won!";
                            color = "#ff4d6d";
                        }

                        statusText.innerText = result;
                        statusText.style.color = color;
                        playAgainBtn.style.display = 'inline-block';
                    }
                });
            }

            function confettiEffect() {
                for(let i=0; i<20; i++) {
                    const c = document.createElement('div');
                    c.innerText = '✨';
                    c.style.cssText = `position:fixed;left:${50 + (Math.random()-0.5)*100}%;top:50%;pointer-events:none;z-index:9999;`;
                    document.body.appendChild(c);
                    gsap.to(c, {
                        y: -100 - Math.random()*200,
                        x: (Math.random()-0.5)*400,
                        opacity: 0,
                        duration: 1 + Math.random(),
                        onComplete: () => c.remove()
                    });
                }
            }

            window.resetGame = async () => {
                try {
                    await fetch('/api/games/sps/reset', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ to: otherUser })
                    });
                } catch (e) {}
                location.reload();
            };

            window.emergencyReset = async function() {
                if (!confirm("This will reload the game for BOTH players. Continue?")) return;
                try {
                    await fetch('/api/games/sps/reset', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ to: otherUser })
                    });
                    location.reload(); // Reload locally after sending signal
                } catch (e) { location.reload(); }
            };

            initGameSync();
        })();
    </script>
</div>
<%- include('partials/footer') %>
