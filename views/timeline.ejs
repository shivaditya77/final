<%- include('partials/header') %>
<div data-barba="container" data-barba-namespace="timeline">
    <link rel="stylesheet" href="/css/Timeline.css">
    <div class="timeline-body">
        <!-- Netflix Intro -->
        <div class="netflix-intro" id="netflix-intro">
            <div class="netflix-logo">
                <div class="logo-line">✨ OUR JOURNEY ✨</div>
                <div class="logo-sub">A LOVE STORY</div>
            </div>
        </div>

        <div class="timeline-vignette"></div>
        <div class="timeline-grain"></div>
        <div class="timeline-progress-bar" id="timeline-progress"></div>
        <div class="timeline-scroll-progress" id="timeline-pct">0%</div>

        <!-- Navigation -->
        <div class="nav-container">
            <a href="/" class="nav-btn" style="text-decoration: none;">
                <span>🏠</span><span class="nav-text">Home</span>
            </a>
            <div class="nav-btn" id="music-toggle" style="cursor: pointer;">
                <span id="music-icon">🎶</span><span class="nav-text" id="music-status">On</span>
            </div>
            <a href="/logout" class="nav-btn premium-logout" style="text-decoration: none;" onclick="return confirm('Are you sure you want to logout? ❤️')" data-barba-prevent="true">
                <span>💋</span><span class="nav-text">Logout</span>
            </a>
        </div>

        <!-- Hero Section -->
        <div class="hero-timeline">
            <div class="hero-content">
                <h1>Our Journey ✨</h1>
                <p>Every moment that brought us here...</p>
            </div>
            <div class="hero-scroll">
                <span>Scroll to relive our story</span>
                <div class="scroll-arrow">↓</div>
            </div>
        </div>

        <!-- Timeline Container -->
        <div class="timeline-container" id="timeline-container">
            <% 
            const timelineData = [
                { date: '8th February 2026', story: 'The day I saw you for the first time… and something inside me quietly said, "this is different". Maybe it was love at first sight.', side: 'right' },
                { date: '9th February 2026', story: "That's when we actually started talking, turning a moment into a connection.", side: 'left' },
                { date: '14th February 2026', story: "We spent the entire Valentine's night together… yet like strangers, hiding what we didn't fully understand yet.", side: 'right' },
                { date: '15th February 2026', story: 'We stayed awake all night, feeling something for each other… but also believing it might never be possible.', side: 'left' },
                { date: '21st February 2026', story: 'The day we finally confessed what our hearts had been holding back.', side: 'right' },
                { date: '22nd February 2026', story: "When you sent me your photo for the first time… and I couldn't stop smiling.", side: 'left' },
                { date: '2nd March 2026', story: 'The day you shared your past with complete honesty… and somehow, it made me fall for you even more deeply.', side: 'right' },
                { date: '4th March 2026 (Holi)', story: 'The day I looked at you and felt like I had the most beautiful girlfriend in the world.', side: 'left' },
                { date: '13th March 2026', story: 'The day I started calling you "Bhondu", and it became something special between us.', side: 'right' },
                { date: '7th April 2026', story: 'When you surprised me on my birthday… the cake, the brownies, that video, and the playlist — everything made me feel truly loved.', side: 'left' },
                { date: '20th April 2026', story: 'The day I got my Accenture Kolkata location… and wished you were right there to celebrate with me.', side: 'right' },
                { date: '9th June 2026', story: 'Happy Birthday, Bhondu… because loving you is something I want to celebrate every day. ❤️', side: 'left' }
            ];
            %>

            <% timelineData.forEach(item => { %>
                <div class="timeline-item">
                    <% if (item.side === 'left') { %>
                        <div class="timeline-left">
                            <div class="timeline-card">
                                <div class="timeline-date">📅 <%= item.date %></div>
                                <div class="timeline-story"><%= item.story %></div>
                                <div class="card-heart">❤️</div>
                            </div>
                        </div>
                        <div class="timeline-right"></div>
                    <% } else { %>
                        <div class="timeline-left"></div>
                        <div class="timeline-right">
                            <div class="timeline-card">
                                <div class="timeline-date">📅 <%= item.date %></div>
                                <div class="timeline-story"><%= item.story %></div>
                                <div class="card-heart">❤️</div>
                            </div>
                        </div>
                    <% } %>
                    <div class="timeline-dot"></div>
                </div>
            <% }) %>
        </div>

        <a href="/reasons" class="timeline-next-btn" style="text-decoration: none;">Continue to 100 Reasons →</a>
    </div>

    <script>
        (function() {
            // ========== INTRO ==========
            const intro = document.getElementById('netflix-intro');
            if (intro) {
                setTimeout(() => {
                    if (intro) {
                        intro.style.opacity = '0';
                        setTimeout(() => intro.remove(), 1000);
                    }
                }, 2500);
            }

            // ========== SCROLL LOGIC ==========
            const progressBar = document.getElementById('timeline-progress');
            const scrollPctText = document.getElementById('timeline-pct');

            function handleScroll() {
                if (!progressBar) return;
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const scrolled = (winScroll / height) * 100;
                const pct = Math.round(scrolled);

                if (progressBar) progressBar.style.width = pct + '%';
                if (scrollPctText) scrollPctText.innerText = pct + '%';

                const items = document.querySelectorAll('.timeline-item');
                items.forEach((item) => {
                    const rect = item.getBoundingClientRect();
                    if (rect.top < window.innerHeight * 0.8) {
                        item.classList.add('show');
                    }
                });
            }

            window.addEventListener('scroll', handleScroll);
            handleScroll();

            // ========== MUSIC TOGGLE ==========
            const musicToggle = document.getElementById('music-toggle');
            const musicIcon = document.getElementById('music-icon');
            const musicStatus = document.getElementById('music-status');

            if (musicToggle) {
                musicToggle.addEventListener('click', () => {
                    const isPlaying = window.toggleMusic();
                    if (musicIcon) musicIcon.innerText = isPlaying ? '🎶' : '🎵';
                    if (musicStatus) musicStatus.innerText = isPlaying ? 'On' : 'Off';
                });
            }

            function syncMusicUI() {
                const audio = document.getElementById('global-audio');
                if (audio && musicIcon && musicStatus) {
                    const isPlaying = !audio.paused;
                    musicIcon.innerText = isPlaying ? '🎶' : '🎵';
                    musicStatus.innerText = isPlaying ? 'On' : 'Off';
                }
            }
            setTimeout(syncMusicUI, 100);

            // Barba cleanup
            barba.hooks.before(() => {
                window.removeEventListener('scroll', handleScroll);
            });
        })();
    </script>
</div>
<%- include('partials/footer') %>
