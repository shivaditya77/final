<div id="global-music-container" style="display:none;">
    <audio id="global-audio" loop></audio>
</div>

<script>
    const musicMap = {
        '/': '/assets/music.mp3',
        '/memories': '/assets/romantic-music.mp3',
        '/promise': '/assets/romantic-music.mp3',
        '/love-letter': '/assets/romantic-music1.mp3',
        '/questions': '/assets/romantic-music2.mp3',
        '/timeline': '/assets/romantic-music2.mp3',
        '/reasons': '/assets/romantic-music1.mp3',
        '/voice-memory': '/assets/romantic-music.mp3',
        '/outfit': '/assets/romantic-music.mp3',
        '/future-plans': '/assets/romantic-music3.mp3',
    };

    const audio = document.getElementById('global-audio');
    const path = window.location.pathname;
    const track = musicMap[path];

    function initMusic() {
        const isMuted = localStorage.getItem('musicMuted') === 'true';
        const savedTime = localStorage.getItem('musicTime');
        const savedTrack = localStorage.getItem('musicTrack');

        if (track) {
            if (savedTrack === track && savedTime) {
                audio.src = track;
                audio.currentTime = parseFloat(savedTime);
            } else {
                audio.src = track;
            }
            
            audio.volume = 0.3;
            
            if (!isMuted) {
                audio.play().catch(() => {
                    console.log('Autoplay blocked. Waiting for interaction.');
                    document.addEventListener('click', () => {
                        audio.play();
                    }, { once: true });
                });
            }
        } else {
            audio.pause();
        }
    }

    // Save state before leave
    window.addEventListener('beforeunload', () => {
        localStorage.setItem('musicTime', audio.currentTime);
        localStorage.setItem('musicTrack', audio.src.replace(window.location.origin, ''));
    });

    // Global toggle function
    window.toggleMusic = function() {
        if (audio.paused) {
            audio.play();
            localStorage.setItem('musicMuted', 'false');
            return true;
        } else {
            audio.pause();
            localStorage.setItem('musicMuted', 'true');
            return false;
        }
    };

    window.updateMusicTrack = function(path) {
        const track = musicMap[path];
        const isMuted = localStorage.getItem('musicMuted') === 'true';
        
        if (track) {
            // Only change if track is different
            const currentTrack = audio.src.replace(window.location.origin, '');
            if (currentTrack !== track) {
                audio.src = track;
                audio.volume = 0.3;
                if (!isMuted) {
                    audio.play().catch(() => {});
                }
            }
        } else {
            audio.pause();
        }
    };

    initMusic();
</script>
