<!-- Navigation Bar Partial -->
<div class="nav-container">
    <div class="nav-btn status-btn" id="partner-status-btn" style="cursor: default;">
        <span class="status-dot" id="global-status-dot"></span>
        <span class="nav-text" id="global-status-text">
            <%= (typeof username !== 'undefined' && username.toLowerCase() === 'bhondu') ? 'Vishu' : 'Bhondu' %>: Offline
        </span>
    </div>
    <a href="/" class="nav-btn" style="text-decoration: none;">
        <span>🏠</span><span class="nav-text">Home</span>
    </a>
    
    <div class="nav-btn notification-bell-btn" id="notif-bell" style="cursor: pointer; position: relative;">
        <span class="bell-icon">🔔</span>
        <div class="notif-badge" id="notif-badge" style="display: none;">0</div>
    </div>

    <% if (typeof showMusic !== 'undefined' && showMusic) { %>
    <div class="nav-btn" id="music-toggle" style="cursor: pointer;">
        <span id="music-icon">🎶</span><span class="nav-text" id="music-status">On</span>
    </div>
    <% } %>

    <div class="nav-btn biometric-btn" id="biometric-setup-btn" style="cursor: pointer; display: none; background: rgba(255, 77, 109, 0.2); border-color: #ff4d6d;">
        <span>☝️</span><span class="nav-text">Enable FaceID</span>
    </div>


    <a href="/logout" class="nav-btn premium-logout" style="text-decoration: none;" onclick="confirmLogout(event)" data-barba-prevent="true">
        <span>💋</span><span class="nav-text">Logout</span>
    </a>
</div>

<!-- PROFESSIONAL GLOBAL NOTIFICATION PORTAL (Moved outside nav-container to fix stacking issues) -->
<div class="notif-dropdown" id="notif-dropdown">
    <div class="notif-header">
        <span>Notifications</span>
        <button onclick="markAllRead(event)">Mark all read</button>
    </div>
    <div class="notif-list" id="notif-list">
        <div class="notif-empty">No notifications yet ❤️</div>
    </div>
    <div class="notif-footer">
        <button onclick="clearNotifications(event)">Clear All</button>
    </div>
</div>

<style>
.nav-container {
    position: fixed;
    top: 20px;
    right: 20px;
    display: flex;
    gap: 12px;
    z-index: 1000;
}

.nav-btn {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 10px 18px;
    border-radius: 50px;
    color: white;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.nav-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.4);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
}

/* NOTIFICATION DROPDOWN */
.notif-dropdown {
    position: fixed;
    top: 80px;
    right: 20px;
    width: 320px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 16px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.6);
    display: none;
    flex-direction: column;
    overflow: hidden;
    animation: slideDown 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 9999; /* Top level */
}

.notif-dropdown.show {
    display: flex;
}

@keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
}

.notif-header {
    padding: 14px 16px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 700;
}

.notif-header button {
    background: none;
    border: none;
    color: #ff4d6d;
    font-size: 0.75rem;
    cursor: pointer;
    font-weight: 600;
}

.notif-list {
    max-height: 400px;
    overflow-y: auto;
}

.notif-item {
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    display: flex;
    gap: 12px;
    transition: background 0.2s;
    cursor: pointer;
    text-decoration: none;
    color: white;
}

.notif-item:hover {
    background: rgba(255,255,255,0.05);
}

.notif-item.unread {
    background: rgba(255, 77, 109, 0.05);
}

.notif-item-icon {
    font-size: 1.2rem;
    margin-top: 2px;
}

.notif-item-content {
    flex: 1;
}

.notif-item-title {
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 2px;
}

.notif-item-desc {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.3;
}

.notif-item-time {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    margin-top: 4px;
}

.notif-empty {
    padding: 30px 20px;
    text-align: center;
    font-size: 0.85rem;
    opacity: 0.5;
}

.notif-footer {
    padding: 10px;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.1);
}

.notif-footer button {
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 0.75rem;
    cursor: pointer;
}

.status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #555;
    box-shadow: 0 0 5px rgba(0,0,0,0.5);
}

.status-dot.online {
    background: #00ffcc;
    box-shadow: 0 0 10px rgba(0, 255, 204, 0.8);
    animation: pulse-green 2s infinite;
}

@keyframes pulse-green {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 255, 204, 0.7); }
    70% { transform: scale(1.1); box-shadow: 0 0 0 10px rgba(0, 255, 204, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0, 255, 204, 0); }
}

@media (max-width: 768px) {
    .nav-container { top: 10px; right: 10px; gap: 8px; }
    .status-btn .nav-text { display: none; }
    .nav-text { display: none; }
    .nav-btn { padding: 10px; }
    .notif-dropdown { 
        top: 70px !important; 
        left: 5% !important; 
        right: 5% !important;
        width: 90% !important; 
        max-width: none !important;
        border-radius: 20px !important;
    }
}
</style>

<script>
(function() {
    const bell = document.getElementById('notif-bell');
    const dropdown = document.getElementById('notif-dropdown');
    const badge = document.getElementById('notif-badge');
    const list = document.getElementById('notif-list');
    
    // Status Elements
    const globalStatusDot = document.getElementById('global-status-dot');
    const globalStatusText = document.getElementById('global-status-text');
    const otherUser = "<%= (typeof username !== 'undefined' && username.toLowerCase() === 'bhondu') ? 'Vishu' : 'Bhondu' %>";
    
    function updateGlobalStatus(isOnline) {
        if (globalStatusDot) globalStatusDot.classList.toggle('online', isOnline);
        if (globalStatusText) {
            globalStatusText.innerText = `${otherUser}: ${isOnline ? 'Online ❤️' : 'Offline 💔'}`;
            globalStatusText.style.color = isOnline ? '#00ffcc' : 'rgba(255,255,255,0.6)';
        }
    }

    // Connect to globalChannel defined in header
    function initStatusTracking() {
        if (window.globalChannel) {
            const channel = window.globalChannel;
            
            // UNBIND first to avoid duplicates on Barba transitions
            channel.unbind('pusher:subscription_succeeded');
            channel.unbind('pusher:member_added');
            channel.unbind('pusher:member_removed');

            channel.bind('pusher:subscription_succeeded', (members) => {
                // If count > 1, it means both are here (presence channel includes self)
                updateGlobalStatus(members.count > 1);
            });

            channel.bind('pusher:member_added', (member) => {
                // Only care if the ADDED member is the OTHER person
                if (member.id.toLowerCase() === otherUser.toLowerCase()) {
                    updateGlobalStatus(true);
                }
            });

            channel.bind('pusher:member_removed', (member) => {
                // Only care if the REMOVED member is the OTHER person
                if (member.id.toLowerCase() === otherUser.toLowerCase()) {
                    updateGlobalStatus(false);
                }
            });
        } else {
            // Retry if channel not ready yet
            setTimeout(initStatusTracking, 1000);
        }
    }

    initStatusTracking();
    
    const notifSound = new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3');

    if (bell) {
        bell.addEventListener('click', (e) => {
            e.stopPropagation();
            dropdown.classList.toggle('show');
            if (dropdown.classList.contains('show')) fetchNotifications();
        });
    }

    document.addEventListener('click', () => {
        if (dropdown) dropdown.classList.remove('show');
    });

    async function fetchNotifications() {
        try {
            const res = await fetch('/api/notifications');
            const data = await res.json();
            if (data.success) {
                renderNotifications(data.notifications);
                updateBadge(data.unreadCount);
            }
        } catch (e) {}
    }

    function renderNotifications(notifications) {
        if (!list) return;
        if (notifications.length === 0) {
            list.innerHTML = '<div class="notif-empty">No notifications yet ❤️</div>';
            return;
        }
        list.innerHTML = notifications.map(n => `
            <a href="${n.link || '#'}" class="notif-item ${n.isRead ? '' : 'unread'}" onclick="markOneRead('${n._id}')">
                <div class="notif-item-icon">${getIcon(n.type)}</div>
                <div class="notif-item-content">
                    <div class="notif-item-title">${n.sender}</div>
                    <div class="notif-item-desc">${n.content}</div>
                    <div class="notif-item-time">${formatTime(n.createdAt)}</div>
                </div>
            </a>
        `).join('');
    }

    function getIcon(type) {
        switch(type) {
            case 'message': return '💬';
            case 'reaction': return '❤️';
            case 'call': return '📞';
            default: return '✨';
        }
    }

    function formatTime(dateStr) {
        const date = new Date(dateStr);
        return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function updateBadge(count) {
        if (!badge) return;
        if (count > 0) {
            badge.innerText = count > 9 ? '9+' : count;
            badge.style.display = 'flex';
        } else {
            badge.style.display = 'none';
        }
    }

    window.markAllRead = async (e) => {
        e.stopPropagation();
        try {
            await fetch('/api/notifications/read-all', { method: 'POST' });
            fetchNotifications();
        } catch (e) {}
    };

    window.markOneRead = async (id) => {
        try {
            await fetch('/api/notifications/mark-read', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
        } catch (e) {}
    };

    window.clearNotifications = async (e) => {
        e.stopPropagation();
        if (!confirm('Clear all notifications?')) return;
        try {
            await fetch('/api/notifications/clear', { method: 'DELETE' });
            fetchNotifications();
        } catch (e) {}
    };

    // Pusher Real-time Notifications
    if (window.globalPusher) {
        const username = "<%= typeof username !== 'undefined' ? username : '' %>";
        if (username) {
            const channel = window.globalPusher.subscribe('private-notifications-' + username.toLowerCase());
            channel.bind('new-notification', (data) => {
                notifSound.play().catch(() => {});
                fetchNotifications();
                showBrowserNotification(data);
            });
        }
    }

    function showBrowserNotification(data) {
        if (!("Notification" in window)) return;
        if (Notification.permission === "granted") {
            new Notification(`New from ${data.sender}`, {
                body: data.content,
                icon: '/favicon.ico'
            });
        } else if (Notification.permission !== "denied") {
            Notification.requestPermission();
        }
    }

    // Initial load
    setTimeout(fetchNotifications, 2000);

    // ========== SERVICE WORKER & PUSH REGISTRATION ==========
    if ('serviceWorker' in navigator && 'PushManager' in window) {
        window.addEventListener('load', async () => {
            try {
                const registration = await navigator.serviceWorker.register('/sw.js');
                console.log('SW registered:', registration);
                
                const username = "<%= typeof username !== 'undefined' ? username : '' %>";
                if (username) {
                    subscribeUserToPush(registration);
                }
            } catch (err) { console.error('SW registration failed:', err); }
        });
    }

    async function subscribeUserToPush(registration) {
        try {
            const publicVapidKey = "<%= process.env.VAPID_PUBLIC_KEY || '' %>";
            if (!publicVapidKey) return;

            const subscription = await registration.pushManager.subscribe({
                userVisibleOnly: true,
                applicationServerKey: urlBase64ToUint8Array(publicVapidKey)
            });

            await fetch('/api/notifications/subscribe', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ subscription })
            });
            console.log('User is subscribed to Push.');
        } catch (err) { console.log('Push subscription failed:', err); }
    }

    function urlBase64ToUint8Array(base64String) {
        const padding = '='.repeat((4 - base64String.length % 4) % 4);
        const base64 = (base64String + padding).replace(/\-/g, '+').replace(/_/g, '/');
        const rawData = window.atob(base64);
        const outputArray = new Uint8Array(rawData.length);
        for (let i = 0; i < rawData.length; ++i) {
            outputArray[i] = rawData.charCodeAt(i);
        }
        return outputArray;
    }
    
    // ========== BIOMETRIC SETUP LOGIC ==========
    const bioBtn = document.getElementById('biometric-setup-btn');
    if (bioBtn && window.PublicKeyCredential && window.PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable) {
        PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable().then(available => {
            if (available) bioBtn.style.display = 'flex';
        });

        bioBtn.addEventListener('click', async () => {
            try {
                const { startRegistration } = await import('https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.es5.umd.min.js');
                
                bioBtn.innerText = 'Setting up...';
                const resp = await fetch('/api/passkey/register-options');
                const options = await resp.json();

                const regResp = await startRegistration(options);

                const verifyResp = await fetch('/api/passkey/register-verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(regResp),
                });

                const result = await verifyResp.json();
                if (result.success) {
                    alert('🎉 Biometric Login Enabled! You can now log in with FaceID/Fingerprint next time.');
                    bioBtn.style.display = 'none';
                } else {
                    alert('❌ Setup failed: ' + result.error);
                    bioBtn.innerHTML = '<span>☝️</span><span class="nav-text">Retry FaceID</span>';
                }
            } catch (err) {
                console.error(err);
                alert('❌ Error: ' + err.message);
                bioBtn.innerHTML = '<span>☝️</span><span class="nav-text">Enable FaceID</span>';
            }
        });
    }
})();
</script>

