<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soul Connect ❤️</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:wght@300;400;500;600;700&family=Dancing+Script:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Global CSS -->
    <link rel="stylesheet" href="/css/main.css?v=1.0.3">
    <link rel="stylesheet" href="/css/app.css?v=1.0.3">
    <link rel="stylesheet" href="/css/VideoCall.css?v=1.0.3">
    
    <!-- Page Specific CSS (Managed via Barba containers) -->
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Barba.js & GSAP for Smooth Transitions -->
    <script src="https://unpkg.com/@barba/core"></script>
    <script src="https://unpkg.com/@barba/prefetch"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
    
    <!-- Global Notifications -->
    <link rel="stylesheet" href="/css/Notifications.css">
    <script src="/js/notifications.js" defer></script>

    <script src="/js/logout.js"></script>
    <script>
        window.PUSHER_KEY = "<%= typeof pusherKey !== 'undefined' ? pusherKey : '' %>";
        window.PUSHER_CLUSTER = "<%= typeof pusherCluster !== 'undefined' ? pusherCluster : '' %>";
        window.CURRENT_USER = "<%= typeof username !== 'undefined' ? username : '' %>";

        function initGlobalPusher() {
            if (!window.PUSHER_KEY || window.PUSHER_KEY === "") {
                console.error("🔥 Chat Engine: PUSHER_KEY is missing!");
                return null;
            }
            
            if (!window.globalPusher) {
                console.log("Initializing Global Pusher...");
                
                const cluster = window.PUSHER_CLUSTER || 'ap2';

                window.globalPusher = new Pusher(window.PUSHER_KEY, {
                    cluster: cluster,
                    forceTLS: true,
                    enabledTransports: ['ws', 'xhr_streaming', 'xhr_polling'],
                    authEndpoint: '/pusher/auth'
                });

                window.globalChannel = window.globalPusher.subscribe('presence-soul-connect');

                // Connection State Logging
                window.globalPusher.connection.bind('state_change', (states) => {
                    console.log(`📡 Pusher State: ${states.previous} -> ${states.current}`);
                });

                window.addEventListener('focus', () => {
                    if (window.globalPusher && window.globalPusher.connection.state === 'disconnected') {
                        window.globalPusher.connect();
                    }
                });
            }
            return window.globalPusher;
        }

        // Auto-init on page load
        document.addEventListener('DOMContentLoaded', () => {
            initGlobalPusher();
        });
    </script>
</head>
<body data-barba="wrapper">
    <!-- Global Notification Container -->
    <div id="global-notification-container" class="notification-container"></div>

    <!-- Transition Overlay -->
    <div class="transition-overlay"></div>
    
    <div id="app-root">
