    </div> <!-- end #app-root -->
    
    <!-- Music Player -->
    <%- include('music') %>

    <!-- Global Scripts -->
    <script>
        // ========== BARBA.JS INITIALIZATION ==========
        barba.use(barbaPrefetch);

        barba.init({
            prefetch: true,
            sync: true,
            transitions: [{
                name: 'pro-ghost-slide',
                async leave(data) {
                    // Start blurring and fading the current page
                    return gsap.to(data.current.container, {
                        duration: 0.4,
                        opacity: 0,
                        filter: 'blur(15px)',
                        scale: 0.96,
                        ease: 'power2.in'
                    });
                },
                async enter(data) {
                    // Update Background Music Track
                    if (window.updateMusicTrack) {
                        window.updateMusicTrack(window.location.pathname);
                    }

                    // Morph Body Background based on destination
                    const path = window.location.pathname;
                    let targetBg = '#0a0a0a';
                    if (path.includes('journal')) targetBg = '#0f0c29';
                    else if (path.includes('chat')) targetBg = '#1a1405';
                    else if (path.includes('memories')) targetBg = '#1a0b0f';
                    
                    gsap.to('body', {
                        backgroundColor: targetBg,
                        duration: 0.6,
                        ease: 'power2.out'
                    });

                    // Prepare next container
                    gsap.set(data.next.container, {
                        opacity: 0,
                        filter: 'blur(15px)',
                        scale: 1.04
                    });

                    window.scrollTo(0, 0);

                    // Re-run scripts
                    const scripts = data.next.container.querySelectorAll('script');
                    scripts.forEach(script => {
                        const newScript = document.createElement('script');
                        Array.from(script.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                        newScript.appendChild(document.createTextNode(script.innerHTML));
                        script.parentNode.replaceChild(newScript, script);
                    });

                    // Snappy fade and focus
                    return gsap.to(data.next.container, {
                        duration: 0.5,
                        opacity: 1,
                        filter: 'blur(0px)',
                        scale: 1,
                        ease: 'power3.out',
                        clearProps: 'all'
                    });
                }
            }]
        });

        // Ensure initial page scripts run (Barba doesn't handle the very first load)
        // document.addEventListener('DOMContentLoaded', () => { ... }); // Browser does this naturally
    </script>
</body>
</html>
