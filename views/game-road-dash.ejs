<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Bhondu Road Dash | Combat Racing</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;600;900&family=Syncopate:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://js.pusher.com/8.0.1/pusher.min.js"></script>
    <style>
        :root {
            --neon-pink: #ff2d55;
            --neon-cyan: #00f2ff;
            --neon-yellow: #ffcc00;
            --bg-dark: #08080a;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-dark);
            color: white;
            overflow: hidden;
            height: 100dvh;
            touch-action: none;
        }

        #game-container {
            position: relative;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at center, #1a1a2e 0%, #08080a 100%);
        }

        canvas {
            display: block;
            background: #111;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
            max-width: 100%;
            max-height: 100%;
        }

        /* UI Elements */
        .hud {
            position: absolute;
            top: 20px;
            width: 90%;
            display: flex;
            justify-content: space-between;
            pointer-events: none;
            z-index: 100;
        }

        .stat-box {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            padding: 10px 20px;
            border-radius: 15px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .stat-label { font-size: 0.6rem; opacity: 0.6; text-transform: uppercase; letter-spacing: 1px; }
        .stat-val { font-family: 'Syncopate', sans-serif; font-size: 1.2rem; color: var(--neon-cyan); }

        .controls-hint {
            position: absolute;
            bottom: 30px;
            width: 100%;
            text-align: center;
            opacity: 0.4;
            font-size: 0.8rem;
            pointer-events: none;
        }

        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.9);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            text-align: center;
            padding: 20px;
        }

        .title {
            font-family: 'Syncopate', sans-serif;
            font-size: 3rem;
            background: linear-gradient(to right, var(--neon-pink), var(--neon-cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .btn-start {
            background: white;
            color: black;
            border: none;
            padding: 15px 50px;
            border-radius: 40px;
            font-weight: 900;
            font-size: 1.1rem;
            cursor: pointer;
            margin-top: 30px;
            box-shadow: 0 10px 30px rgba(255,255,255,0.2);
        }

        .kick-btn {
            position: absolute;
            bottom: 40px;
            right: 20px;
            width: 80px;
            height: 80px;
            background: rgba(255, 45, 85, 0.2);
            border: 2px solid var(--neon-pink);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            z-index: 200;
            cursor: pointer;
        }
        .kick-btn:active { transform: scale(0.9); background: var(--neon-pink); }

        .powerup-toast {
            position: absolute;
            top: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--neon-yellow);
            color: black;
            padding: 5px 15px;
            border-radius: 10px;
            font-weight: 900;
            font-size: 0.8rem;
            display: none;
            z-index: 300;
        }

        .back-btn { position: absolute; top: 20px; left: 20px; color: white; opacity: 0.5; text-decoration: none; z-index: 200; }
    </style>
</head>
<body>
    <div id="game-container">
        <a href="/games" class="back-btn">← EXIT</a>
        
        <div class="hud">
            <div class="stat-box">
                <div class="stat-label">Distance</div>
                <div class="stat-val" id="distVal">0m</div>
            </div>
            <div class="stat-box" style="text-align: right;">
                <div class="stat-label">Rank</div>
                <div class="stat-val" id="rankVal" style="color: var(--neon-pink);">2nd</div>
            </div>
        </div>

        <canvas id="gameCanvas"></canvas>

        <div class="kick-btn" id="kickBtn">🤜</div>
        <div class="powerup-toast" id="powerToast">TURBO!</div>

        <div class="controls-hint">Steer: Tap Sides • Battle: Kick Button</div>

        <div class="overlay" id="startOverlay">
            <h1 class="title">ROAD DASH</h1>
            <p style="opacity: 0.6; max-width: 300px;">Race through traffic. Kick your partner. Win the glory.</p>
            <button class="btn-start" id="startBtn" onclick="startGame()">START RACE</button>
        </div>

        <div class="overlay" id="endOverlay" style="display: none;">
            <h1 id="endTitle" style="font-size: 4rem; margin-bottom: 10px;">CRASHED!</h1>
            <p id="endSub" style="margin-bottom: 40px; opacity: 0.7;">You were kicked off the road.</p>
            <button class="btn-start" onclick="location.reload()">TRY AGAIN</button>
        </div>
    </div>

    <!-- Audio Assets -->
    <audio id="snd-engine" src="https://assets.mixkit.co/active_storage/sfx/2571/2571-preview.mp3" loop></audio>
    <audio id="snd-kick" src="https://assets.mixkit.co/active_storage/sfx/2658/2658-preview.mp3"></audio>
    <audio id="snd-crash" src="https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3"></audio>
    <audio id="snd-powerup" src="https://assets.mixkit.co/active_storage/sfx/2004/2004-preview.mp3"></audio>
    <audio id="snd-whoosh" src="https://assets.mixkit.co/active_storage/sfx/270/270-preview.mp3"></audio>
    <audio id="snd-turbo" src="https://assets.mixkit.co/active_storage/sfx/2242/2242-preview.mp3"></audio>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const username = "<%= username %>";
        const otherUser = "<%= otherUser %>";
        
        // Game Settings
        const ROAD_WIDTH = 400;
        const LANE_COUNT = 3;
        const LANE_WIDTH = ROAD_WIDTH / LANE_COUNT;
        
        let width, height;
        let gameActive = false;
        let distance = 0;
        let speed = 0;
        let maxSpeed = 12;
        let roadOffset = 0;
        let shake = 0;
        
        const player = { x: ROAD_WIDTH/2, y: 0, targetX: ROAD_WIDTH/2, lane: 1, color: '#00f2ff', emoji: '🏍️', name: username, crashed: false, shield: 0, turbo: 0 };
        const opponent = { x: ROAD_WIDTH/2, y: 0, targetX: ROAD_WIDTH/2, lane: 1, color: '#ff2d55', emoji: '🏍️', name: otherUser, crashed: false, shield: 0, turbo: 0 };
        let traffic = [];
        let particles = [];
        let powerups = [];

        // Pusher Setup
        const pusher = new Pusher('<%= pusherKey %>', { cluster: '<%= pusherCluster %>', authEndpoint: '/pusher/auth' });
        const channel = pusher.subscribe('private-notifications-' + username.toLowerCase());

        channel.bind('road-dash-start', () => { if(!gameActive) beginRace(); });
        channel.bind('road-dash-sync', (data) => {
            opponent.targetX = data.x;
            opponent.lane = data.lane;
            opponent.crashed = data.state === 'crashed';
            opponent.shield = data.shield || 0;
            opponent.turbo = data.turbo || 0;
        });
        channel.bind('road-dash-action', (data) => {
            if (data.action === 'kick') handleOpponentKick(data.data);
            if (data.action === 'powerup') handleOpponentPowerup(data.data);
        });

        function resize() {
            width = canvas.width = Math.min(window.innerWidth, 500);
            height = canvas.height = window.innerHeight;
            player.y = height - 150;
            opponent.y = height - 150;
        }
        window.addEventListener('resize', resize);
        resize();

        function startGame() {
            document.getElementById('startOverlay').style.display = 'none';
            fetch('/api/games/road-dash/start', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ to: otherUser }) });
            beginRace();
        }

        function beginRace() {
            gameActive = true;
            distance = 0;
            speed = 5;
            playSound('engine', true);
            loop();
            spawnTraffic();
        }

        function playSound(id, loop = false) {
            const s = document.getElementById('snd-' + id);
            if (!s) return;
            s.currentTime = 0;
            s.loop = loop;
            s.play().catch(e => console.log("Audio blocked"));
        }

        function stopSound(id) {
            const s = document.getElementById('snd-' + id);
            if (s) s.pause();
        }

        function loop() {
            if (!gameActive) return;

            update();
            draw();
            requestAnimationFrame(loop);
        }

        function update() {
            if (player.crashed) {
                speed *= 0.95;
                if (speed < 0.1) speed = 0;
            } else {
                distance += speed / 10;
                let targetMax = player.turbo > 0 ? 25 : maxSpeed;
                if (speed < targetMax) speed += 0.05;
                if (speed > targetMax) speed -= 0.1;
                
                if (player.turbo > 0) {
                    player.turbo--;
                    if (player.turbo === 299) playSound('turbo');
                }
                if (player.shield > 0) player.shield--;
            }

            roadOffset = (roadOffset + speed) % 100;
            if (shake > 0) shake *= 0.9; else shake = 0;
            document.getElementById('distVal').innerText = Math.floor(distance) + 'm';

            // Interpolate positions
            player.x += (player.targetX - player.x) * 0.2;
            opponent.x += (opponent.targetX - opponent.x) * 0.2;

            // Traffic movement
            traffic.forEach((car, index) => {
                car.y += speed - car.speed;
                if (car.y > height + 100) traffic.splice(index, 1);
                if (!player.crashed && player.shield <= 0 && checkCollision(player, car)) crash('You hit a car!');
            });

            // Powerups movement
            powerups.forEach((p, index) => {
                p.y += speed;
                if (p.y > height + 100) powerups.splice(index, 1);
                if (!player.crashed && checkCollision(player, p)) collectPowerup(p, index);
            });

            // Rank check
            document.getElementById('rankVal').innerText = player.crashed ? 'CRASHED' : (distance > 0 ? '1st' : '2nd');

            // Sync with opponent periodically
            if (frameCount % 8 === 0) {
                fetch('/api/games/road-dash/sync', { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify({ 
                        to: otherUser, 
                        x: player.x, 
                        lane: player.lane, 
                        state: player.crashed ? 'crashed' : 'playing',
                        shield: player.shield,
                        turbo: player.turbo
                    }) 
                });
            }
            if (frameCount % 200 === 0 && !player.crashed) spawnPowerup();
            frameCount++;
        }

        let frameCount = 0;

        function checkCollision(p, obj) {
            const dx = p.x - obj.x;
            const dy = p.y - obj.y;
            return Math.abs(dx) < 40 && Math.abs(dy) < 60;
        }

        function draw() {
            ctx.save();
            if (shake > 0) ctx.translate((Math.random()-0.5)*shake, (Math.random()-0.5)*shake);
            ctx.clearRect(0, 0, width, height);

            // Draw Road
            ctx.fillStyle = '#15151a';
            ctx.fillRect(0, 0, width, height);

            // Lane Lines
            ctx.strokeStyle = 'rgba(255,255,255,0.1)';
            ctx.setLineDash([40, 60]);
            ctx.lineDashOffset = -roadOffset;
            for(let i=1; i<LANE_COUNT; i++) {
                const lx = i * (width / LANE_COUNT);
                ctx.beginPath();
                ctx.moveTo(lx, 0);
                ctx.lineTo(lx, height);
                ctx.stroke();
            }
            ctx.setLineDash([]);

            // Draw Traffic
            traffic.forEach(car => {
                ctx.fillStyle = car.color;
                ctx.shadowBlur = 15; ctx.shadowColor = car.color;
                roundRect(ctx, car.x - 20, car.y - 40, 40, 80, 8);
                ctx.shadowBlur = 0;
                // Headlights
                ctx.fillStyle = 'white';
                ctx.fillRect(car.x - 15, car.y - 45, 8, 5);
                ctx.fillRect(car.x + 7, car.y - 45, 8, 5);
            });

            // Draw Powerups
            powerups.forEach(p => {
                ctx.save();
                ctx.translate(p.x, p.y);
                ctx.font = '30px Arial';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.shadowBlur = 20; ctx.shadowColor = p.color;
                ctx.fillText(p.icon, 0, 0);
                ctx.restore();
            });

            // Draw Players
            drawPlayer(opponent, true);
            drawPlayer(player, false);
            
            // Particles
            drawParticles();
            ctx.restore();
        }

        function drawPlayer(p, isOpponent) {
            ctx.save();
            ctx.translate(p.x, p.y);
            if (p.crashed) ctx.rotate(frameCount * 0.2);
            
            // Shield Aura
            if (p.shield > 0) {
                ctx.beginPath();
                ctx.arc(0, 0, 45, 0, Math.PI*2);
                ctx.strokeStyle = '#4ade80';
                ctx.lineWidth = 3;
                ctx.stroke();
                ctx.globalAlpha = 0.2; ctx.fillStyle = '#4ade80'; ctx.fill(); ctx.globalAlpha = 1;
            }

            // Turbo Flame
            if (p.turbo > 0) {
                ctx.fillStyle = '#ff2d55';
                ctx.beginPath(); ctx.moveTo(-10, 40); ctx.lineTo(0, 70); ctx.lineTo(10, 40); ctx.fill();
            }

            ctx.font = '40px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.shadowBlur = 20; ctx.shadowColor = p.color;
            ctx.fillText(p.emoji, 0, 0);
            
            // Name tag
            ctx.font = '10px Outfit';
            ctx.fillStyle = 'white';
            ctx.fillText(p.name, 0, 40);
            
            ctx.restore();
        }

        // Interaction Handling
        window.onpointerdown = (e) => {
            if (!gameActive || player.crashed) return;
            if (e.target.id === 'kickBtn') { kick(); return; }
            
            const touchX = e.clientX;
            if (touchX < width / 2) {
                if (player.lane > 0) { player.lane--; playSound('whoosh'); }
            } else {
                if (player.lane < LANE_COUNT - 1) { player.lane++; playSound('whoosh'); }
            }
            player.targetX = (player.lane + 0.5) * (width / LANE_COUNT);
        };

        function kick() {
            if (player.crashed) return;
            // Check if opponent is close
            const dx = Math.abs(player.x - opponent.x);
            const dy = Math.abs(player.y - opponent.y);
            
            // Visual kick effect
            createParticles(player.x, player.y, player.color);
            playSound('kick');
            if ('vibrate' in navigator) navigator.vibrate(50);
            
            if (dx < 100 && dy < 80) {
                const dir = player.x < opponent.x ? 1 : -1;
                fetch('/api/games/road-dash/action', { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify({ to: otherUser, action: 'kick', data: { dir } }) 
                });
            }
        }

        function handleOpponentKick(data) {
            if (player.shield > 0) return; // Shield blocks kicks!
            shake = 15;
            playSound('kick');
            if ('vibrate' in navigator) navigator.vibrate([100, 50, 100]);
            createParticles(player.x, player.y, opponent.color);
            player.targetX += data.dir * 120;
            // If pushed out of bounds or into traffic...
            setTimeout(() => {
                if (player.x < 20 || player.x > width - 20) crash('Pushed off the road!');
            }, 200);
        }

        function spawnPowerup() {
            const types = [
                { type: 'turbo', icon: '⚡', color: '#ffcc00' },
                { type: 'shield', icon: '🛡️', color: '#4ade80' }
            ];
            const t = types[Math.floor(Math.random()*types.length)];
            const lane = Math.floor(Math.random() * LANE_COUNT);
            powerups.push({
                x: (lane + 0.5) * (width / LANE_COUNT),
                y: -100,
                ...t
            });
        }

        function collectPowerup(p, index) {
            powerups.splice(index, 1);
            if (p.type === 'turbo') player.turbo = 300;
            if (p.type === 'shield') player.shield = 400;
            
            const toast = document.getElementById('powerToast');
            toast.innerText = p.type.toUpperCase() + '!';
            toast.style.display = 'block';
            playSound('powerup');
            if ('vibrate' in navigator) navigator.vibrate(30);
            setTimeout(() => toast.style.display = 'none', 1000);
            
            fetch('/api/games/road-dash/action', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ to: otherUser, action: 'powerup', data: { type: p.type } }) 
            });
        }

        function handleOpponentPowerup(data) {
            // Just for visual sync
        }

        function spawnTraffic() {
            if (!gameActive) return;
            const lane = Math.floor(Math.random() * LANE_COUNT);
            const car = {
                x: (lane + 0.5) * (width / LANE_COUNT),
                y: -100,
                speed: 2 + Math.random() * 4,
                color: ['#ffcc00', '#4ade80', '#ff2d55', '#ffffff'][Math.floor(Math.random()*4)]
            };
            traffic.push(car);
            setTimeout(spawnTraffic, Math.max(400, 1500 - distance/2));
        }

        function crash(reason) {
            if (player.crashed || player.shield > 0) return;
            player.crashed = true;
            player.emoji = '💥';
            shake = 30;
            playSound('crash');
            stopSound('engine');
            if ('vibrate' in navigator) navigator.vibrate([200, 100, 200]);
            createParticles(player.x, player.y, '#ffcc00', 20);
            
            setTimeout(() => {
                gameActive = false;
                document.getElementById('endOverlay').style.display = 'flex';
                document.getElementById('endTitle').innerText = "CRASHED!";
                document.getElementById('endSub').innerText = reason;
            }, 1500);
        }

        // Utils
        function roundRect(ctx, x, y, width, height, radius) {
            ctx.beginPath(); ctx.moveTo(x + radius, y); ctx.lineTo(x + width - radius, y); ctx.quadraticCurveTo(x + width, y, x + width, y + radius); ctx.lineTo(x + width, y + height - radius); ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height); ctx.lineTo(x + radius, y + height); ctx.quadraticCurveTo(x, y + height, x, y + height - radius); ctx.lineTo(x, y + radius); ctx.quadraticCurveTo(x, y, x + radius, y); ctx.closePath(); ctx.fill();
        }

        function createParticles(x, y, color, count = 10) {
            for(let i=0; i<count; i++) {
                particles.push({
                    x, y, 
                    vx: (Math.random() - 0.5) * 10,
                    vy: (Math.random() - 0.5) * 10,
                    life: 1,
                    color
                });
            }
        }

        function drawParticles() {
            particles.forEach((p, i) => {
                p.x += p.vx; p.y += p.vy; p.life -= 0.02;
                if (p.life <= 0) { particles.splice(i, 1); return; }
                ctx.globalAlpha = p.life;
                ctx.fillStyle = p.color;
                ctx.beginPath(); ctx.arc(p.x, p.y, 3, 0, Math.PI*2); ctx.fill();
                ctx.globalAlpha = 1;
            });
        }
    </script>
</body>
</html>
